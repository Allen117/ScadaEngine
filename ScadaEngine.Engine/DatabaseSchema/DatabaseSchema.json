{
  "Tables": [
    {
      "TableName": "ModbusCoordinator",
      "Columns": [
        { "Name": "Id", "Type": "int", "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name", "Type": "varchar", "Length": 100, "Nullable": false },
        { "Name": "ModbusID", "Type": "varchar", "Length": 100, "Nullable": false },
        { "Name": "DeviceName", "Type": "nvarchar", "Length": 100, "Nullable": true },
        { "Name": "DelayTime", "Type": "int", "Default": 0, "Nullable": false },
        { "Name": "MonitorEnabled", "Type": "bit", "Default": true, "Nullable": false }
      ]
    },
    {
      "TableName": "HistoryData",
      "Columns": [
        { "Name": "SID", "Type": "nvarchar", "Length": 50, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "Value", "Type": "float", "Nullable": false },
        { "Name": "Quality", "Type": "int", "Nullable": false },
        { "Name": "Timestamp", "Type": "datetime", "IsPrimaryKey": true, "Nullable": false }
      ],
      "ClusteredIndex": ["SID", "Timestamp"]
    },
    {
      "TableName": "LatestData",
      "Columns": [
        { "Name": "SID", "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "Value", "Type": "float", "Nullable": true },
        { "Name": "Timestamp", "Type": "datetime", "Default": "getdate()", "Nullable": true },
        { "Name": "Quality", "Type": "int", "Default": 1, "Nullable": true }
      ]
    },
    {
      "TableName": "Users",
      "Columns": [
        { "Name": "UserID", "Type": "int", "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Username", "Type": "nvarchar", "Length": 50, "Nullable": false, "IsUnique": true },
        { "Name": "RealName", "Type": "nvarchar", "Length": 100, "Nullable": true },
        { "Name": "PasswordHash", "Type": "nvarchar", "Length": -1, "Nullable": false },
        { "Name": "Role", "Type": "nvarchar", "Length": 20, "Nullable": false },
        { "Name": "Department", "Type": "nvarchar", "Length": 50, "Nullable": true },
        { "Name": "IsActive", "Type": "bit", "Default": 1, "Nullable": true },
        { "Name": "LastLoginAt", "Type": "datetime", "Nullable": true },
        { "Name": "CreatedAt", "Type": "datetime", "Default": "getdate()", "Nullable": true },
        { "Name": "UpdatedAt", "Type": "datetime", "Default": "getdate()", "Nullable": true }
      ]
    },
    {
      "_comment": "系統層級鍵值設定 — 例如 first-run setup 完成旗標（SettingKey='SetupCompleted', SettingValue='1'）。一次性、不自動重開後門用。",
      "TableName": "SystemSettings",
      "Columns": [
        { "Name": "SettingKey",   "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "SettingValue", "Type": "nvarchar", "Length": -1,  "Nullable": true },
        { "Name": "UpdatedAt",    "Type": "datetime",                "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "TableName": "ConditionControlRules",
      "Columns": [
        { "Name": "Id",                 "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "ConditionPointSID",  "Type": "nvarchar", "Length": 100,        "Nullable": false },
        { "Name": "Operator",           "Type": "tinyint",                        "Nullable": false,
          "_comment": "0=>  1=<  2=>=  3=<=  4===  5=!=" },
        { "Name": "ConditionValue",     "Type": "float",                          "Nullable": false },
        { "Name": "ControlPointSID",    "Type": "nvarchar", "Length": 100,        "Nullable": false },
        { "Name": "ControlValue",       "Type": "float",                          "Nullable": false },
        { "Name": "Remarks",            "Type": "nvarchar", "Length": 50,         "Nullable": true  },
        { "Name": "IsEnabled",          "Type": "bit",                            "Nullable": false, "Default": 1 },
        { "Name": "CreatedAt",          "Type": "datetime",                       "Nullable": true,  "Default": "getdate()" }
      ]
    },
    {
      "TableName": "ModbusPoints",
      "Columns": [
        { "Name": "SID", "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "Name", "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "Address", "Type": "nvarchar", "Length": 50, "Nullable": false },
        { "Name": "DataType", "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "Ratio", "Type": "float", "Default": 1.0, "Nullable": false },
        { "Name": "Unit", "Type": "nvarchar", "Length": 50, "Nullable": false },
        { "Name": "Min", "Type": "float", "Nullable": true },
        { "Name": "Max", "Type": "float", "Nullable": true }
      ]
    },
    {
      "_comment": "畫面設計 — 版本紀錄。IsPublished=1 的那筆為即時監控顯示的設計。",
      "TableName": "ScadaDesign",
      "Columns": [
        { "Name": "Id",          "Type": "int",          "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",        "Type": "nvarchar",     "Length": 100,        "Nullable": false, "Default": "未命名設計" },
        { "Name": "IsPublished", "Type": "bit",                                "Nullable": false, "Default": 0,
          "_comment": "1 = 即時監控顯示此版本，同時只有一筆應為 1" },
        { "Name": "SavedAt",     "Type": "datetime",                           "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "畫面設計 — 各頁面資料。WidgetStateJson 儲存該頁 widget 陣列 JSON；BgDataUrl 儲存背景圖 base64（獨立欄位避免全樹讀取時搬運大量圖片資料）。",
      "TableName": "ScadaDesignPage",
      "Columns": [
        { "Name": "Id",             "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "DesignId",       "Type": "int",                            "Nullable": false,
          "_comment": "FK → ScadaDesign.Id（由應用程式保證一致性）" },
        { "Name": "PageSid",        "Type": "nvarchar", "Length": 50,         "Nullable": false,
          "_comment": "對應前端 szId，例如 p1、p2-1" },
        { "Name": "ParentPageSid",  "Type": "nvarchar", "Length": 50,         "Nullable": true,
          "_comment": "父頁面 szId；NULL 表示根節點" },
        { "Name": "SortOrder",      "Type": "int",                            "Nullable": false, "Default": 0,
          "_comment": "同層頁面的顯示順序（由 0 起算）" },
        { "Name": "PageName",       "Type": "nvarchar", "Length": 100,        "Nullable": false },
        { "Name": "PageIcon",       "Type": "nvarchar", "Length": 50,         "Nullable": true,
          "_comment": "FontAwesome class，例如 fa-home" },
        { "Name": "CanvasW",        "Type": "int",                            "Nullable": false, "Default": 1200 },
        { "Name": "CanvasH",        "Type": "int",                            "Nullable": false, "Default": 800  },
        { "Name": "BgFileName",     "Type": "nvarchar", "Length": 255,        "Nullable": true  },
        { "Name": "BgDataUrl",      "Type": "nvarchar", "Length": -1,         "Nullable": true,
          "_comment": "背景圖 base64 DataURL；nvarchar(MAX)" },
        { "Name": "WidgetStateJson","Type": "nvarchar", "Length": -1,         "Nullable": true,
          "_comment": "該頁 widget 陣列 JSON，格式: [{szType,nX,nY,nW,nH,props:{...}}]" }
      ]
    },
    {
      "_comment": "事件/警報記錄表 — 記錄警報觸發、恢復、確認的完整生命週期",
      "TableName": "EventLog",
      "Columns": [
        { "Name": "Id",             "Type": "bigint",    "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false,
          "_comment": "自動遞增流水號，用 bigint 因為事件量大" },
        { "Name": "SID",            "Type": "nvarchar",  "Length": 100,  "Nullable": false,
          "_comment": "觸發事件的測點 SID，例如 196865-S1" },
        { "Name": "EventType",      "Type": "tinyint",                   "Nullable": false,
          "_comment": "0=警報(Alarm) 1=故障(Fault) 2=警告(Warning) 3=資訊(Info) 4=系統(System)" },
        { "Name": "Severity",       "Type": "tinyint",                   "Nullable": false, "Default": 1,
          "_comment": "嚴重程度: 0=緊急 1=高 2=中 3=低" },
        { "Name": "TriggerValue",   "Type": "float",                     "Nullable": true,
          "_comment": "觸發當下的測點數值" },
        { "Name": "ThresholdValue", "Type": "float",                     "Nullable": true,
          "_comment": "被違反的門檻值（上限/下限）" },
        { "Name": "Operator",       "Type": "tinyint",                   "Nullable": true,
          "_comment": "比較運算子: 0=> 1=< 2=>= 3=<= 4=== 5=!=，與 ConditionControlRules 一致" },
        { "Name": "Message",        "Type": "nvarchar",  "Length": 500,  "Nullable": false,
          "_comment": "事件描述文字（人類可讀 fallback），例如 '溫度超過上限 85°C'" },
        { "Name": "MessageKey",     "Type": "nvarchar",  "Length": 64,   "Nullable": true,
          "_comment": "結構化訊息 i18n key，例如 'alarm.high_exceed'；舊資料為 NULL，Web 顯示時 fallback 用 Message 欄" },
        { "Name": "MessageArgs",    "Type": "nvarchar",  "Length": 512,  "Nullable": true,
          "_comment": "結構化訊息參數 JSON，例如 '{\"name\":\"溫度\",\"threshold\":\"85.0\"}'，Web 顯示時與 MessageKey 套模板" },
        { "Name": "OccurredAt",     "Type": "datetime",                  "Nullable": false, "Default": "getdate()",
          "_comment": "事件發生時間" },
        { "Name": "ClearedAt",      "Type": "datetime",                  "Nullable": true,
          "_comment": "事件恢復/解除時間，NULL 表示仍在發生中" },
        { "Name": "IsAcknowledged", "Type": "bit",                       "Nullable": false, "Default": 0,
          "_comment": "是否已被操作人員確認" },
        { "Name": "AcknowledgedBy", "Type": "nvarchar",  "Length": 50,   "Nullable": true,
          "_comment": "確認人員的 Username" },
        { "Name": "AcknowledgedAt", "Type": "datetime",                  "Nullable": true,
          "_comment": "確認時間" },
        { "Name": "Remarks",        "Type": "nvarchar",  "Length": 500,  "Nullable": true,
          "_comment": "操作人員備註" },
        { "Name": "NotifyChannel",      "Type": "nvarchar",  "Length": 10,   "Nullable": true,
          "_comment": "通知摘要專用：'Email' | 'Line'；普通 alarm 事件為 NULL" },
        { "Name": "NotifyStatus",       "Type": "tinyint",                   "Nullable": true,
          "_comment": "0=AllSent 1=PartialFailed 2=AllFailed 3=RateLimited 4=NoTarget 5=Disabled" },
        { "Name": "NotifyDetail",       "Type": "nvarchar",  "Length": 500,  "Nullable": true,
          "_comment": "人類可讀的通知結果摘要" },
        { "Name": "NotifyRelatedEventId","Type": "bigint",                   "Nullable": true,
          "_comment": "通知摘要事件關聯到的 alarm EventLog.Id" }
      ],
      "ClusteredIndex": ["OccurredAt", "SID"]
    },
    {
      "_comment": "警報規則表 — 每個 SID 一筆規則，定義上限/下限/DI 警報條件",
      "TableName": "AlarmRules",
      "Columns": [
        { "Name": "Id",                "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "SID",               "Type": "nvarchar", "Length": 100, "Nullable": false,
          "_comment": "測點 SID，例如 196865-S1" },
        { "Name": "IsEnabled",         "Type": "bit",      "Nullable": false, "Default": 1,
          "_comment": "總開關" },
        { "Name": "IsAlarmHigh",       "Type": "bit",      "Nullable": false, "Default": 0 },
        { "Name": "AlarmHighValue",    "Type": "float",    "Nullable": true },
        { "Name": "DeadbandHigh",      "Type": "float",    "Nullable": true, "Default": 0 },
        { "Name": "AlarmHighSeverity", "Type": "tinyint",  "Nullable": false, "Default": 1,
          "_comment": "0=緊急 1=高 2=中 3=低" },
        { "Name": "IsAlarmLow",        "Type": "bit",      "Nullable": false, "Default": 0 },
        { "Name": "AlarmLowValue",     "Type": "float",    "Nullable": true },
        { "Name": "DeadbandLow",       "Type": "float",    "Nullable": true, "Default": 0 },
        { "Name": "AlarmLowSeverity",  "Type": "tinyint",  "Nullable": false, "Default": 1 },
        { "Name": "IsDiAlarm",         "Type": "bit",      "Nullable": false, "Default": 0,
          "_comment": "DI 點位專用" },
        { "Name": "DiTriggerState",    "Type": "nvarchar", "Length": 10,  "Nullable": true,
          "_comment": "'ON' 或 'OFF'" },
        { "Name": "DiAlarmSeverity",   "Type": "tinyint",  "Nullable": false, "Default": 1 },
        { "Name": "DiOnLabel",         "Type": "nvarchar", "Length": 50,  "Nullable": true,
          "_comment": "DI ON 狀態的顯示名稱，例如 '運轉'" },
        { "Name": "DiOffLabel",        "Type": "nvarchar", "Length": 50,  "Nullable": true,
          "_comment": "DI OFF 狀態的顯示名稱，例如 '停止'" },
        { "Name": "Remarks",           "Type": "nvarchar", "Length": 200, "Nullable": true },
        { "Name": "CreatedAt",         "Type": "datetime", "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",         "Type": "datetime", "Nullable": true }
      ]
    },
    {
      "_comment": "AO 手動控制上次輸出值 — 以 SID 為主鍵，UPSERT 最新一筆",
      "TableName": "ManualControlValue",
      "Columns": [
        { "Name": "SID",       "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "Value",     "Type": "float",                   "Nullable": false },
        { "Name": "IsAuto",    "Type": "bit",                     "Nullable": false, "Default": 0,
          "_comment": "1=目前為自動控制, 0=手動控制" },
        { "Name": "UpdatedAt", "Type": "datetime",                "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "流程圖控制 — 樹狀結構（資料夾與邏輯節點）",
      "TableName": "LogicFlowTree",
      "Columns": [
        { "Name": "Id",        "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "ParentId",  "Type": "int",                            "Nullable": true,
          "_comment": "父節點 Id；NULL 表示根層級" },
        { "Name": "Name",      "Type": "nvarchar", "Length": 100,        "Nullable": false },
        { "Name": "NodeType",  "Type": "nvarchar", "Length": 10,         "Nullable": false,
          "_comment": "'folder' 或 'logic'" },
        { "Name": "SortOrder", "Type": "int",                            "Nullable": false, "Default": 0,
          "_comment": "同層排序（由 0 起算）" },
        { "Name": "IsEnabled", "Type": "bit",                            "Nullable": false, "Default": 1,
          "_comment": "啟用/停用邏輯（僅 logic 類型有意義）" },
        { "Name": "CreatedAt", "Type": "datetime",                       "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt", "Type": "datetime",                       "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "流程圖控制 — 圖形內容（一個邏輯節點對應一筆）",
      "TableName": "LogicFlowDiagram",
      "Columns": [
        { "Name": "TreeId",      "Type": "int",      "IsPrimaryKey": true, "Nullable": false,
          "_comment": "FK → LogicFlowTree.Id（由應用程式保證一致性）" },
        { "Name": "DiagramJson", "Type": "nvarchar", "Length": -1,         "Nullable": true,
          "_comment": "完整流程圖 JSON（nodes + edges）；nvarchar(MAX)" },
        { "Name": "Version",     "Type": "int",                            "Nullable": false, "Default": 1,
          "_comment": "樂觀鎖版本號" },
        { "Name": "UpdatedAt",   "Type": "datetime",                       "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "使用者權限設定 — 每個 User 角色帳號對應一筆，Admin 不需要（全權限）",
      "TableName": "UserPermissions",
      "Columns": [
        { "Name": "UserID",         "Type": "int",      "IsPrimaryKey": true, "Nullable": false,
          "_comment": "FK → Users.UserID（由應用程式保證一致性）" },
        { "Name": "PermissionJson", "Type": "nvarchar", "Length": -1,         "Nullable": false, "Default": "{}",
          "_comment": "JSON 格式權限設定：{pages:[...], scadaPages:{pageSid:{canView,canControl}}}" },
        { "Name": "UpdatedAt",      "Type": "datetime",                       "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "時間排程表 — 供 LogicFlow A接點排程模式使用，每筆為一個時段",
      "TableName": "TimeSchedules",
      "Columns": [
        { "Name": "Id",              "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",            "Type": "nvarchar", "Length": 100,  "Nullable": false,
          "_comment": "排程名稱，例如 '上班時間'" },
        { "Name": "RecurrenceType",  "Type": "tinyint",                  "Nullable": false, "Default": 0,
          "_comment": "0=每週 1=N週循環 2=每月 3=N月循環" },
        { "Name": "RunLength",       "Type": "int",                      "Nullable": true,
          "_comment": "跑幾週/月（type 1,3 時必填），例如 1=跑1週/月" },
        { "Name": "RestLength",      "Type": "int",                      "Nullable": true,
          "_comment": "休幾週/月（type 1,3 時必填），例如 1=休1週/月" },
        { "Name": "AnchorDateTime",  "Type": "datetime",                 "Nullable": true,
          "_comment": "週期起算時刻，精確到分鐘，決定交替切換點（type 1,3 時必填）" },
        { "Name": "DaysOfWeek",      "Type": "nvarchar", "Length": 50,   "Nullable": true,
          "_comment": "星期幾，逗號分隔: 1=週一...7=週日，例如 '1,2,3,4,5'（type 0,1 時使用）" },
        { "Name": "DaysOfMonth",     "Type": "nvarchar", "Length": 100,  "Nullable": true,
          "_comment": "每月幾號，逗號分隔，例如 '1,15'（type 2,3 時使用）" },
        { "Name": "StartTime",       "Type": "nvarchar", "Length": 10,   "Nullable": false,
          "_comment": "開始時間，24小時制 HH:mm，例如 '08:00'" },
        { "Name": "EndTime",         "Type": "nvarchar", "Length": 10,   "Nullable": false,
          "_comment": "結束時間，24小時制 HH:mm，例如 '17:00'" },
        { "Name": "ExcludeDates",    "Type": "nvarchar", "Length": -1,   "Nullable": true,
          "_comment": "例外日清單（當天不啟動），逗號分隔 yyyy-MM-dd，例如 '2026-05-15,2026-05-16'" },
        { "Name": "IncludeDates",    "Type": "nvarchar", "Length": -1,   "Nullable": true,
          "_comment": "加開日清單（當天無視重複規則強制啟動），逗號分隔 yyyy-MM-dd" },
        { "Name": "IsEnabled",       "Type": "bit",                      "Nullable": false, "Default": 1 },
        { "Name": "Remarks",         "Type": "nvarchar", "Length": 200,  "Nullable": true },
        { "Name": "CreatedAt",       "Type": "datetime",                 "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",       "Type": "datetime",                 "Nullable": true }
      ]
    },
    {
      "_comment": "計算點位設定 — 使用者自訂公式，從多個原始點位衍生計算值",
      "TableName": "CalculatedPoints",
      "Columns": [
        { "Name": "SID",             "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false,
          "_comment": "計算點位 SID，格式: CALC-S{N}" },
        { "Name": "Name",            "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "Unit",            "Type": "nvarchar", "Length": 50,  "Nullable": true },
        { "Name": "GroupName", "Type": "nvarchar", "Length": 100, "Nullable": true,
          "_comment": "歸屬群組，用於 MQTT 主題分類" },
        { "Name": "Formula",         "Type": "nvarchar", "Length": 500, "Nullable": false,
          "_comment": "計算公式，變數名對應 InputMappings 的 key" },
        { "Name": "InputMappings",   "Type": "nvarchar", "Length": -1,  "Nullable": false,
          "_comment": "JSON: {\"變數名\":\"SID\", ...}；nvarchar(MAX)" },
        { "Name": "IsEnabled",       "Type": "bit",      "Nullable": false, "Default": 1 },
        { "Name": "CreatedAt",       "Type": "datetime", "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",       "Type": "datetime", "Nullable": true }
      ]
    },
    {
      "_comment": "水系統迴路階層（自參照樹）。葉子綁 RT 系列點位的 SID，虛擬節點不綁 SID。獨立於 EnergyCircuit — 領域分離。",
      "TableName": "WaterCircuit",
      "Columns": [
        { "Name": "Id",          "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",        "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "ParentId",    "Type": "int",                     "Nullable": true,
          "_comment": "父節點 Id；NULL 表示根層級（self-FK，由應用程式保證一致性）" },
        { "Name": "SortOrder",   "Type": "int",                     "Nullable": false, "Default": 0,
          "_comment": "同層排序（由 0 起算）" },
        { "Name": "SID",         "Type": "nvarchar", "Length": 100, "Nullable": true,
          "_comment": "葉子綁實體點位（Modbus / Calculated / DB）；虛擬迴路為 NULL。下拉僅列 RT 系列單位" },
        { "Name": "Description", "Type": "nvarchar", "Length": 500, "Nullable": true },
        { "Name": "CreatedAt",   "Type": "datetime",                "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",   "Type": "datetime",                "Nullable": true }
      ]
    },
    {
      "_comment": "能源管理 — 電表/迴路階層（自參照樹）。葉子綁 SID + MaxKwh，虛擬節點不綁 SID。",
      "TableName": "EnergyCircuit",
      "Columns": [
        { "Name": "Id",          "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",        "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "ParentId",    "Type": "int",                     "Nullable": true,
          "_comment": "父節點 Id；NULL 表示根層級（self-FK，由應用程式保證一致性）" },
        { "Name": "SortOrder",   "Type": "int",                     "Nullable": false, "Default": 0,
          "_comment": "同層排序（由 0 起算）" },
        { "Name": "SID",         "Type": "nvarchar", "Length": 100, "Nullable": true,
          "_comment": "葉子綁 ModbusPoints/CalculatedPoints 的 SID；虛擬迴路為 NULL" },
        { "Name": "MaxKwh",      "Type": "float",                   "Nullable": true,
          "_comment": "電表累積最大值（kWh），用於溢位/重置判定。葉子才有意義" },
        { "Name": "Sign",        "Type": "int",                     "Nullable": false, "Default": 1,
          "_comment": "對父節點的貢獻方向：+1=正向加入、-1=反向扣減。根節點固定 +1" },
        { "Name": "IsDemandEnabled", "Type": "bit", "Nullable": false, "Default": 0,
          "_comment": "是否啟用需量計算（ΔkWh×4 算法，直接使用本迴路 SID）；僅葉子有意義" },
        { "Name": "IsMainMeter", "Type": "bit", "Nullable": false, "Default": 0,
          "_comment": "主要電表標記 — 全系統唯一（應用層保證：勾新的自動取消舊的）；僅實體電表（綁 SID）有意義" },
        { "Name": "Description", "Type": "nvarchar", "Length": 500, "Nullable": true },
        { "Name": "CreatedAt",   "Type": "datetime",                "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",   "Type": "datetime",                "Nullable": true }
      ]
    },
    {
      "_comment": "DB 來源 — 將外部資料庫寫入的點位納入 SCADA SID 體系，每個 Coordinator 預留 100 個 slot。Name UNIQUE，UPSERT by Name 保 Id 穩定。",
      "TableName": "DBCoordinator",
      "Columns": [
        { "Name": "Id",              "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",            "Type": "nvarchar", "Length": 100, "Nullable": false, "IsUnique": true,
          "_comment": "= sheet name = JSON 檔名" },
        { "Name": "PollingInterval", "Type": "int",                     "Nullable": false, "Default": 1000,
          "_comment": "毫秒" },
        { "Name": "ConnectTimeout",  "Type": "int",                     "Nullable": false, "Default": 1000,
          "_comment": "毫秒；polling 讀 DBLatestData 時換算成 SqlCommand.CommandTimeout（秒，向上取整）" },
        { "Name": "MonitorEnabled",  "Type": "bit",                     "Nullable": false, "Default": 1 },
        { "Name": "CreatedAt",       "Type": "datetime",                "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "DB 來源點位 — SID 格式 DB{CoordinatorId}-S{Sequence}；Sequence 由載入器以 JSON 陣列順序自動填，1~100。",
      "TableName": "DBPoints",
      "Columns": [
        { "Name": "SID",           "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false,
          "_comment": "DB{CoordinatorId}-S{Sequence}" },
        { "Name": "CoordinatorId", "Type": "int",                     "Nullable": false },
        { "Name": "Sequence",      "Type": "int",                     "Nullable": false,
          "_comment": "1~100；由載入器以 JSON 陣列索引+1 自動產生（與 Modbus 對齊）" },
        { "Name": "Name",          "Type": "nvarchar", "Length": 100, "Nullable": false },
        { "Name": "Unit",          "Type": "nvarchar", "Length": 50,  "Nullable": true },
        { "Name": "Min",           "Type": "float",                   "Nullable": false, "Default": 0.0,
          "_comment": "UI 顯示下限 + 控制寫入下限（寫入路徑做時驗證）" },
        { "Name": "Max",           "Type": "float",                   "Nullable": false, "Default": 100.0,
          "_comment": "UI 顯示上限 + 控制寫入上限（寫入路徑做時驗證）" }
      ]
    },
    {
      "_comment": "DB 來源統一入口表 — 外部系統 INSERT/UPDATE 此表，Engine 依 SID prefix 分群 polling。寫入路徑（Phase 2）也統一 UPDATE 此表。",
      "TableName": "DBLatestData",
      "Columns": [
        { "Name": "SID",       "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "Value",     "Type": "float",                   "Nullable": true },
        { "Name": "Timestamp", "Type": "datetime",                "Nullable": true,  "Default": "getdate()" },
        { "Name": "Quality",   "Type": "int",                     "Nullable": true,  "Default": 1 }
      ]
    },
    {
      "_comment": "能源管理 — 葉子層 hourly 預聚合表。一列 = 一個葉子 SID 在某個小時的 kWh 增量（已套 MaxKwh 溢位、未套 sign）。Quality=0 表示掉線 transition（只缺一邊邊界），兩邊都缺則不寫該列（sparse storage）。",
      "TableName": "EnergyLeafHourly",
      "Columns": [
        { "Name": "SID",          "Type": "nvarchar", "Length": 50, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "HourStart",    "Type": "datetime",               "IsPrimaryKey": true, "Nullable": false,
          "_comment": "小時起點（local time，與 HistoryData.Timestamp 同基準）" },
        { "Name": "DeltaKwh",     "Type": "float",                  "Nullable": false,
          "_comment": "該小時 kWh 增量；Quality=0 時恆為 0" },
        { "Name": "Quality",      "Type": "tinyint",                "Nullable": false, "Default": 1,
          "_comment": "1=Good, 0=掉線 transition" },
        { "Name": "IsRolledOver", "Type": "bit",                    "Nullable": false, "Default": 0,
          "_comment": "是否觸發 MaxKwh 溢位修正" },
        { "Name": "CreatedAt",    "Type": "datetime",               "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "冷凍噸報表 — 葉子層 hourly 預聚合表。一列 = 一個葉子 SID 在某個小時的 RT·h（冷量，= AVG(RT) × 1h）。SampleCount < 30 視為資料不足，整列不寫（sparse storage）。",
      "TableName": "WaterLeafHourly",
      "Columns": [
        { "Name": "SID",          "Type": "nvarchar", "Length": 50, "IsPrimaryKey": true, "Nullable": false },
        { "Name": "HourStart",    "Type": "datetime",               "IsPrimaryKey": true, "Nullable": false,
          "_comment": "小時起點（local time，與 HistoryData.Timestamp 同基準）" },
        { "Name": "RtHour",       "Type": "float",                  "Nullable": false,
          "_comment": "該小時 RT·h（冷量）= AVG(RT samples in hour) × 1h" },
        { "Name": "SampleCount",  "Type": "int",                    "Nullable": false, "Default": 0,
          "_comment": "該小時 HistoryData 樣本數（Quality=1）。資料完整度判定，預設門檻 30" },
        { "Name": "Quality",      "Type": "tinyint",                "Nullable": false, "Default": 1,
          "_comment": "1=Good。保留欄位供未來擴充" },
        { "Name": "IsBackfilled", "Type": "bit",                    "Nullable": false, "Default": 0,
          "_comment": "是否由 backfill 流程寫入（目前固定 false）" },
        { "Name": "CreatedAt",    "Type": "datetime",               "Nullable": false, "Default": "getdate()" }
      ]
    },
    {
      "_comment": "需量計算結果 — 每分鐘寫一筆（每個啟用 IsDemandEnabled 的迴路各一），ΔkWh×4 法（取 15min 窗口首尾兩筆 kWh 差值×4）",
      "TableName": "DemandData",
      "Columns": [
        { "Name": "SID",         "Type": "nvarchar", "Length": 100, "IsPrimaryKey": true,  "Nullable": false,
          "_comment": "對應 EnergyCircuit.SID（kWh 點位 SID，即迴路本身的度數點位）" },
        { "Name": "Timestamp",   "Type": "datetime",               "IsPrimaryKey": true,  "Nullable": false,
          "_comment": "計算時刻，truncate 到整分鐘（local time）" },
        { "Name": "DemandKW",    "Type": "float",                  "Nullable": false,
          "_comment": "15min 滑動時間加權平均功率 kW；Quality=0 時為 0" },
        { "Name": "WindowStart", "Type": "datetime",               "Nullable": false,
          "_comment": "本次計算窗口起點（= Timestamp - 15min）" },
        { "Name": "SampleCount", "Type": "int",                    "Nullable": false,
          "_comment": "窗口內 Quality=1 的樣本數；< 2 則 Quality=0" },
        { "Name": "Quality",     "Type": "tinyint",                "Nullable": false, "Default": 1,
          "_comment": "1=Good, 0=資料不足（SampleCount < 2）或 ΔkWh < 0（電表重置）" }
      ],
      "ClusteredIndex": ["SID", "Timestamp"]
    },
    {
      "_comment": "Line 通知收件群組 — 警報觸發時推播 Line 訊息的目標群組清單",
      "TableName": "LineNotifyTargets",
      "Columns": [
        { "Name": "Id",           "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "GroupId",      "Type": "nvarchar", "Length": 64,  "Nullable": false,
          "_comment": "Line GroupID，C 開頭 33 字元" },
        { "Name": "Label",        "Type": "nvarchar", "Length": 100, "Nullable": false,
          "_comment": "顯示名稱，例如 '主管群'、'值班工程群'" },
        { "Name": "MaxSeverity",  "Type": "tinyint",                 "Nullable": false, "Default": 3,
          "_comment": "接收上限：0=只收 Critical, 1=Critical+High, 2=Critical+High+Medium, 3=全收" },
        { "Name": "Language",     "Type": "nvarchar", "Length": 10,  "Nullable": false, "Default": "zh-TW",
          "_comment": "推播訊息語系：'zh-TW' 或 'en'" },
        { "Name": "IsEnabled",    "Type": "bit",                     "Nullable": false, "Default": 1 },
        { "Name": "CreatedAt",    "Type": "datetime",                "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",    "Type": "datetime",                "Nullable": true }
      ]
    },
    {
      "_comment": "Email 通知收件群組 — 警報觸發時寄信給此群組所有收件人",
      "TableName": "EmailGroups",
      "Columns": [
        { "Name": "Id",           "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "Name",         "Type": "nvarchar", "Length": 100, "Nullable": false, "IsUnique": true,
          "_comment": "群組唯一識別名稱，例如 'shift_engineers'" },
        { "Name": "Label",        "Type": "nvarchar", "Length": 100, "Nullable": false,
          "_comment": "顯示名稱，例如 '值班工程師'" },
        { "Name": "MaxSeverity",  "Type": "tinyint",                 "Nullable": false, "Default": 3,
          "_comment": "0=只收 Critical, 1=Critical+High, 2=Critical+High+Medium, 3=全收" },
        { "Name": "Language",     "Type": "nvarchar", "Length": 10,  "Nullable": false, "Default": "zh-TW",
          "_comment": "通知訊息語系：'zh-TW' 或 'en'" },
        { "Name": "IsEnabled",    "Type": "bit",                     "Nullable": false, "Default": 1 },
        { "Name": "Remarks",      "Type": "nvarchar", "Length": 200, "Nullable": true },
        { "Name": "CreatedAt",    "Type": "datetime",                "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",    "Type": "datetime",                "Nullable": true }
      ]
    },
    {
      "_comment": "Email 收件人清單 — 一個群組可有多個收件人",
      "TableName": "EmailRecipients",
      "Columns": [
        { "Name": "Id",           "Type": "int",      "IsPrimaryKey": true, "IsIdentity": true, "Nullable": false },
        { "Name": "GroupId",      "Type": "int",                     "Nullable": false,
          "_comment": "FK → EmailGroups.Id" },
        { "Name": "EmailAddress", "Type": "nvarchar", "Length": 200, "Nullable": false },
        { "Name": "DisplayName",  "Type": "nvarchar", "Length": 100, "Nullable": true },
        { "Name": "IsEnabled",    "Type": "bit",                     "Nullable": false, "Default": 1 },
        { "Name": "CreatedAt",    "Type": "datetime",                "Nullable": false, "Default": "getdate()" },
        { "Name": "UpdatedAt",    "Type": "datetime",                "Nullable": true }
      ]
    },
    {
      "_comment": "Email 群組-警報規則 對應表（多對多）。空對應視同收所有規則的警報。",
      "TableName": "EmailGroupRuleMap",
      "Columns": [
        { "Name": "GroupId",     "Type": "int", "IsPrimaryKey": true, "Nullable": false,
          "_comment": "FK → EmailGroups.Id" },
        { "Name": "AlarmRuleId", "Type": "int", "IsPrimaryKey": true, "Nullable": false,
          "_comment": "FK → AlarmRules.Id" },
        { "Name": "CreatedAt",   "Type": "datetime",                   "Nullable": false, "Default": "getdate()" }
      ]
    }
  ]
}