  "notify.body.triggered.html": "<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;margin:0;padding:0;background:#f4f4f4;'><table cellpadding='0' cellspacing='0' style='width:100%;max-width:600px;margin:20px auto;background:#fff;border:1px solid #ddd;'><tr><td style='background:{color};color:#fff;padding:14px 20px;font-size:18px;font-weight:bold;'>{icon} Alarm Triggered [{severity}]</td></tr><tr><td style='padding:20px;'><table style='width:100%;border-collapse:collapse;'><tr><td style='padding:8px 0;color:#666;width:110px;'>Triggered At</td><td style='padding:8px 0;'>{time}</td></tr><tr><td style='padding:8px 0;color:#666;'>Point Name</td><td style='padding:8px 0;font-weight:bold;'>{name}</td></tr><tr><td style='padding:8px 0;color:#666;vertical-align:top;'>Description</td><td style='padding:8px 0;'>{message}</td></tr></table></td></tr><tr><td style='background:#f9f9f9;color:#999;padding:10px 20px;font-size:12px;text-align:center;'>Auto-sent by SCADA system. Do not reply.</td></tr></table></body></html>",
  "notify.body.cleared.html": "<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;margin:0;padding:0;background:#f4f4f4;'><table cellpadding='0' cellspacing='0' style='width:100%;max-width:600px;margin:20px auto;background:#fff;border:1px solid #ddd;'><tr><td style='background:#28a745;color:#fff;padding:14px 20px;font-size:18px;font-weight:bold;'>✅ Alarm Cleared</td></tr><tr><td style='padding:20px;'><table style='width:100%;border-collapse:collapse;'><tr><td style='padding:8px 0;color:#666;width:110px;'>Cleared At</td><td style='padding:8px 0;'>{time}</td></tr><tr><td style='padding:8px 0;color:#666;'>Point Name</td><td style='padding:8px 0;font-weight:bold;'>{name}</td></tr><tr><td style='padding:8px 0;color:#666;vertical-align:top;'>Description</td><td style='padding:8px 0;'>{message}</td></tr></table></td></tr><tr><td style='background:#f9f9f9;color:#999;padding:10px 20px;font-size:12px;text-align:center;'>Auto-sent by SCADA system. Do not reply.</td></tr></table></body></html>",
  "notify.body.test.html": "<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;'><h3>📨 SCADA Test Message</h3><p>Group: <b>{label}</b></p><p>Time: {time}</p><p>If you receive this, your Email notification settings are correct.</p></body></html>",

