@{
    ViewData["Title"] = Localizer["designer.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* asp-append-version：檔案內容 hash 進 query string，改版後瀏覽器不會吃到舊快取 CSS *@
<link rel="stylesheet" href="~/css/designer.css" asp-append-version="true" />

<!-- Designer 主容器 -->
<div class="designer-outer" id="designerOuter">

        <!-- ===== 工具列 ===== -->
        <div class="designer-toolbar">
            <i class="fas fa-paint-brush text-primary me-1"></i>
            <span class="text-white fw-semibold" style="font-size:13px;">@Localizer["designer.title"]</span>

            <div style="width:1px;height:16px;background:#555;margin:0 4px;"></div>

            <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:12px;"
                    onclick="clearCanvas()" title="@Localizer["designer.toolbar.clear_tooltip"]">
                <i class="fas fa-trash-alt me-1"></i>@Localizer["designer.toolbar.clear"]
            </button>

            <button class="btn btn-sm btn-outline-warning py-0 px-2" style="font-size:12px;"
                    onclick="triggerImportImage()" title="@Localizer["designer.toolbar.import_image_tooltip"]">
                <i class="fas fa-file-image me-1"></i>@Localizer["designer.toolbar.import_image"]
            </button>

            <!-- 隱藏的 file input，僅接受圖片格式 -->
            <input type="file" id="imgFileInput" accept="image/*" style="display:none"
                   onchange="onImageFileSelected(this)">

            <!-- 已匯入圖片時顯示的資訊列 -->
            <span id="bgImgBadge" style="display:none;align-items:center;gap:6px;
                  background:#3a3a1a;border:1px solid #665500;border-radius:4px;
                  padding:2px 8px;font-size:11px;color:#ffc107;">
                <i class="fas fa-image"></i>
                <span id="bgImgName"></span>
                <span id="bgImgSize" style="color:#aaa;"></span>
                <button onclick="clearBgImage()" style="background:none;border:none;
                        color:#ff8888;cursor:pointer;padding:0 2px;font-size:12px;"
                        title="@Localizer["designer.toolbar.bg_remove"]">✕</button>
            </span>

            <button id="btnSave" class="btn btn-sm btn-success py-0 px-2" style="font-size:12px;"
                    onclick="saveDesign()" title="@Localizer["designer.toolbar.save_tooltip"]">
                <i class="fas fa-save me-1"></i>@Localizer["designer.toolbar.save"]
            </button>

            <!-- ===== 對齊工具群組（≥ 2 選取時顯示） ===== -->
            <div id="alignToolGroup" class="align-tool-group" style="display:none;">
                <div class="align-tool-sep"></div>
                <button type="button" class="align-tool-btn" onclick="alignLeft()"
                        title="@Localizer["designer.toolbar.align_left_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_left"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="1" y1="1" x2="1" y2="15" stroke="currentColor" stroke-width="1.4"/>
                        <rect x="2" y="3" width="11" height="3"/>
                        <rect x="2" y="9" width="7" height="3"/>
                    </svg>
                </button>
                <button type="button" class="align-tool-btn" onclick="alignCenterH()"
                        title="@Localizer["designer.toolbar.align_center_h_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_center_h"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="8" y1="1" x2="8" y2="15" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2 1"/>
                        <rect x="2" y="3" width="12" height="3"/>
                        <rect x="4" y="9" width="8" height="3"/>
                    </svg>
                </button>
                <button type="button" class="align-tool-btn" onclick="alignRight()"
                        title="@Localizer["designer.toolbar.align_right_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_right"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="15" y1="1" x2="15" y2="15" stroke="currentColor" stroke-width="1.4"/>
                        <rect x="3" y="3" width="11" height="3"/>
                        <rect x="7" y="9" width="7" height="3"/>
                    </svg>
                </button>
                <div class="align-tool-divider"></div>
                <button type="button" class="align-tool-btn" onclick="alignTop()"
                        title="@Localizer["designer.toolbar.align_top_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_top"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="1" y1="1" x2="15" y2="1" stroke="currentColor" stroke-width="1.4"/>
                        <rect x="3" y="2" width="3" height="11"/>
                        <rect x="9" y="2" width="3" height="7"/>
                    </svg>
                </button>
                <button type="button" class="align-tool-btn" onclick="alignCenterV()"
                        title="@Localizer["designer.toolbar.align_center_v_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_center_v"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="1" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2 1"/>
                        <rect x="3" y="2" width="3" height="12"/>
                        <rect x="9" y="4" width="3" height="8"/>
                    </svg>
                </button>
                <button type="button" class="align-tool-btn" onclick="alignBottom()"
                        title="@Localizer["designer.toolbar.align_bottom_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.align_bottom"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <line x1="1" y1="15" x2="15" y2="15" stroke="currentColor" stroke-width="1.4"/>
                        <rect x="3" y="3" width="3" height="11"/>
                        <rect x="9" y="7" width="3" height="7"/>
                    </svg>
                </button>
            </div>

            <!-- ===== 等距分布工具群組（≥ 3 選取時顯示） ===== -->
            <div id="distToolGroup" class="dist-tool-group" style="display:none;">
                <div class="align-tool-divider"></div>
                <button type="button" class="align-tool-btn" onclick="distributeHorizontally()"
                        title="@Localizer["designer.toolbar.distribute_h_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.distribute_h"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <rect x="1" y="3" width="2.5" height="10"/>
                        <rect x="6.75" y="3" width="2.5" height="10"/>
                        <rect x="12.5" y="3" width="2.5" height="10"/>
                    </svg>
                </button>
                <button type="button" class="align-tool-btn" onclick="distributeVertically()"
                        title="@Localizer["designer.toolbar.distribute_v_tooltip"]"
                        aria-label="@Localizer["designer.toolbar.distribute_v"]">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="1" width="10" height="2.5"/>
                        <rect x="3" y="6.75" width="10" height="2.5"/>
                        <rect x="3" y="12.5" width="10" height="2.5"/>
                    </svg>
                </button>
            </div>

            <span class="ms-auto text-secondary" style="font-size:11px;">
                <i class="fas fa-info-circle me-1"></i>
                @Localizer["designer.toolbar.hint"]
            </span>
        </div>

        <!-- ===== 主體區域 ===== -->
        <div class="designer-body">

            <!-- 頁面清單 -->
            <div class="page-panel">
                <div class="page-panel-header">
                    <i class="fas fa-sitemap me-1"></i> @Localizer["designer.page_panel.title"]
                    <button class="btn-add-root" onclick="addPage(null)" title="@Localizer["designer.page_panel.add_root_tooltip"]">＋</button>
                </div>
                <div class="page-tree-wrap" id="pageTreeWrap">
                    <!-- 由 JS 動態產生 -->
                </div>
            </div>

            <!-- 元件庫展開按鈕 -->
            <div class="comp-expand-tab" id="compExpandTab" style="display:none;" onclick="toggleComponentPanel()" title="@Localizer["designer.component_panel.expand_tooltip"]">
                <i class="fas fa-chevron-right"></i>
                <span class="tab-label">@Localizer["designer.component_panel.title"]</span>
            </div>

            <!-- 元件庫 -->
            <div class="component-panel" id="componentPanel">
                <div class="panel-header" style="display:flex;align-items:center;">
                    <i class="fas fa-th-large me-1"></i> @Localizer["designer.component_panel.title"]
                    <button class="comp-panel-toggle" onclick="toggleComponentPanel()" title="@Localizer["designer.component_panel.collapse_tooltip"]">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>

                <div class="widget-cat">
                    <div class="widget-cat-title">@Localizer["designer.component_panel.cat_display"]</div>
                    <div class="widget-cat-items">

                <!-- 表格 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="table"
                     title="@Localizer["designer.widget_tooltip.table"]">
                    <i class="fas fa-table text-info"></i>
                    <span>@Localizer["designer.widget.table"]</span>
                </div>

                <!-- 儀錶板 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="gauge"
                     title="@Localizer["designer.widget_tooltip.gauge"]">
                    <i class="fas fa-tachometer-alt text-warning"></i>
                    <span>@Localizer["designer.widget.gauge"]</span>
                </div>

                <!-- 文字 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="text"
                     title="@Localizer["designer.widget_tooltip.text"]">
                    <i class="fas fa-font" style="color:#a78bfa;"></i>
                    <span>@Localizer["designer.widget.text"]</span>
                </div>

                    </div>
                </div>

                <div class="widget-cat">
                    <div class="widget-cat-title">@Localizer["designer.component_panel.cat_point"]</div>
                    <div class="widget-cat-items">

                <!-- 控制按鈕 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="controlBtn"
                     title="@Localizer["designer.widget_tooltip.controlBtn"]">
                    <i class="fas fa-toggle-on" style="color:#20c997;"></i>
                    <span>@Localizer["designer.widget.controlBtn"]</span>
                </div>

                <!-- AI 點位 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="realtimeValue"
                     title="@Localizer["designer.widget_tooltip.realtimeValue"]">
                    <i class="fas fa-digital-tachograph" style="color:#ff6b6b;"></i>
                    <span>@Localizer["designer.widget.realtimeValue"]</span>
                </div>

                <!-- DI 點位 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="diPoint"
                     title="@Localizer["designer.widget_tooltip.diPoint"]">
                    <i class="fas fa-circle" style="color:#28a745;"></i>
                    <span>@Localizer["designer.widget.diPoint"]</span>
                </div>

                <!-- AO 點位 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="aoPoint"
                     title="@Localizer["designer.widget_tooltip.aoPoint"]">
                    <i class="fas fa-sliders-h" style="color:#0dcaf0;"></i>
                    <span>@Localizer["designer.widget.aoPoint"]</span>
                </div>

                <!-- DO 點位 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="doPoint"
                     title="@Localizer["designer.widget_tooltip.doPoint"]">
                    <i class="fas fa-toggle-on" style="color:#ffc107;"></i>
                    <span>@Localizer["designer.widget.doPoint"]</span>
                </div>

                    </div>
                </div>

                <div class="widget-cat">
                    <div class="widget-cat-title">@Localizer["designer.component_panel.cat_equip"]</div>
                    <div class="widget-cat-items">

                <!-- 水泵 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="pump"
                     title="@Localizer["designer.widget_tooltip.pump"]">
                    <svg viewBox="0 0 50 40" width="28" height="23" xmlns="http://www.w3.org/2000/svg" style="display:block;">
                        <!-- 底座 -->
                        <rect x="12" y="33" width="16" height="2.5" rx="1" fill="#4a4a4a"/>
                        <rect x="12" y="35" width="16" height="1.5" rx=".5" fill="#333"/>
                        <rect x="15" y="27.5" width="3" height="6" rx=".5" fill="#4a4a4a"/>
                        <rect x="22" y="27.5" width="3" height="6" rx=".5" fill="#4a4a4a"/>
                        <!-- 泵體 -->
                        <path d="M 20,4 L 46,4 L 46,12 L 33,12 A 14,14 0 1,1 20,4 Z"
                              fill="#555" stroke="#3a3a3a" stroke-width="1.5" stroke-linejoin="round"/>
                        <rect x="22" y="5" width="22" height="2" rx=".5" fill="rgba(255,255,255,.12)"/>
                        <!-- 葉片 -->
                        <circle cx="20" cy="18" r="4.5" fill="#6c757d" stroke="#444" stroke-width=".8"/>
                        <path d="M 19.3,17 C 18.5,15.5 19,14 20,13.5 C 21,14 21.5,15.5 20.7,17 Z" fill="rgba(255,255,255,.4)"/>
                        <path d="M 20.8,18.5 C 22,20 23,20.5 23.2,21 C 22.3,21.8 21,21 20.3,19.5 Z" fill="rgba(255,255,255,.4)"/>
                        <path d="M 19.2,18.5 C 18,20 17,20.5 16.8,21 C 17.7,21.8 19,21 19.7,19.5 Z" fill="rgba(255,255,255,.4)"/>
                        <circle cx="20" cy="18" r="1.2" fill="#3a3a3a"/>
                    </svg>
                    <span>@Localizer["designer.widget.pump"]</span>
                </div>

                <!-- 管路 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="pipe"
                     title="@Localizer["designer.widget_tooltip.pipe"]">
                    <svg viewBox="0 0 28 16" width="28" height="16" xmlns="http://www.w3.org/2000/svg" style="display:block;">
                        <rect x="1" y="6" width="26" height="4" rx="2" fill="#adb5bd"/>
                        <rect x="2" y="6.5" width="6" height="3" rx="1.5" fill="#0d6efd"/>
                        <rect x="11" y="6.5" width="6" height="3" rx="1.5" fill="#0d6efd"/>
                        <rect x="20" y="6.5" width="6" height="3" rx="1.5" fill="#0d6efd"/>
                    </svg>
                    <span>@Localizer["designer.widget.pipe"]</span>
                </div>

                <!-- 冷卻水塔 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="coolingTower"
                     title="@Localizer["designer.widget_tooltip.coolingTower"]">
                    <svg viewBox="0 0 32 32" width="26" height="26" xmlns="http://www.w3.org/2000/svg" style="display:block;">
                        <ellipse cx="16" cy="28.5" rx="11" ry="2" fill="rgba(0,0,0,.2)"/>
                        <path d="M6,11 L16,16 L16,28 L6,23 Z" fill="#6c757d" stroke="#3a3a3a" stroke-width="1" stroke-linejoin="round"/>
                        <line x1="9" y1="13.7" x2="9" y2="25.7" stroke="rgba(0,0,0,.25)" stroke-width="1"/>
                        <line x1="12" y1="15.2" x2="12" y2="27.2" stroke="rgba(0,0,0,.25)" stroke-width="1"/>
                        <path d="M16,16 L26,11 L26,23 L16,28 Z" fill="#565e66" stroke="#3a3a3a" stroke-width="1" stroke-linejoin="round"/>
                        <line x1="17.5" y1="17" x2="24.5" y2="21.8" stroke="rgba(255,255,255,.3)" stroke-width="1"/>
                        <line x1="24.5" y1="13.5" x2="17.5" y2="25.5" stroke="rgba(255,255,255,.3)" stroke-width="1"/>
                        <path d="M16,6 L26,11 L16,16 L6,11 Z" fill="#8a9199" stroke="#3a3a3a" stroke-width="1" stroke-linejoin="round"/>
                        <polyline points="6,8 16,3 26,8" fill="none" stroke="#e8a812" stroke-width="1.2"/>
                        <polyline points="6,8 16,13 26,8" fill="none" stroke="#e8a812" stroke-width="1.2"/>
                        <line x1="6" y1="11" x2="6" y2="8" stroke="#e8a812" stroke-width="1.2"/>
                        <line x1="26" y1="11" x2="26" y2="8" stroke="#e8a812" stroke-width="1.2"/>
                        <line x1="16" y1="16" x2="16" y2="13" stroke="#e8a812" stroke-width="1.2"/>
                        <ellipse cx="16" cy="10.5" rx="5" ry="2.5" fill="#5a5a5a" stroke="#333" stroke-width="1"/>
                        <path d="M16,10.5 L16,8.6 C17.6,8.9 17.6,10 16,10.3 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,10.5 L19.6,11.2 C18.6,12 16.9,11.6 16.3,10.8 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,10.5 L12.4,11.2 C12.9,9.9 14.7,9.6 15.6,10.2 Z" fill="rgba(255,255,255,.5)"/>
                        <circle cx="16" cy="10.5" r="1" fill="#3a3a3a"/>
                    </svg>
                    <span>@Localizer["designer.widget.coolingTower"]</span>
                </div>

                <!-- 空調箱風扇 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="ahuFan"
                     title="@Localizer["designer.widget_tooltip.ahuFan"]">
                    <svg viewBox="0 0 32 32" width="26" height="26" xmlns="http://www.w3.org/2000/svg" style="display:block;">
                        <rect x="4" y="6" width="24" height="20" rx="3" fill="#6c757d" stroke="#3a3a3a" stroke-width="1"/>
                        <rect x="1.5" y="12" width="2.5" height="8" rx="1" fill="#5a5a5a"/>
                        <rect x="28" y="12" width="2.5" height="8" rx="1" fill="#5a5a5a"/>
                        <circle cx="16" cy="16" r="7.5" fill="#6c757d" stroke="#333" stroke-width="1"/>
                        <path d="M16,16 L16,9.5 C17.6,10.6 17.6,13.2 16,14.5 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,16 L21.6,12.8 C21.6,14.7 19.4,16.1 17.4,15.5 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,16 L21.6,19.2 C20,20.2 17.8,19.3 17.4,17.3 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,16 L16,22.5 C14.4,21.4 14.4,18.8 16,17.5 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,16 L10.4,19.2 C10.4,17.3 12.6,15.9 14.6,16.5 Z" fill="rgba(255,255,255,.5)"/>
                        <path d="M16,16 L10.4,12.8 C12,11.8 14.2,12.7 14.6,14.7 Z" fill="rgba(255,255,255,.5)"/>
                        <circle cx="16" cy="16" r="1.8" fill="#3a3a3a"/>
                    </svg>
                    <span>@Localizer["designer.widget.ahuFan"]</span>
                </div>

                <!-- 冰機 -->
                <div class="widget-lib-item"
                     draggable="true"
                     data-widget-type="chiller"
                     title="@Localizer["designer.widget_tooltip.chiller"]">
                    <svg viewBox="0 0 32 32" width="26" height="26" xmlns="http://www.w3.org/2000/svg" style="display:block;">
                        <rect x="6" y="27" width="21" height="1.8" rx=".8" fill="#4a4a4a"/>
                        <rect x="16.5" y="6" width="8.5" height="3.6" rx="1.8" fill="#565b60" stroke="#3a3a3a" stroke-width=".6"/>
                        <rect x="6" y="17.5" width="21" height="7.5" rx="3.7" fill="#6c757d" stroke="#3a3a3a" stroke-width=".8"/>
                        <rect x="10" y="9.5" width="17" height="6.5" rx="3.2" fill="#6c757d" stroke="#3a3a3a" stroke-width=".8"/>
                        <rect x="7" y="4.5" width="9" height="13.5" rx=".8" fill="#61666b" stroke="#3a3a3a" stroke-width=".8"/>
                        <rect x="8.2" y="6.3" width="5" height="3.8" rx=".5" fill="#243640"/>
                        <rect x="8.8" y="7" width="2.6" height=".8" rx=".4" fill="rgba(120,220,180,.8)"/>
                        <circle cx="9.3" cy="12.5" r=".8" fill="#e57373"/>
                        <circle cx="11.5" cy="12.5" r=".8" fill="#81c784"/>
                        <circle cx="13.7" cy="12.5" r=".8" fill="#ffd54f"/>
                        <circle cx="11.5" cy="3.8" r="1.2" fill="#81c784" stroke="#3a3a3a" stroke-width=".5"/>
                    </svg>
                    <span>@Localizer["designer.widget.chiller"]</span>
                </div>

                    </div>
                </div>
            </div>

            <!-- 畫布 -->
            <div class="canvas-wrapper" id="canvasWrapper">
                <div id="canvas"></div>
                <div class="canvas-statusbar" id="canvasStatusbar"></div>
            </div>

            <!-- 屬性面板 -->
            <div class="property-panel collapsed">
                <div class="panel-header">
                    <i class="fas fa-sliders-h me-1"></i> @Localizer["designer.property_panel.title"]
                </div>
                <div class="prop-body" id="propBody">
                    <div class="no-sel-hint" id="noSelHint">
                        <i class="fas fa-mouse-pointer"></i>
                        @Localizer["designer.property_panel.no_sel"]
                    </div>
                </div>
            </div>

        </div><!-- /.designer-body -->
    </div><!-- /.designer-outer -->

<!-- 右鍵選單（fixed，掛在 body 層） -->
<div id="ctxMenu"></div>

<!-- ===== 點位選擇 Modal（兩步驟） ===== -->
<div class="modal fade" id="pointPickerModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:460px;">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" style="font-size:13px;display:flex;align-items:center;gap:4px;">
                    <i class="fas fa-tachometer-alt text-warning"></i>
                    <span id="ppModalTitle">@Localizer["designer.picker.title.device"]</span>
                </h6>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:12px 16px;">

                <!-- 來源類型切換（僅 DI widget 開啟 picker 時顯示，仿 LogicFlow） -->
                <div id="ppSourceToggle" style="display:none;margin-bottom:8px;">
                    <div class="btn-group btn-group-sm w-100">
                        <button type="button" class="btn btn-outline-warning active" id="ppBtnPoint"
                                onclick="switchPickerSource('point')">
                            <i class="fas fa-server me-1"></i>@Localizer["designer.picker.toggle.point"]
                        </button>
                        <button type="button" class="btn btn-outline-warning" id="ppBtnSchedule"
                                onclick="switchPickerSource('schedule')">
                            <i class="fas fa-calendar-alt me-1"></i>@Localizer["designer.picker.toggle.schedule"]
                        </button>
                    </div>
                </div>

                <!-- Step 0: 選擇來源類型 -->
                <div id="ppStep0">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div class="point-list-item" onclick="showDeviceStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-server" style="font-size:18px;color:#7ecfff;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="point-name" style="font-size:14px;">@Localizer["designer.picker.source.device"]</div>
                                <div class="point-sid">@Localizer["designer.picker.source.device_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#555;font-size:12px;"></i>
                        </div>
                        <div class="point-list-item" onclick="showCalcPointStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-calculator" style="font-size:18px;color:#ffc107;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="point-name" style="font-size:14px;">@Localizer["designer.picker.source.calc"]</div>
                                <div class="point-sid">@Localizer["designer.picker.source.calc_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#555;font-size:12px;"></i>
                        </div>
                        <div class="point-list-item" onclick="showDbPointStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-database" style="font-size:18px;color:#6ec1a3;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="point-name" style="font-size:14px;">@Localizer["designer.picker.source.db"]</div>
                                <div class="point-sid">@Localizer["designer.picker.source.db_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#555;font-size:12px;"></i>
                        </div>
                        <!-- 迴路來源（僅 AI 點位 / 表格資料 cell 顯示；plan 2026-07-23 迴路指標） -->
                        <div class="point-list-item" id="ppSrcCircuit" onclick="showCircuitStep()" style="cursor:pointer;padding:14px 16px;display:none;">
                            <i class="fas fa-sitemap" style="font-size:18px;color:#69db7c;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="point-name" style="font-size:14px;">@Localizer["designer.picker.source.circuit"]</div>
                                <div class="point-sid">@Localizer["designer.picker.source.circuit_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#555;font-size:12px;"></i>
                        </div>
                    </div>
                </div>

                <!-- Step 1: 設備清單 -->
                <div id="ppStep1" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button class="pp-back-btn" onclick="goBackToStep0()" title="@Localizer["designer.picker.back_to_source"]">
                            <i class="fas fa-arrow-left"></i> @Localizer["designer.picker.back"]
                        </button>
                        <span class="pp-device-tag"><i class="fas fa-server me-1"></i>@Localizer["designer.picker.device_list"]</span>
                    </div>
                    <div id="deviceListContainer" style="max-height:290px;overflow-y:auto;"></div>
                </div>

                <!-- Step 2: 點位清單 -->
                <div id="ppStep2" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button class="pp-back-btn" onclick="goBackToDevices()" title="@Localizer["designer.picker.back"]">
                            <i class="fas fa-arrow-left"></i> @Localizer["designer.picker.back"]
                        </button>
                        <span class="pp-device-tag"><i class="fas fa-server me-1" id="ppDeviceIcon"></i><span id="ppDeviceName"></span></span>
                    </div>
                    <input type="text" id="ppPointSearch"
                           class="form-control form-control-sm mb-2"
                           placeholder="@Localizer["designer.picker.search_placeholder"]"
                           style="background:#3c3c3c;border:1px solid #555;color:#c8c8c8;"
                           oninput="filterPointList(this.value)">
                    <div id="pointListContainer" style="max-height:270px;overflow-y:auto;"></div>
                </div>

                <!-- Step 3: 排程清單（DI widget 切「排程」分頁時顯示） -->
                <div id="ppStep3" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <span class="pp-device-tag"><i class="fas fa-calendar-alt me-1"></i>@Localizer["designer.picker.title.schedule"]</span>
                    </div>
                    <div id="scheduleListContainer" style="max-height:320px;overflow-y:auto;"></div>
                </div>

            </div>
            <div class="modal-footer" style="gap:8px;">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["designer.picker.cancel"]</button>
                <button type="button" class="btn btn-warning btn-sm" id="btnConfirmPoint"
                        onclick="confirmPointPick()" disabled>@Localizer["designer.picker.confirm"]</button>
            </div>
        </div>
    </div>
</div>

<!-- ===== 列範本建議 Modal（plan 2026-06-01-designer-row-template） ===== -->
<div class="modal fade" id="rowTemplateModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" style="font-size:13px;display:flex;align-items:center;gap:4px;">
                    <i class="fas fa-magic text-info"></i>
                    <span>@Localizer["designer.row_template.modal_title"]</span>
                </h6>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body row-template-body" id="rowTemplateBody" style="padding:12px 16px;">
                <!-- 由 JS 動態渲染：suggest view 或 adjust view -->
            </div>
            <div class="modal-footer" id="rowTemplateFooter" style="gap:8px;">
                <!-- 由 JS 動態渲染按鈕 -->
            </div>
        </div>
    </div>
</div>

<!-- ===== 迴路自動帶入確認 Modal（plan 2026-07-23 表頭驅動整列帶入；body 複用 row-template-body 樣式） ===== -->
<div class="modal fade" id="cmetricFillModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" style="font-size:13px;display:flex;align-items:center;gap:4px;">
                    <i class="fas fa-sitemap" style="color:#69db7c;"></i>
                    <span>@Localizer["designer.cmetric.fill_modal_title"]</span>
                </h6>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body row-template-body" id="cmetricFillBody" style="padding:12px 16px;">
                <!-- 由 JS 動態渲染：欄名 → 帶入內容 勾選清單 -->
            </div>
            <div class="modal-footer" id="cmetricFillFooter" style="gap:8px;">
                <!-- 由 JS 動態渲染按鈕 -->
            </div>
        </div>
    </div>
</div>

<!-- ===== 頁面編輯 Modal ===== -->
<div class="modal fade" id="pageEditModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
        <div class="modal-content" style="background:#2d2d2d;border:1px solid #555;color:#c8c8c8;">
            <div class="modal-header" style="border-bottom:1px solid #444;padding:10px 16px;">
                <h6 class="modal-title" style="font-size:13px;">
                    <i class="fas fa-pen text-info me-2"></i>@Localizer["designer.page_modal.title"]
                </h6>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:12px 16px;">
                <div style="margin-bottom:12px;">
                    <div style="color:#9d9d9d;font-size:11px;margin-bottom:4px;">@Localizer["designer.page_modal.name_label"]</div>
                    <input type="text" id="editPageNameInput"
                           class="form-control form-control-sm"
                           style="background:#3c3c3c;border:1px solid #555;color:#c8c8c8;"
                           placeholder="@Localizer["designer.page_modal.name_placeholder"]">
                </div>
                <div>
                    <div style="color:#9d9d9d;font-size:11px;margin-bottom:6px;">@Localizer["designer.page_modal.icon_label"]</div>
                    <div id="iconPickerGrid" class="icon-picker-grid"></div>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #444;padding:8px 16px;gap:8px;">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["designer.page_modal.cancel"]</button>
                <button type="button" class="btn btn-info btn-sm" onclick="confirmPageEdit()">@Localizer["designer.page_modal.confirm"]</button>
            </div>
        </div>
    </div>
</div>

