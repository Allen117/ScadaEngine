@{
    ViewData["Title"] = Localizer["emscardsetting.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/ems-card-setting.css" asp-append-version="true" />

<div class="container mt-4 ems-card-setting-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="fas fa-th-large me-2"></i>@Localizer["emscardsetting.title"]</h4>
        <button class="btn btn-primary" id="btnSave" onclick="window._emsCardSetting.save()">
            <i class="fas fa-save me-1"></i>@Localizer["emscardsetting.btn.save"]
        </button>
    </div>

    <!-- 版面預覽：卡片依實際欄寬呈現，拖曳排序、✕ 隱藏 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <h6 class="mb-0"><i class="fas fa-eye me-1"></i> @Localizer["emscardsetting.preview"]</h6>
        </div>
        <div class="card-body">
            <div class="form-text mb-2">@Localizer["emscardsetting.hint"]</div>
            <div class="row g-3" id="previewGrid">
                <div class="col-12 text-center text-muted py-4">@Localizer["emscardsetting.loading"]</div>
            </div>
        </div>
    </div>

    <!-- 已隱藏的卡片：點「加回」回到預覽最後 -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light py-2">
            <h6 class="mb-0"><i class="fas fa-eye-slash me-1"></i> @Localizer["emscardsetting.hidden"]</h6>
        </div>
        <div class="card-body" id="hiddenTray">
            <span class="text-muted small">@Localizer["emscardsetting.none_hidden"]</span>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ems-card-setting.js" asp-append-version="true"></script>
}
