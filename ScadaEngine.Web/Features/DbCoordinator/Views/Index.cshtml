@{
    ViewData["Title"] = Localizer["dbcoord.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var coordinatorListJson = ViewBag.CoordinatorListJson as string ?? "[]";
}

<link rel="stylesheet" href="~/css/dbcoordinator.css" asp-append-version="true" />

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="fas fa-database me-2"></i>@Localizer["dbcoord.title"]</h4>
        <div>
            <button class="btn btn-secondary me-2" id="btnRefreshPage" onclick="window._dbCoord.refreshPage()">
                <i class="fas fa-sync me-1"></i>@Localizer["dbcoord.btn.refresh_page"]
            </button>
            <button class="btn btn-primary" id="btnReloadEngine" onclick="window._dbCoord.reloadEngine()">
                <i class="fas fa-bolt me-1"></i>@Localizer["dbcoord.btn.reload_engine"]
            </button>
        </div>
    </div>

    <div class="row">
        <!-- 左側選單 -->
        <div class="col-md-3 pe-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2">
                    <h6 class="mb-0"><i class="fas fa-database me-1"></i> @Localizer["dbcoord.card.db_comm"]</h6>
                </div>
                <div id="dbCoordinatorList"></div>
            </div>
        </div>

        <!-- 右側詳情 -->
        <div class="col-md-9">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex align-items-center">
                    <h6 class="mb-0" id="detailTitle">
                        <i class="fas fa-info-circle me-1"></i>
                        @Localizer["dbcoord.card.device_detail"]
                    </h6>
                </div>
                <div class="card-body" id="detailBody">
                    <div id="fullDetail" class="row g-3" style="display:none;">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.id"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldId" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.name"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldName" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.polling_interval"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldPollingInterval" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.connect_timeout"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldConnectTimeout" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.monitor_enabled"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldMonitorEnabled" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.point_count"]</label>
                            <input type="text" class="form-control form-control-sm" id="fieldPointCount" readonly />
                        </div>

                        <!-- 點位列表（名稱可行內編輯，回寫 DBPoint/*.json） -->
                        <div class="col-12">
                            <label class="form-label fw-bold text-muted small">@Localizer["dbcoord.label.points"]</label>
                            <div class="table-responsive point-table-wrap">
                                <table class="table table-sm table-hover align-middle mb-0" id="pointTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:110px;">@Localizer["dbcoord.th.sid"]</th>
                                            <th>@Localizer["dbcoord.th.name"]</th>
                                            <th style="width:110px;">@Localizer["dbcoord.th.unit"]</th>
                                            <th style="width:80px;" class="text-end">@Localizer["dbcoord.th.min"]</th>
                                            <th style="width:80px;" class="text-end">@Localizer["dbcoord.th.max"]</th>
                                        </tr>
                                    </thead>
                                    <tbody id="pointTableBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div id="emptyDetail" class="text-center text-muted py-5">
                        <i class="fas fa-hand-pointer fa-3x mb-3 d-block"></i>
                        <p id="emptyDetailMsg">@Localizer["dbcoord.empty.select_source"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window._dbCoordData = @Html.Raw(coordinatorListJson);
    </script>
    <script src="~/js/dbcoordinator.js" asp-append-version="true"></script>
}
