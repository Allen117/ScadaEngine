@using ScadaEngine.Common.Data.Models
@model List<UserModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "帳號管理";
}

<div class="container-fluid mt-4">
    <h4 class="mb-3"><i class="fas fa-users-cog me-2"></i>帳號管理</h4>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex align-items-center">
            <h6 class="mb-0"><i class="fas fa-users me-2"></i>使用者清單</h6>
            <span class="badge bg-light text-dark ms-2">共 @Model.Count 筆</span>
            <button class="btn btn-success btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="fas fa-user-plus me-1"></i>新增使用者
            </button>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>帳號</th>
                                <th>姓名</th>
                                <th>密碼</th>
                                <th>角色</th>
                                <th>部門</th>
                                <th class="text-center">狀態</th>
                                <th>最後登入</th>
                                <th>建立時間</th>
                                <th class="text-center" style="width:100px">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><i class="fas fa-user me-1 text-primary"></i>@user.szUsername</td>
                                    <td>@(string.IsNullOrEmpty(user.szRealName) ? "-" : user.szRealName)</td>
                                    <td class="text-muted">@(new string('*', user.szPasswordHash.Length))</td>
                                    <td>
                                        @{
                                            var badgeClass = user.szRole switch
                                            {
                                                "Admin" => "bg-danger",
                                                "Operator" => "bg-primary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@user.szRole</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(user.szDepartment) ? "-" : user.szDepartment)</td>
                                    <td class="text-center">
                                        @if (user.isActive)
                                        {
                                            <span class="badge bg-success">啟用</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">停用</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @(user.dtLastLoginAt.HasValue ? user.dtLastLoginAt.Value.ToString("yyyy-MM-dd HH:mm:ss") : "尚未登入")
                                    </td>
                                    <td class="small text-muted">
                                        @(user.dtCreatedAt.HasValue ? user.dtCreatedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") : "-")
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-outline-primary btn-sm me-1 btn-edit"
                                                data-userid="@user.nUserID"
                                                data-username="@user.szUsername"
                                                data-realname="@user.szRealName"
                                                data-role="@user.szRole"
                                                data-department="@user.szDepartment"
                                                data-isactive="@user.isActive.ToString().ToLower()"
                                                title="編輯">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm btn-delete"
                                                data-userid="@user.nUserID"
                                                data-username="@user.szUsername"
                                                title="刪除">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-user-slash fa-3x mb-3 d-block"></i>
                    <p>目前無使用者資料</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- 新增使用者 Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h6 class="modal-title" id="createUserModalLabel">
                    <i class="fas fa-user-plus me-2"></i>新增使用者
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">帳號 <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="inputUsername" maxlength="50" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">姓名</label>
                        <input type="text" class="form-control" id="inputRealName" maxlength="100">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">密碼 <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="inputPassword" maxlength="100" required>
                            <button class="btn btn-outline-secondary" type="button" id="btnTogglePassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">確認密碼 <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="inputPasswordConfirm" maxlength="100" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">角色 <span class="text-danger">*</span></label>
                        <select class="form-select" id="inputRole">
                            <option value="Admin">Admin</option>
                            <option value="Operator" selected>Operator</option>
                            <option value="Viewer">Viewer</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">部門</label>
                        <input type="text" class="form-control" id="inputDepartment" maxlength="50">
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="inputIsActive" checked>
                            <label class="form-check-label" for="inputIsActive">啟用帳號</label>
                        </div>
                    </div>
                </div>
                <div id="createUserAlert" class="alert mt-3 mb-0" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btnCreateUser">
                    <i class="fas fa-save me-1"></i>儲存
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    // 密碼顯示/隱藏切換
    document.getElementById('btnTogglePassword').addEventListener('click', function () {
        var pwd = document.getElementById('inputPassword');
        var icon = this.querySelector('i');
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            pwd.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    });

    // Modal 關閉時重置表單
    document.getElementById('createUserModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('inputUsername').value = '';
        document.getElementById('inputRealName').value = '';
        document.getElementById('inputPassword').value = '';
        document.getElementById('inputPasswordConfirm').value = '';
        document.getElementById('inputRole').value = 'Operator';
        document.getElementById('inputDepartment').value = '';
        document.getElementById('inputIsActive').checked = true;
        var alert = document.getElementById('createUserAlert');
        alert.style.display = 'none';
        alert.textContent = '';
    });

    function showAlert(msg, type) {
        var alert = document.getElementById('createUserAlert');
        alert.className = 'alert mt-3 mb-0 alert-' + type;
        alert.textContent = msg;
        alert.style.display = '';
    }

    // 儲存按鈕
    document.getElementById('btnCreateUser').addEventListener('click', async function () {
        var szUsername = document.getElementById('inputUsername').value.trim();
        var szRealName = document.getElementById('inputRealName').value.trim();
        var szPassword = document.getElementById('inputPassword').value;
        var szPasswordConfirm = document.getElementById('inputPasswordConfirm').value;
        var szRole = document.getElementById('inputRole').value;
        var szDepartment = document.getElementById('inputDepartment').value.trim();
        var isActive = document.getElementById('inputIsActive').checked;

        // 前端驗證
        if (!szUsername) { showAlert('請輸入帳號', 'warning'); return; }
        if (!szPassword) { showAlert('請輸入密碼', 'warning'); return; }
        if (szPassword !== szPasswordConfirm) { showAlert('兩次輸入的密碼不一致', 'warning'); return; }

        this.disabled = true;
        this.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>儲存中...';

        try {
            var resp = await fetch('/AccountSetting/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    username: szUsername,
                    realName: szRealName,
                    password: szPassword,
                    role: szRole,
                    department: szDepartment,
                    isActive: isActive
                })
            });
            var result = await resp.json();
            if (result.success) {
                showAlert('新增成功，頁面即將重新整理...', 'success');
                setTimeout(function () { location.reload(); }, 1000);
            } else {
                showAlert(result.message || '新增失敗', 'danger');
            }
        } catch (ex) {
            showAlert('新增失敗：' + ex.message, 'danger');
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fas fa-save me-1"></i>儲存';
        }
    });
})();
</script>
}
