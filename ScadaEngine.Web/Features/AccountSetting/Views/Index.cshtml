@using ScadaEngine.Common.Data.Models
@model List<UserModel>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "帳號管理";
    var szConfigurablePages = ViewData["ConfigurablePages"]?.ToString() ?? "[]";
    var szScadaDesignPages = ViewData["ScadaDesignPages"]?.ToString() ?? "[]";
}

<div class="container-fluid mt-4"
     id="accountSettingRoot"
     data-configurable-pages="@szConfigurablePages"
     data-scada-design-pages="@szScadaDesignPages">
    <h4 class="mb-3"><i class="fas fa-users-cog me-2"></i>帳號管理</h4>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex align-items-center">
            <h6 class="mb-0"><i class="fas fa-users me-2"></i>使用者清單</h6>
            <span class="badge bg-light text-dark ms-2">共 @Model.Count 筆</span>
            <button class="btn btn-success btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="fas fa-user-plus me-1"></i>新增使用者
            </button>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>帳號</th>
                                <th>姓名</th>
                                <th>角色</th>
                                <th>部門</th>
                                <th class="text-center">狀態</th>
                                <th>最後登入</th>
                                <th>建立時間</th>
                                <th class="text-center" style="width:100px">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td><i class="fas fa-user me-1 text-primary"></i>@user.szUsername</td>
                                    <td>@(string.IsNullOrEmpty(user.szRealName) ? "-" : user.szRealName)</td>
                                    <td>
                                        @{
                                            var badgeClass = user.szRole == "Admin" ? "bg-danger" : "bg-primary";
                                        }
                                        <span class="badge @badgeClass">@user.szRole</span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(user.szDepartment) ? "-" : user.szDepartment)</td>
                                    <td class="text-center">
                                        @if (user.isActive)
                                        {
                                            <span class="badge bg-success">啟用</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">停用</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @(user.dtLastLoginAt.HasValue ? user.dtLastLoginAt.Value.ToString("yyyy-MM-dd HH:mm:ss") : "尚未登入")
                                    </td>
                                    <td class="small text-muted">
                                        @(user.dtCreatedAt.HasValue ? user.dtCreatedAt.Value.ToString("yyyy-MM-dd HH:mm:ss") : "-")
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-outline-primary btn-sm me-1 btn-edit"
                                                data-userid="@user.nUserID"
                                                data-username="@user.szUsername"
                                                data-realname="@user.szRealName"
                                                data-role="@user.szRole"
                                                data-department="@user.szDepartment"
                                                data-isactive="@user.isActive.ToString().ToLower()"
                                                title="編輯">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm btn-delete"
                                                data-userid="@user.nUserID"
                                                data-username="@user.szUsername"
                                                title="刪除">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-user-slash fa-3x mb-3 d-block"></i>
                    <p>目前無使用者資料</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- 新增使用者 Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h6 class="modal-title" id="createUserModalLabel">
                    <i class="fas fa-user-plus me-2"></i>新增使用者
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">帳號 <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="inputUsername" maxlength="50" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">姓名</label>
                        <input type="text" class="form-control" id="inputRealName" maxlength="100">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">密碼 <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="inputPassword" maxlength="100" required>
                            <button class="btn btn-outline-secondary" type="button" id="btnTogglePassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">確認密碼 <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="inputPasswordConfirm" maxlength="100" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">角色 <span class="text-danger">*</span></label>
                        <select class="form-select" id="inputRole">
                            <option value="Admin">Admin</option>
                            <option value="User" selected>User</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">部門</label>
                        <input type="text" class="form-control" id="inputDepartment" maxlength="50">
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="inputIsActive" checked>
                            <label class="form-check-label" for="inputIsActive">啟用帳號</label>
                        </div>
                    </div>
                </div>
                <div id="createUserAlert" class="alert mt-3 mb-0" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btnCreateUser">
                    <i class="fas fa-save me-1"></i>儲存
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 編輯使用者 Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h6 class="modal-title" id="editUserModalLabel">
                    <i class="fas fa-user-edit me-2"></i>編輯使用者
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserID">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">帳號</label>
                        <input type="text" class="form-control" id="editUsername" disabled>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">姓名</label>
                        <input type="text" class="form-control" id="editRealName" maxlength="100">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">角色 <span class="text-danger">*</span></label>
                        <select class="form-select" id="editRole">
                            <option value="Admin">Admin</option>
                            <option value="User">User</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">部門</label>
                        <input type="text" class="form-control" id="editDepartment" maxlength="50">
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="editIsActive">
                            <label class="form-check-label" for="editIsActive">啟用帳號</label>
                        </div>
                    </div>
                </div>

                <!-- 權限設定區塊（僅 User 角色顯示） -->
                <div id="permissionSection" class="mt-3" style="display:none;">
                    <hr>
                    <h6 class="fw-bold"><i class="fas fa-shield-alt me-1"></i>頁面存取權限</h6>

                    <div class="card mb-3">
                        <div class="card-header py-2 bg-light d-flex align-items-center">
                            <small class="fw-bold">主功能頁面</small>
                            <div class="form-check form-check-inline ms-auto mb-0">
                                <input class="form-check-input" type="checkbox" id="cbSelectAllPages">
                                <label class="form-check-label small" for="cbSelectAllPages">全選</label>
                            </div>
                        </div>
                        <div class="card-body py-2" id="permMainPages"></div>
                    </div>

                    <div class="card">
                        <div class="card-header py-2 bg-light">
                            <small class="fw-bold">即時監控子頁面（ScadaPage）</small>
                        </div>
                        <div class="card-body py-2" id="permScadaPages">
                            <small class="text-muted">載入中...</small>
                        </div>
                    </div>
                </div>

                <div id="editUserAlert" class="alert mt-3 mb-0" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-warning" id="btnSaveEdit">
                    <i class="fas fa-save me-1"></i>儲存變更
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 刪除確認 Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title"><i class="fas fa-exclamation-triangle text-danger me-2"></i>確認刪除</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-3">
                <p class="mb-1">確定要刪除使用者 <strong id="deleteUsername"></strong> 嗎？</p>
                <small class="text-muted">此操作無法復原</small>
                <input type="hidden" id="deleteUserID">
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center gap-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger btn-sm" id="btnConfirmDelete">確認刪除</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/accountsetting.js"></script>
}
