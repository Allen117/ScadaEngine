<!-- 點位選擇 Modal（兩步驟：設備 → 點位） -->
<div class="modal fade" id="pointPickerModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:460px;">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" style="font-size:13px;display:flex;align-items:center;gap:4px;">
                    <i class="fas fa-tachometer-alt text-primary"></i>
                    <span id="ppModalTitle">@Localizer["logicflow.pp.title_select_device"]</span>
                </h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:12px 16px;">
                <!-- 來源類型切換（僅 contact 時顯示） -->
                <div id="ppSourceToggle" class="d-none" style="margin-bottom:8px;">
                    <div class="btn-group btn-group-sm w-100">
                        <button class="btn btn-outline-primary active" id="ppBtnPoint"
                                onclick="window._lf.ppSwitchSource('point')">
                            <i class="fas fa-server me-1"></i>@Localizer["logicflow.pp.toggle.point"]</button>
                        <button class="btn btn-outline-primary" id="ppBtnSchedule"
                                onclick="window._lf.ppSwitchSource('schedule')">
                            <i class="fas fa-calendar-alt me-1"></i>@Localizer["logicflow.pp.toggle.schedule"]</button>
                    </div>
                </div>
                <!-- Step 0: 選擇來源類型 -->
                <div id="ppStep0">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div class="pp-list-item" onclick="window._lf.ppShowDeviceStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-server text-primary" style="font-size:18px;"></i>
                            <div style="flex:1;">
                                <div class="pp-point-name" style="font-size:14px;">@Localizer["logicflow.pp.option.device_point"]</div>
                                <div class="pp-point-sid">@Localizer["logicflow.pp.option.device_point_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted" style="font-size:12px;"></i>
                        </div>
                        <div id="ppStep0Calc" class="pp-list-item" onclick="window._lf.ppShowCalcStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-calculator text-warning" style="font-size:18px;"></i>
                            <div style="flex:1;">
                                <div class="pp-point-name" style="font-size:14px;">@Localizer["logicflow.pp.option.calc_point"]</div>
                                <div class="pp-point-sid">@Localizer["logicflow.pp.option.calc_point_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted" style="font-size:12px;"></i>
                        </div>
                        <div id="ppStep0Db" class="pp-list-item" onclick="window._lf.ppShowDbStep()" style="cursor:pointer;padding:14px 16px;">
                            <i class="fas fa-database text-info" style="font-size:18px;"></i>
                            <div style="flex:1;">
                                <div class="pp-point-name" style="font-size:14px;">@Localizer["logicflow.pp.option.db_point"]</div>
                                <div class="pp-point-sid">@Localizer["logicflow.pp.option.db_point_desc"]</div>
                            </div>
                            <i class="fas fa-chevron-right text-muted" style="font-size:12px;"></i>
                        </div>
                    </div>
                </div>
                <!-- Step 1: 設備清單 -->
                <div id="ppStep1" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button id="ppStep1Back" class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="window._lf.ppBackToStep0()" title="@Localizer["logicflow.pp.back_tip"]">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["logicflow.pp.back"]
                        </button>
                        <span class="text-primary fw-bold small"><i class="fas fa-server me-1"></i>@Localizer["logicflow.pp.device_list_header"]</span>
                    </div>
                    <div id="deviceListContainer" style="max-height:290px;overflow-y:auto;"></div>
                </div>
                <!-- Step 2: 點位清單 -->
                <div id="ppStep2" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" onclick="window._lf.ppGoBack()" title="@Localizer["logicflow.pp.back"]">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["logicflow.pp.back"]
                        </button>
                        <span class="text-primary fw-bold small"><i class="fas fa-server me-1" id="ppDeviceIcon"></i><span id="ppDeviceName"></span></span>
                    </div>
                    <input type="text" id="ppPointSearch" class="form-control form-control-sm mb-2"
                           placeholder="@Localizer["logicflow.pp.search_placeholder"]" oninput="window._lf.ppFilter(this.value)">
                    <div id="pointListContainer" style="max-height:270px;overflow-y:auto;"></div>
                </div>
                <!-- Step 3: 排程清單 -->
                <div id="ppStep3" style="display:none;">
                    <div id="scheduleListContainer" style="max-height:320px;overflow-y:auto;"></div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">@Localizer["logicflow.pp.cancel"]</button>
                <button type="button" class="btn btn-sm btn-primary" id="btnConfirmPoint"
                        onclick="window._lf.ppConfirm()" disabled>@Localizer["logicflow.pp.confirm"]</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/logicflow.css" />

@section Scripts {
<script src="~/js/common/schedule-eval.js"></script>
<script src="~/js/logicflow/state.js"></script>
<script src="~/js/logicflow/algo.js"></script>
<script src="~/js/logicflow/eval.js"></script>
<script src="~/js/logicflow/render.js"></script>
<script src="~/js/logicflow/canvas.js"></script>
