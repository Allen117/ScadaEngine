@model ScadaEngine.Web.Features.EventLog.Models.EventLogQueryViewModel
@{
    ViewData["Title"] = Localizer["eventlog.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css" />
<link rel="stylesheet" href="~/css/eventlog.css" />

<div class="container-fluid py-3">
    <!-- 標題列 -->
    <div class="d-flex align-items-center mb-3">
        <h5 class="mb-0">
            <i class="fas fa-clipboard-list text-primary me-2"></i>@Localizer["eventlog.title"]
        </h5>
    </div>

    <!-- 查詢條件 -->
    <div class="query-card p-3 mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.start_time"]</label>
                <input type="text" id="startTime" class="form-control form-control-sm"
                       value="@Model.dtStartTime.ToString("yyyy-MM-dd HH:mm")" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.end_time"]</label>
                <input type="text" id="endTime" class="form-control form-control-sm"
                       value="@Model.dtEndTime.ToString("yyyy-MM-dd HH:mm")" autocomplete="off" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.event_type"]</label>
                <select id="eventType" class="form-select form-select-sm">
                    <option value="">@Localizer["eventlog.filter.all"]</option>
                    <option value="0">@Localizer["eventlog.event.alarm"]</option>
                    <option value="2">@Localizer["eventlog.event.warning"]</option>
                    <option value="3">@Localizer["eventlog.event.info"]</option>
                    <option value="4">@Localizer["eventlog.event.system"]</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.severity"]</label>
                <select id="severity" class="form-select form-select-sm">
                    <option value="">@Localizer["eventlog.filter.all"]</option>
                    <option value="0">@Localizer["eventlog.severity.urgent"]</option>
                    <option value="1">@Localizer["eventlog.severity.high"]</option>
                    <option value="2">@Localizer["eventlog.severity.medium"]</option>
                    <option value="3">@Localizer["eventlog.severity.low"]</option>
                    <option value="4">@Localizer["eventlog.severity.none"]</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.point"]</label>
                <div class="input-group input-group-sm">
                    <input type="text" id="sidFilter" class="form-control form-control-sm" placeholder="@Localizer["eventlog.filter.unselected"]" readonly />
                    <button class="btn btn-outline-primary" type="button" id="btnOpenPicker"
                            onclick="window._eventLog.openPointPicker()">
                        <i class="fas fa-crosshairs"></i>
                    </button>
                    <button class="btn btn-outline-secondary" type="button" id="btnClearPicker"
                            onclick="window._eventLog.clearPointPicker()" style="display:none;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-1">
                <label class="form-label mb-1 small fw-bold">@Localizer["eventlog.filter.acknowledged"]</label>
                <select id="acknowledged" class="form-select form-select-sm">
                    <option value="">@Localizer["eventlog.filter.all"]</option>
                    <option value="0">@Localizer["eventlog.ack.unack"]</option>
                    <option value="1">@Localizer["eventlog.ack.acked"]</option>
                </select>
            </div>
            <div class="col-md-1 d-flex gap-1">
                <button id="btnQuery" class="btn btn-primary btn-sm flex-fill" onclick="window._eventLog.queryEvents()">
                    <i class="fas fa-search me-1"></i>@Localizer["eventlog.filter.button.query"]
                </button>
            </div>
        </div>
        <!-- 快速時間範圍 -->
        <div class="mt-2 d-flex align-items-center gap-1 flex-wrap">
            <small class="text-muted me-1"><i class="fas fa-clock me-1"></i>@Localizer["eventlog.filter.quick"]</small>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="1">1h</button>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="6">6h</button>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="24">24h</button>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="72">3d</button>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="168">7d</button>
            <button class="btn btn-outline-secondary btn-xs quick-range" data-hours="720">30d</button>
        </div>
    </div>

    <!-- 統計摘要 -->
    <div class="row g-2 mb-3" id="statsRow" style="display:none;">
        <div class="col">
            <div class="stat-card bg-light">
                <div class="small text-muted">@Localizer["eventlog.stat.total"]</div>
                <div class="fw-bold fs-5" id="statTotal">0</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="background:#fde8e8;">
                <div class="small text-muted">@Localizer["eventlog.stat.alarm"]</div>
                <div class="fw-bold fs-5 text-danger" id="statAlarm">0</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="background:#fff8e1;">
                <div class="small text-muted">@Localizer["eventlog.stat.warning"]</div>
                <div class="fw-bold fs-5 text-warning" id="statWarning">0</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="background:#e8f5e9;">
                <div class="small text-muted">@Localizer["eventlog.stat.cleared"]</div>
                <div class="fw-bold fs-5 text-success" id="statCleared">0</div>
            </div>
        </div>
        <div class="col">
            <div class="stat-card" style="background:#e3f2fd;">
                <div class="small text-muted">@Localizer["eventlog.stat.unack"]</div>
                <div class="fw-bold fs-5 text-primary" id="statUnack">0</div>
            </div>
        </div>
    </div>

    <!-- 結果表格 -->
    <div class="query-card position-relative">
        <div class="loading-overlay" id="loadingOverlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">@Localizer["eventlog.result.loading"]</span>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center p-3 pb-0">
            <span class="text-muted small" id="resultInfo">@Localizer["eventlog.result.placeholder"]</span>
            <button class="btn btn-outline-success btn-sm" id="btnExport" onclick="window._eventLog.exportCSV()" style="display:none;">
                <i class="fas fa-file-csv me-1"></i>@Localizer["eventlog.result.button.export"]
            </button>
        </div>

        <div class="table-container p-3">
            <table class="table table-hover table-sm result-table mb-0" id="resultTable">
                <thead>
                    <tr>
                        <th>@Localizer["eventlog.col.no"]</th>
                        <th>@Localizer["eventlog.col.occurred_at"]</th>
                        <th>@Localizer["eventlog.col.event_type"]</th>
                        <th>@Localizer["eventlog.col.severity"]</th>
                        <th>@Localizer["eventlog.col.message"]</th>
                        <th>@Localizer["eventlog.col.cleared_at"]</th>
                        <th>@Localizer["eventlog.col.ack_status"]</th>
                        <th>@Localizer["eventlog.col.ack_by"]</th>
                    </tr>
                </thead>
                <tbody id="resultBody">
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="fas fa-search fa-2x mb-2 d-block"></i>
                            @Localizer["eventlog.result.empty_default"]
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 點位選擇 Modal（兩步驟：設備 → 點位）-->
<div class="modal fade" id="ppModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:440px;">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title mb-0" id="ppTitle">
                    <i class="fas fa-crosshairs text-primary me-1"></i>@Localizer["eventlog.picker.title.select_device"]
                </h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:10px 14px;">
                <!-- Step 1: 設備清單 -->
                <div id="ppStep1">
                    <div id="ppDeviceList" style="max-height:320px;overflow-y:auto;"></div>
                </div>
                <!-- Step 2: 點位清單 -->
                <div id="ppStep2" style="display:none;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <button class="btn btn-link btn-sm text-primary p-0" onclick="window._eventLog.ppBack()">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["eventlog.picker.button.back"]
                        </button>
                        <span class="badge bg-secondary" id="ppDevName"></span>
                    </div>
                    <input type="text" id="ppSearch" class="form-control form-control-sm mb-2"
                           placeholder="@Localizer["eventlog.picker.search_placeholder"]" oninput="window._eventLog.ppFilter(this.value)" />
                    <div id="ppPointList" style="max-height:280px;overflow-y:auto;"></div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["eventlog.picker.button.cancel"]</button>
                <button type="button" class="btn btn-primary btn-sm" id="ppConfirmBtn"
                        onclick="window._eventLog.ppConfirm()" disabled>@Localizer["eventlog.picker.button.confirm"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/zh-tw.js"></script>
    <script src="~/js/flatpickr-init.js"></script>
    <script src="~/js/eventlog.js"></script>
}
