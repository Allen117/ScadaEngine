@{
    ViewData["Title"] = Localizer["scadapage.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/scadapage.css" />
<link rel="stylesheet" href="~/css/active-alarm-panel.css" />

<div class="container-fluid mt-4">

    <!-- 主體：頁面樹側欄 + 畫布區（高度由 .scada-canvas-viewport 決定，不在這裡用 min-height 兜底） -->
    <div class="d-flex gap-3">

        <!-- 頁面樹側欄 -->
        <div style="width:160px;flex-shrink:0;background:#f8f9fa;border:1px solid #dee2e6;border-radius:8px;padding:8px;overflow-y:auto;">
            <div style="font-size:16px;color:#6c757d;letter-spacing:1px;margin-bottom:8px;padding:0 4px;">
                <i class="fas fa-sitemap me-1"></i>@Localizer["scadapage.tree.title"]
            </div>
            <div id="scadaPageTree">
                <p style="font-size:16px;color:#6c757d;text-align:center;margin-top:24px;">@Localizer["scadapage.tree.loading"]</p>
            </div>
        </div>

        <!-- 畫布區（深色工作區，畫布以 transform: scale 等比 fit 並置中） -->
        <div class="scada-canvas-viewport">
            <div id="scadaCanvasWrap">
                <div id="scadaCanvas" style="position:relative;background:#fff;border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,.12);">
                    <p id="scadaPlaceholder" style="padding:120px 20px;text-align:center;color:#6c757d;font-size:13px;margin:0;">
                        <i class="fas fa-desktop fa-3x" style="display:block;margin-bottom:12px;opacity:.3;"></i>
                        @Localizer["scadapage.placeholder"]
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- 未恢復警報面板（Active Alarm Summary Panel） -->
    <div id="activeAlarmPanel" class="active-alarm-panel">
        <div class="alarm-panel-header">
            <div class="alarm-panel-title alarm-toggle-trigger" title="@Localizer["scadapage.alarm.toggle_title"]">
                <i class="fas fa-bell"></i>
                <span>@Localizer["scadapage.alarm.title"]</span>
                <span class="alarm-count-badge zero">0</span>
                <i class="fas fa-chevron-down alarm-toggle-icon ms-2"></i>
            </div>
            <div class="alarm-panel-controls" onclick="event.stopPropagation();">
                <label class="alarm-filter-label">
                    <i class="fas fa-filter"></i>
                    <select id="alarmAckFilter" class="alarm-filter-select">
                        <option value="all">@Localizer["scadapage.alarm.filter.all"]</option>
                        <option value="unacked">@Localizer["scadapage.alarm.filter.unacked"]</option>
                        <option value="acked">@Localizer["scadapage.alarm.filter.acked"]</option>
                    </select>
                </label>
            </div>
        </div>
        <div class="alarm-conn-warn" style="display:none;"></div>
        <div class="alarm-panel-body">
            <ul class="alarm-list">
                <li class="alarm-empty"><i class="fas fa-check-circle text-success"></i>@Localizer["scadapage.alarm.empty"]</li>
            </ul>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // 權限資料（由 Controller 注入，供外部 JS 讀取）
        window._isAdmin = @Html.Raw(ViewData["IsAdmin"]?.ToString().ToLower() ?? "false");
        window._scadaPagePerms = @Html.Raw(ViewData["ScadaPagePermissions"] ?? "{}");
    </script>
    <script src="~/js/common/schedule-eval.js"></script>
    <script src="~/js/common/motor-equip-svg.js"></script>
    <script src="~/js/scadapage.js"></script>
    <script src="~/js/active-alarm-panel.js"></script>
}
