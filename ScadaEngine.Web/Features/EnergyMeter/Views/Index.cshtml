@{
    ViewData["Title"] = "電表/迴路設定";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-sitemap text-primary me-2"></i>電表/迴路設定
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>能源管理
        </span>
    </div>

    <div class="row g-3">
        <!-- 左側樹狀清單 -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                    <span><i class="fas fa-folder-tree me-1"></i>迴路階層</span>
                    <button class="btn btn-sm btn-outline-light py-0" onclick="window._em.openCreateModal(null)">
                        <i class="fas fa-plus me-1"></i>新增點表/迴路
                    </button>
                </div>
                <div class="card-body p-2" style="height: calc(100vh - 250px); overflow-y: auto;">
                    <div id="treeContainer">
                        <div class="text-center mt-5"><div class="spinner-border spinner-border-sm text-primary"></div> 載入中...</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 右側詳情 -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <span id="detailTitle"><i class="fas fa-hand-pointer me-1"></i>請從左側選取迴路</span>
                </div>
                <div class="card-body" id="detailArea">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-sitemap fa-4x mb-3 d-block" style="opacity:.3"></i>
                        <p>選取左側的節點即可檢視/編輯詳細資訊</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增/編輯 Modal -->
<div class="modal fade" id="circuitModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title"><i class="fas fa-edit me-1"></i><span id="modalTitle">新增迴路</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="emId">
                <input type="hidden" id="emParentId">

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-tag me-1"></i>名稱</label>
                    <input type="text" class="form-control form-control-sm" id="emName" placeholder="例如：水系統 / 冰機 1">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-cog me-1"></i>節點類型</label>
                    <div class="btn-group btn-group-sm w-100" role="group">
                        <input type="radio" class="btn-check" name="emType" id="emTypeVirtual" value="virtual" checked>
                        <label class="btn btn-outline-primary" for="emTypeVirtual">
                            <i class="fas fa-folder me-1"></i>虛擬迴路
                        </label>
                        <input type="radio" class="btn-check" name="emType" id="emTypeMeter" value="meter">
                        <label class="btn btn-outline-primary" for="emTypeMeter">
                            <i class="fas fa-bolt me-1"></i>實體電表
                        </label>
                    </div>
                </div>

                <div class="mb-3" id="emSignRow">
                    <label class="form-label fw-semibold"><i class="fas fa-plus-minus me-1"></i>貢獻方向</label>
                    <div class="btn-group btn-group-sm w-100" role="group">
                        <input type="radio" class="btn-check" name="emSign" id="emSignPos" value="1" checked>
                        <label class="btn btn-outline-success" for="emSignPos">
                            <i class="fas fa-plus me-1"></i>正向（加入父）
                        </label>
                        <input type="radio" class="btn-check" name="emSign" id="emSignNeg" value="-1">
                        <label class="btn btn-outline-danger" for="emSignNeg">
                            <i class="fas fa-minus me-1"></i>反向（從父扣減）
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">用於建立「總表 − 已分配子表」這類算式；根節點不適用</small>
                </div>

                <div class="mb-3" id="emMeterFields" style="display:none;">
                    <label class="form-label fw-semibold"><i class="fas fa-server me-1"></i>通訊設備</label>
                    <select class="form-select form-select-sm" id="emDevice">
                        <option value="">-- 請選擇設備 --</option>
                    </select>

                    <div id="emSubUnitRow" style="display:none;">
                        <label class="form-label fw-semibold mt-3"><i class="fas fa-microchip me-1"></i>子單元</label>
                        <select class="form-select form-select-sm" id="emSubUnit">
                            <option value="">-- 請選擇子單元 --</option>
                        </select>
                    </div>

                    <label class="form-label fw-semibold mt-3"><i class="fas fa-plug me-1"></i>度數對應點位</label>
                    <select class="form-select form-select-sm" id="emSid" disabled>
                        <option value="">-- 請先選擇設備 --</option>
                    </select>
                    <small class="text-muted d-block mt-1">僅列出單位為 kWh 的累積點位（含計算點、DB 來源點位）</small>

                    <label class="form-label fw-semibold mt-3"><i class="fas fa-sort-numeric-up me-1"></i>累積最大值 MaxKwh</label>
                    <input type="text" inputmode="numeric" class="form-control form-control-sm" id="emMaxKwh" placeholder="例如：1,000,000,000">
                    <small class="text-muted d-block mt-1">電表累積值溢位/重置時用於計算 delta；留空表示不處理溢位</small>

                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="emDemandEnabled">
                        <label class="form-check-label fw-semibold" for="emDemandEnabled">
                            <i class="fas fa-tachometer-alt me-1"></i>啟用需量計算
                        </label>
                    </div>

                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="emMainMeter">
                        <label class="form-check-label fw-semibold" for="emMainMeter">
                            <i class="fas fa-star me-1"></i>主要電表
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">全系統僅能有一顆主要電表；勾選後原本的主要電表會自動取消</small>

                    <div id="emMeterInfoRow" class="mt-2" style="display:none;">
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="window._em.openMeterInfoModal()">
                            <i class="fas fa-info-circle me-1"></i>電表資訊設定
                        </button>
                        <small class="text-muted d-block mt-1" id="emMeterInfoSummary">電壓/電流/功率/功因 點位綁定</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-comment me-1"></i>說明</label>
                    <textarea class="form-control form-control-sm" id="emDesc" rows="2" placeholder="選填"></textarea>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="window._em.saveCircuit()">
                    <i class="fas fa-save me-1"></i>儲存
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 電表資訊設定 Modal（主要電表：電壓/電流/功率/功因 點位綁定） -->
<div class="modal fade" id="meterInfoModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title"><i class="fas fa-info-circle me-1"></i>電表資訊設定 — 電壓/電流/功率/功因</h6>
                <button type="button" class="btn-close" onclick="window._em.closeMeterInfoModal()"></button>
            </div>
            <div class="modal-body">
                <!-- 自動比對建議區塊（有候選才顯示） -->
                <div id="miSuggestBox" class="mi-suggest-box" style="display:none;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold"><i class="fas fa-magic me-1 text-primary"></i>依度數點位名稱找到以下建議</span>
                        <button type="button" class="btn btn-sm btn-success py-0" onclick="window._em.applyAllSuggestions()">
                            <i class="fas fa-check-double me-1"></i>全部帶入
                        </button>
                    </div>
                    <div id="miSuggestList"></div>
                </div>

                <!-- 四列綁定 -->
                <div id="miBindingList"></div>

                <small class="text-muted d-block mt-2">四個點位皆可留空；顯示單位取自綁定點位本身的 Unit。儲存迴路後才會寫入資料庫。</small>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-primary" onclick="window._em.closeMeterInfoModal()">
                    <i class="fas fa-check me-1"></i>完成
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 兩步驟點位選擇器 Modal（設備 → 點位清單＋搜尋） -->
<div class="modal fade" id="emPointPickerModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title"><i class="fas fa-crosshairs me-1"></i><span id="ppTitle">選擇點位</span></h6>
                <button type="button" class="btn-close" onclick="window._em.closePointPicker(false)"></button>
            </div>
            <div class="modal-body">
                <div class="row g-2">
                    <div class="col-md-5">
                        <div class="pp-panel-title"><i class="fas fa-server me-1"></i>通訊設備</div>
                        <div id="ppDeviceList" class="pp-list"></div>
                    </div>
                    <div class="col-md-7">
                        <div class="pp-panel-title"><i class="fas fa-plug me-1"></i>點位</div>
                        <input type="text" class="form-control form-control-sm mb-1" id="ppSearch" placeholder="搜尋點位名稱 / SID..." autocomplete="off">
                        <div id="ppPointList" class="pp-list"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-outline-danger me-auto" onclick="window._em.clearPickedPoint()">
                    <i class="fas fa-eraser me-1"></i>清除綁定
                </button>
                <button type="button" class="btn btn-sm btn-secondary" onclick="window._em.closePointPicker(false)">取消</button>
                <button type="button" class="btn btn-sm btn-primary" id="ppConfirmBtn" disabled onclick="window._em.closePointPicker(true)">
                    <i class="fas fa-check me-1"></i>確定
                </button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/energymeter.css" />

@section Scripts {
    <script src="~/js/role-aliases.js"></script>
    <script src="~/js/energymeter.js"></script>
}
