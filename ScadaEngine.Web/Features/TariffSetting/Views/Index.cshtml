@model ScadaEngine.Web.Features.TariffSetting.Models.TariffSettingViewModel
@{
    ViewData["Title"] = Localizer["tariffsetting.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-file-invoice-dollar text-primary me-2"></i>@Localizer["tariffsetting.title"]
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>@Localizer["tariffsetting.breadcrumb.energy"]
        </span>
    </div>

    <!-- 頂部資訊卡：採用方案 + 累計度數/金額（本版不計算，顯示 --） -->
    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body py-2 d-flex align-items-center">
                    <i class="fas fa-check-circle fa-2x text-primary me-3"></i>
                    <div>
                        <div class="text-muted small">@Localizer["tariffsetting.card.active_plan"]</div>
                        <div class="fw-bold ts-card-value" id="tsActivePlanName">--</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body py-2 d-flex align-items-center">
                    <i class="fas fa-bolt fa-2x text-primary me-3"></i>
                    <div>
                        <div class="text-muted small">@Localizer["tariffsetting.card.acc_kwh"]</div>
                        <div class="fw-bold ts-card-value"><span id="tsAccKwh">--</span> kWh</div>
                        <div class="text-muted ts-card-hint" id="tsAccKwhHint">@Localizer["tariffsetting.card.acc_hint"]</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body py-2 d-flex align-items-center">
                    <i class="fas fa-dollar-sign fa-2x text-primary me-3"></i>
                    <div class="flex-grow-1">
                        <div class="text-muted small">@Localizer["tariffsetting.card.acc_cost"]</div>
                        <div class="fw-bold ts-card-value"><span id="tsAccCost">--</span> @Localizer["tariffsetting.unit.ntd"]</div>
                        <div class="text-muted ts-card-hint" id="tsAccCostHint">@Localizer["tariffsetting.card.acc_hint"]</div>
                    </div>
                    <button class="btn btn-outline-primary btn-sm text-nowrap" id="btnTsRecalc" onclick="window._ts.openRecalc()">
                        <i class="fas fa-sync-alt me-1"></i>@Localizer["tariffsetting.button.recalculate"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 方案選擇 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <i class="fas fa-list-ul me-1"></i>@Localizer["tariffsetting.select.title"]
        </div>
        <div class="card-body p-3">
            <div class="ts-select-bar">
                <div>
                    <label class="form-label fw-semibold">@Localizer["tariffsetting.select.category"]</label>
                    <select id="tsCategory" class="form-select form-select-sm"></select>
                </div>
                <div class="ts-plan-select">
                    <label class="form-label fw-semibold">@Localizer["tariffsetting.select.plan"]</label>
                    <select id="tsPlan" class="form-select form-select-sm"></select>
                </div>
                <div class="ts-active-btn">
                    <button class="btn btn-primary btn-sm" id="btnTsSetActive" onclick="window._ts.setActive()">
                        <i class="fas fa-check me-1"></i>@Localizer["tariffsetting.button.set_active"]
                    </button>
                    <span class="badge bg-success d-none" id="tsActiveBadge">
                        <i class="fas fa-check me-1"></i>@Localizer["tariffsetting.badge.active"]
                    </span>
                </div>
            </div>
            <div class="text-muted small mt-2" id="tsCategoryDesc"></div>
        </div>
    </div>

    <!-- 方案內容（JS 依方案型態渲染） -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
            <span><i class="fas fa-edit me-1"></i><span id="tsPlanTitle">@Localizer["tariffsetting.editor.loading"]</span></span>
            <span id="tsTypeBadge"></span>
        </div>
        <div class="card-body p-3" id="tsPlanContainer">
            <div class="text-center text-muted py-4">@Localizer["tariffsetting.editor.loading"]</div>
        </div>
        <div class="card-footer bg-light py-2 d-flex justify-content-between">
            <button class="btn btn-outline-secondary btn-sm" onclick="window._ts.resetPlan()">
                <i class="fas fa-undo me-1"></i>@Localizer["tariffsetting.button.reset"]
            </button>
            <button class="btn btn-primary btn-sm" onclick="window._ts.savePlan()">
                <i class="fas fa-save me-1"></i>@Localizer["tariffsetting.button.save"]
            </button>
        </div>
    </div>
</div>

<!-- 重新計算電費 Modal（date-only 用原生 input type=date，無 AM/PM 問題不需 flatpickr） -->
<div class="modal fade" id="tsRecalcModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title"><i class="fas fa-sync-alt me-2"></i>@Localizer["tariffsetting.recalc.title"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning py-2 small">
                    <i class="fas fa-exclamation-triangle me-1"></i>@Localizer["tariffsetting.recalc.warning"]
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label small mb-1" for="tsRecalcStart">@Localizer["tariffsetting.recalc.start"]</label>
                        <input type="date" id="tsRecalcStart" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-1" for="tsRecalcEnd">@Localizer["tariffsetting.recalc.end"]</label>
                        <input type="date" id="tsRecalcEnd" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="text-muted small mt-2">@Localizer["tariffsetting.recalc.hint"]</div>
                <div id="tsRecalcResult" class="small mt-2"></div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["tariffsetting.recalc.close"]</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnTsRecalcRun" onclick="window._ts.runRecalc()">
                    <i class="fas fa-play me-1"></i>@Localizer["tariffsetting.recalc.run"]
                </button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css" />
<link rel="stylesheet" href="~/css/tariffsetting.css" asp-append-version="true" />

@section Scripts {
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/zh-tw.js"></script>
    <script src="~/js/flatpickr-init.js" asp-append-version="true"></script>
    <script src="~/js/tariffsetting.js" asp-append-version="true"></script>
}
