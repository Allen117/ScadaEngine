@using ScadaEngine.Engine.Models
@model List<CoordinatorModel>
@{
    ViewData["Title"] = "Modbus來源";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/commsetting.css" />

<div class="container-fluid mt-4">
    <h4 class="mb-3"><i class="fas fa-network-wired me-2"></i>Modbus來源</h4>

    <div class="row">
        <!-- 左側選單 -->
        <div class="col-md-3 pe-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2">
                    <h6 class="mb-0"><i class="fas fa-server me-1"></i> Modbus 通訊</h6>
                </div>
                <div id="coordinatorList">
                    @if (Model.Any())
                    {
                        @for (var i = 0; i < Model.Count; i++)
                        {
                            var c = Model[i];
                            var modbusIds = c.szModbusID.Split(',', StringSplitOptions.TrimEntries);
                            var deviceNames = c.szDeviceName.Split(',', StringSplitOptions.TrimEntries);
                            var hasSubItems = modbusIds.Length > 1;

                            if (hasSubItems)
                            {
                                <!-- 有子選單的 Coordinator -->
                                <div class="coordinator-group">
                                    <a href="#"
                                       class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                       data-index="@i">
                                        <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                        <i class="fas fa-plug me-1 text-secondary"></i>
                                        <span class="small">@c.szName</span>
                                        @if (!c.isMonitorEnabled)
                                        {
                                            <span class="badge bg-secondary ms-1" style="font-size:.6rem;">停用</span>
                                        }
                                    </a>
                                    <div class="sub-menu" style="display:none;">
                                        @for (var j = 0; j < modbusIds.Length; j++)
                                        {
                                            var subName = j < deviceNames.Length ? deviceNames[j] : "";
                                            var subId = modbusIds[j];
                                            <a href="#"
                                               class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                               data-index="@i"
                                               data-sub-index="@j"
                                               data-sub-id="@c.Id"
                                               data-sub-modbusid="@subId"
                                               data-sub-name="@subName">
                                                <i class="fas fa-microchip me-1 text-muted" style="font-size:.75rem;"></i>
                                                <span class="small">@(string.IsNullOrEmpty(subName) ? subId : subName)</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <!-- 無子選單的 Coordinator -->
                                <a href="#"
                                   class="list-group-item list-group-item-action py-2 coordinator-item"
                                   data-index="@i">
                                    <i class="fas fa-plug me-1 text-secondary"></i>
                                    <span class="small">@c.szName</span>
                                    @if (!c.isMonitorEnabled)
                                    {
                                        <span class="badge bg-secondary ms-1" style="font-size:.6rem;">停用</span>
                                    }
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                            尚無設備資料
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 右側詳情 -->
        <div class="col-md-9">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex align-items-center">
                    <h6 class="mb-0" id="detailTitle">
                        <i class="fas fa-info-circle me-1"></i>
                        @(Model.Any() ? "設備詳細資料" : "請選擇設備")
                    </h6>
                </div>
                <div class="card-body" id="detailBody">
                    @if (Model.Any())
                    {
                        <!-- 完整欄位（單一 ModbusID 時顯示） -->
                        <div id="fullDetail" class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Id</label>
                                <input type="text" class="form-control form-control-sm" id="fieldId" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Name（設備名稱）</label>
                                <input type="text" class="form-control form-control-sm" id="fieldName" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">ModbusID</label>
                                <input type="text" class="form-control form-control-sm" id="fieldModbusID" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">DelayTime（延遲時間 ms）</label>
                                <input type="text" class="form-control form-control-sm" id="fieldDelayTime" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">MonitorEnabled（啟用監控）</label>
                                <input type="text" class="form-control form-control-sm" id="fieldMonitorEnabled" readonly />
                            </div>
                        </div>

                        <!-- 子項目欄位（子選單項目點擊時顯示） -->
                        <div id="subDetail" class="row g-3" style="display:none;">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Id</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldId" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">ModbusID</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldModbusID" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">名稱</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldName" />
                            </div>
                            <div class="col-12 mt-2">
                                <button class="btn btn-primary btn-sm" id="btnSaveName">
                                    <i class="fas fa-save me-1"></i>儲存名稱
                                </button>
                                <span id="saveStatus" class="ms-2 small" style="display:none;"></span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-hand-pointer fa-3x mb-3 d-block"></i>
                            <p>目前無設備資料，請先於 Engine 設定 Modbus 裝置。</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window._commSettingData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    </script>
    <script src="~/js/commsetting.js"></script>
}
