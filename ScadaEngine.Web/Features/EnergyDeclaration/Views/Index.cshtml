@model ScadaEngine.Web.Features.EnergyDeclaration.Models.EnergyDeclarationViewModel
@{
    ViewData["Title"] = Localizer["energydeclaration.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-file-signature text-primary me-2"></i>@Localizer["energydeclaration.title"]
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>@Localizer["energydeclaration.breadcrumb.energy"]
        </span>
    </div>

    <!-- 申報報表設定 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list-ul me-1"></i>@Localizer["energydeclaration.config.title"]</span>
            <button class="btn btn-primary btn-sm" onclick="window._ed.openCreateModal()">
                <i class="fas fa-plus me-1"></i>@Localizer["energydeclaration.button.add"]
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 ed-config-table">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["energydeclaration.config.col_name"]</th>
                            <th>@Localizer["energydeclaration.config.col_energy_circuit"]</th>
                            <th>@Localizer["energydeclaration.config.col_water_circuit"]</th>
                            <th>@Localizer["energydeclaration.config.col_description"]</th>
                            <th class="text-end">@Localizer["energydeclaration.config.col_actions"]</th>
                        </tr>
                    </thead>
                    <tbody id="edConfigBody">
                        <tr><td colspan="5" class="text-center text-muted py-3">@Localizer["energydeclaration.config.loading"]</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 查詢條件 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <i class="fas fa-filter me-1"></i>@Localizer["energydeclaration.filter.title"]
        </div>
        <div class="card-body p-3">
            <div class="ed-filter-bar">
                <div class="ed-report">
                    <label class="form-label fw-semibold"><i class="fas fa-file-signature me-1"></i>@Localizer["energydeclaration.filter.report"]</label>
                    <select id="edReport" class="form-select form-select-sm">
                        <option value="">@Localizer["energydeclaration.select.loading"]</option>
                    </select>
                </div>
                <!-- 頁面固定格式：只選年度，產出該年 1~12 月（每月 1 號 ~ 月底） -->
                <div class="ed-narrow-date">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["energydeclaration.filter.year"]</label>
                    <input type="number" id="edYear" class="form-control form-control-sm" min="2000" max="2100">
                </div>

                <div class="ed-btn">
                    <button class="btn btn-primary btn-sm" onclick="window._ed.query()">
                        <i class="fas fa-search me-1"></i>@Localizer["energydeclaration.button.query"]
                    </button>
                </div>
                <div class="ed-btn">
                    <button class="btn btn-success btn-sm" onclick="window._ed.exportExcel()" id="btnEdExport" disabled>
                        <i class="fas fa-file-excel me-1"></i>@Localizer["energydeclaration.button.export"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 結果區 -->
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-chart-bar me-1"></i>@Localizer["energydeclaration.chart.title"]</span>
                    <span class="text-muted small" id="edWarnText"></span>
                </div>
                <div class="card-body">
                    <div style="height:360px;">
                        <canvas id="edChart"></canvas>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    @Localizer["energydeclaration.label.total_kwh"]：<span id="edTotalKwh" class="fw-bold text-primary">--</span> kWh
                    <span class="mx-2">|</span>
                    @Localizer["energydeclaration.label.total_rt"]：<span id="edTotalRt" class="fw-bold text-primary">--</span> RT·h
                    <span class="mx-2">|</span>
                    @Localizer["energydeclaration.label.total_efficiency"]：<span id="edTotalEff" class="fw-bold text-primary">--</span> kWh/RTh
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <i class="fas fa-table me-1"></i>@Localizer["energydeclaration.table.title"]
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:420px;overflow-y:auto;">
                        <table class="table table-striped table-hover table-bordered mb-0">
                            <thead class="table-dark" style="position:sticky;top:0;z-index:30;">
                                <tr>
                                    <th>@Localizer["energydeclaration.table.col_period"]</th>
                                    <th class="text-end">@Localizer["energydeclaration.table.col_kwh"]</th>
                                    <th class="text-end">@Localizer["energydeclaration.table.col_rt"]</th>
                                    <th class="text-end">@Localizer["energydeclaration.table.col_efficiency"]</th>
                                </tr>
                            </thead>
                            <tbody id="edTableBody">
                                <tr><td colspan="4" class="text-center text-muted py-4">@Localizer["energydeclaration.table.empty"]</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 新增/編輯申報報表 Modal -->
<div class="modal fade" id="edConfigModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title" id="edModalTitle">@Localizer["energydeclaration.modal.title_add"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">@Localizer["energydeclaration.modal.name"] <span class="text-danger">*</span></label>
                    <input type="text" id="edModalName" class="form-control form-control-sm" maxlength="100" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-bolt me-1"></i>@Localizer["energydeclaration.modal.energy_circuit"] <span class="text-danger">*</span></label>
                    <select id="edModalEnergyCircuit" class="form-select form-select-sm"></select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-snowflake me-1"></i>@Localizer["energydeclaration.modal.water_circuit"] <span class="text-danger">*</span></label>
                    <select id="edModalWaterCircuit" class="form-select form-select-sm"></select>
                </div>
                <div class="mb-1">
                    <label class="form-label fw-semibold">@Localizer["energydeclaration.modal.description"]</label>
                    <textarea id="edModalDescription" class="form-control form-control-sm" rows="2" maxlength="500"></textarea>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["energydeclaration.modal.cancel"]</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="window._ed.saveConfig()">
                    <i class="fas fa-save me-1"></i>@Localizer["energydeclaration.modal.save"]
                </button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/energydeclaration.css" />

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/js/energydeclaration.js"></script>
    <script>
        window._edInit = { today: '@Model.dtToday.ToString("yyyy-MM-dd")' };
    </script>
}
