@{
    ViewData["Title"] = Localizer["calcpoint.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/calcpoint.css" />

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fas fa-calculator me-2"></i>@Localizer["calcpoint.subtitle"]</h5>
        <button class="btn btn-primary btn-sm" onclick="window._calcPoint.openCreateModal()">
            <i class="fas fa-plus me-1"></i>@Localizer["calcpoint.btn.add"]
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white py-2">
            <h6 class="mb-0"><i class="fas fa-list me-2"></i>@Localizer["calcpoint.card.list_title"]</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered mb-0" id="calcPointTable">
                    <thead class="table-dark">
                        <tr>
                            <th>@Localizer["calcpoint.col.name"]</th>
                            <th>@Localizer["calcpoint.col.formula"]</th>
                            <th style="width: 80px;">@Localizer["calcpoint.col.unit"]</th>
                            <th style="width: 120px;">@Localizer["calcpoint.col.group"]</th>
                            <th style="width: 80px;">@Localizer["calcpoint.col.status"]</th>
                            <th style="width: 100px;">@Localizer["calcpoint.col.created_at"]</th>
                            <th style="width: 120px;">@Localizer["calcpoint.col.actions"]</th>
                        </tr>
                    </thead>
                    <tbody id="calcPointTableBody">
                    </tbody>
                </table>
            </div>
            <div id="emptyState" class="text-center text-muted py-4" style="display:none;">
                <i class="fas fa-inbox fa-3x mb-2 d-block"></i>
                <div>@Localizer["calcpoint.empty.hint"]</div>
            </div>
        </div>
        <div class="card-footer bg-light text-muted small">
            <span id="calcPointCount"></span>
            <span class="ms-3">@Localizer["calcpoint.footer.engine_reload_hint"]</span>
        </div>
    </div>
</div>

<!-- 新增/編輯 Modal -->
<div class="modal fade" id="calcPointModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="calcPointModalTitle">@Localizer["calcpoint.modal.add_title"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editSID" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="fas fa-tag me-1"></i>@Localizer["calcpoint.label.name"]</label>
                        <input type="text" class="form-control form-control-sm" id="inputName" placeholder="@Localizer["calcpoint.placeholder.name"]">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="fas fa-ruler me-1"></i>@Localizer["calcpoint.label.unit"]</label>
                        <input type="text" class="form-control form-control-sm" id="inputUnit" placeholder="@Localizer["calcpoint.placeholder.unit"]">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="fas fa-layer-group me-1"></i>@Localizer["calcpoint.label.group_name"]</label>
                        <input type="text" class="form-control form-control-sm" id="inputGroupName" placeholder="@Localizer["calcpoint.placeholder.group"]">
                    </div>
                </div>

                <hr class="my-3">

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-semibold mb-0"><i class="fas fa-link me-1"></i>@Localizer["calcpoint.label.input_mapping"]</label>
                        <button class="btn btn-outline-primary btn-sm" onclick="window._calcPoint.addVariableRow()">
                            <i class="fas fa-plus me-1"></i>@Localizer["calcpoint.btn.add_variable"]
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 180px;">@Localizer["calcpoint.col.var_name"]</th>
                                    <th>@Localizer["calcpoint.col.var_point"]</th>
                                    <th style="width: 60px;">@Localizer["calcpoint.col.actions"]</th>
                                </tr>
                            </thead>
                            <tbody id="variableTableBody">
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold"><i class="fas fa-square-root-alt me-1"></i>@Localizer["calcpoint.label.formula"]</label>
                    <input type="text" class="form-control form-control-sm font-monospace" id="inputFormula"
                           placeholder="@Localizer["calcpoint.placeholder.formula"]"
                           data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true"
                           title="@Localizer["calcpoint.tooltip.formula"]">
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-info btn-sm" onclick="window._calcPoint.previewFormula()">
                        <i class="fas fa-bolt me-1"></i>@Localizer["calcpoint.btn.preview"]
                    </button>
                    <span id="previewResult" class="fw-semibold"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["calcpoint.btn.cancel"]</button>
                <button type="button" class="btn btn-primary" onclick="window._calcPoint.saveCalcPoint()">
                    <i class="fas fa-save me-1"></i>@Localizer["calcpoint.btn.save"]
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 刪除確認 Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["calcpoint.modal.delete_title"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="deleteMessage"></p>
                <p class="text-danger small mb-0">@Localizer["calcpoint.modal.delete_warning"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["calcpoint.btn.cancel"]</button>
                <button type="button" class="btn btn-danger" onclick="window._calcPoint.confirmDelete()">
                    <i class="fas fa-trash-alt me-1"></i>@Localizer["calcpoint.btn.confirm_delete"]
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 點位選擇器 Modal -->
<div class="modal fade" id="cpPointPickerModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" style="max-width:460px;">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" style="font-size:13px;display:flex;align-items:center;gap:4px;">
                    <i class="fas fa-tachometer-alt text-warning"></i>
                    <span id="cpPkTitle">@Localizer["calcpoint.pk.title_source"]</span>
                </h6>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:12px 16px;">

                <!-- Step 0: 來源類型 -->
                <div id="cpPkStep0">
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        <div class="cpPk-list-item cpPk-source-item" onclick="window._calcPoint.pkShowDeviceStep()">
                            <i class="fas fa-server" style="font-size:18px;color:#0d6efd;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="cpPk-item-name" style="font-size:14px;">@Localizer["calcpoint.pk.source.device"]</div>
                                <div class="cpPk-item-sub">@Localizer["calcpoint.pk.source.device_sub"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#999;font-size:12px;"></i>
                        </div>
                        <div class="cpPk-list-item cpPk-source-item" onclick="window._calcPoint.pkShowCalcStep()">
                            <i class="fas fa-calculator" style="font-size:18px;color:#ffc107;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div class="cpPk-item-name" style="font-size:14px;">@Localizer["calcpoint.pk.source.calc"]</div>
                                <div class="cpPk-item-sub">@Localizer["calcpoint.pk.source.calc_sub"]</div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#999;font-size:12px;"></i>
                        </div>
                    </div>
                </div>

                <!-- Step 1: 設備 / 群組清單 -->
                <div id="cpPkStep1" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button class="btn btn-link btn-sm text-decoration-none p-0" onclick="window._calcPoint.pkBackToStep0()">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["calcpoint.pk.back"]
                        </button>
                    </div>
                    <div id="cpPkDeviceList" style="max-height:290px;overflow-y:auto;"></div>
                </div>

                <!-- Step 2: 點位清單 -->
                <div id="cpPkStep2" style="display:none;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                        <button class="btn btn-link btn-sm text-decoration-none p-0" onclick="window._calcPoint.pkGoBack()">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["calcpoint.pk.back"]
                        </button>
                        <span class="badge bg-light text-dark border">
                            <i class="fas fa-server me-1" id="cpPkDevIcon"></i><span id="cpPkDevName"></span>
                        </span>
                    </div>
                    <input type="text" id="cpPkSearch"
                           class="form-control form-control-sm mb-2"
                           placeholder="@Localizer["calcpoint.pk.search_placeholder"]"
                           oninput="window._calcPoint.pkFilterPoints(this.value)">
                    <div id="cpPkPointList" style="max-height:270px;overflow-y:auto;"></div>
                </div>

            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localizer["calcpoint.btn.cancel"]</button>
                <button type="button" class="btn btn-primary btn-sm" id="cpPkBtnConfirm" disabled onclick="window._calcPoint.pkConfirm()">
                    <i class="fas fa-check me-1"></i>@Localizer["calcpoint.pk.btn.confirm"]
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    window._calcPointData = @Html.Raw(ViewData["CalcPointsJson"]);
</script>

@section Scripts {
    <script src="~/js/calcpoint.js"></script>
}
