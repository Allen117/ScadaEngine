@model ScadaEngine.Web.Features.ConditionCtrl.Models.ConditionControlViewModel
@{
    ViewData["Title"] = "條件控制";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var pointJson = System.Text.Json.JsonSerializer.Serialize(
        Model.PointList.Select(p => new { sid = p.szSID, name = p.szName, unit = p.szUnit ?? "" })
    );

    var coordJson = System.Text.Json.JsonSerializer.Serialize(
        Model.CoordinatorList.Select(c => new { id = c.Id, name = c.szName, modbusId = c.szModbusID ?? "", deviceName = c.szDeviceName ?? "" })
    );

    var dbCoordJson = System.Text.Json.JsonSerializer.Serialize(
        Model.DbCoordinatorList.Select(c => new { id = c.Id, name = c.szName })
    );

    // 把 DB 規則序列化為 JS 可用格式（operator 轉為符號字串）
    var existingRulesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.ExistingRules.Select(r => new {
            conditionPointSid  = r.szConditionPointSID,
            operatorSymbol     = r.OperatorSymbol,
            conditionValue     = r.dConditionValue,
            controlPointSid    = r.szControlPointSID,
            controlValue       = r.dControlValue,
            remarks            = r.szRemarks ?? ""
        })
    );
}

<div class="container-fluid mt-4">

    <!-- 頁面標題 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">
            <i class="fas fa-code-branch text-primary me-2"></i>條件控制
        </h2>
        <span class="text-muted small">
            <i class="fas fa-cogs me-1"></i>條件控制設定
        </span>
    </div>

    <!-- 新增條件控制規則 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="fas fa-plus-circle text-success me-2"></i>新增條件控制規則
            </h5>
        </div>
        <div class="card-body">

            <!-- 第一列：條件側（設備 → 條件點位 → 運算子 → 數值） -->
            <div class="row g-3 align-items-end mb-2">

                <!-- 條件設備 -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-server text-dark me-1"></i>設備
                    </label>
                    <select id="conditionCoordinator" class="form-select form-select-sm">
                        <option value="0">— 全部設備 —</option>
                        @foreach (var c in Model.CoordinatorList)
                        {
                            <option value="@c.Id">@c.szName</option>
                        }
                        @foreach (var c in Model.DbCoordinatorList)
                        {
                            <option value="DB:@c.Id">@c.szName（DB 來源）</option>
                        }
                        <option value="CALC">計算點位</option>
                    </select>
                </div>

                <!-- 條件子設備 (多ID時顯示) -->
                <div class="col-md-2 d-none" id="conditionSubDeviceCol">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-sitemap text-dark me-1"></i>子設備
                    </label>
                    <select id="conditionSubDevice" class="form-select form-select-sm">
                        <option value="">— 請選擇子設備 —</option>
                    </select>
                </div>

                <!-- 條件點位 -->
                <div class="col-md-4" id="conditionPointCol">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-tag text-primary me-1"></i>參考點位
                    </label>
                    <select id="conditionPoint" class="form-select form-select-sm">
                        <option value="">— 請選擇點位 —</option>
                        @foreach (var p in Model.PointList)
                        {
                            <option value="@p.szSID" data-name="@p.szName" data-unit="@(p.szUnit ?? "")">
                                @p.szName
                            </option>
                        }
                    </select>
                </div>

                <!-- 運算子 -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-not-equal text-warning me-1"></i>運算子
                    </label>
                    <select id="conditionOperator" class="form-select form-select-sm">
                        <option value=">">&gt;　（大於）</option>
                        <option value="<">&lt;　（小於）</option>
                        <option value=">=">&gt;=　（大於等於）</option>
                        <option value="<=">&lt;=　（小於等於）</option>
                        <option value="==">=　（等於）</option>
                        <option value="!=">≠　（不等於）</option>
                    </select>
                </div>

                <!-- 數值 -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-hashtag text-info me-1"></i>數值
                    </label>
                    <input type="number" id="conditionValue" class="form-control form-control-sm"
                           placeholder="輸入比較數值" step="any" />
                </div>

            </div>

            <!-- 第二列：控制側（設備 → 控制點位 → 控制值） -->
            <div class="row g-3 align-items-end">

                <!-- 控制設備 -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-server text-dark me-1"></i>設備
                    </label>
                    <select id="controlCoordinator" class="form-select form-select-sm">
                        <option value="0">— 全部設備 —</option>
                        @foreach (var c in Model.CoordinatorList)
                        {
                            <option value="@c.Id">@c.szName</option>
                        }
                        @foreach (var c in Model.DbCoordinatorList)
                        {
                            <option value="DB:@c.Id">@c.szName（DB 來源）</option>
                        }
                        <option value="CALC">計算點位</option>
                    </select>
                </div>

                <!-- 控制子設備 (多ID時顯示) -->
                <div class="col-md-2 d-none" id="controlSubDeviceCol">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-sitemap text-dark me-1"></i>子設備
                    </label>
                    <select id="controlSubDevice" class="form-select form-select-sm">
                        <option value="">— 請選擇子設備 —</option>
                    </select>
                </div>

                <!-- 控制點位 -->
                <div class="col-md-4" id="controlPointCol">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-bolt text-danger me-1"></i>控制點位
                    </label>
                    <select id="controlPoint" class="form-select form-select-sm">
                        <option value="">— 請選擇點位 —</option>
                        @foreach (var p in Model.PointList)
                        {
                            <option value="@p.szSID" data-name="@p.szName" data-unit="@(p.szUnit ?? "")">
                                @p.szName
                            </option>
                        }
                    </select>
                </div>

                <!-- 控制值 -->
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-pen text-secondary me-1"></i>控制值
                    </label>
                    <input type="number" id="controlValue" class="form-control form-control-sm"
                           placeholder="輸入控制值" step="any" />
                </div>

                <!-- 備註 -->
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        <i class="fas fa-comment-alt text-muted me-1"></i>備註
                        <small class="text-muted fw-normal">（選填，最多 50 字）</small>
                    </label>
                    <input type="text" id="remarksValue" class="form-control form-control-sm"
                           placeholder="輸入備註說明" maxlength="50" />
                </div>

            </div>

            <div class="mt-3 d-flex align-items-center gap-2">
                <button id="btnAddRule" class="btn btn-success btn-sm px-4">
                    <i class="fas fa-plus me-1"></i>新增規則
                </button>
                <button id="btnClearForm" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-times me-1"></i>清除
                </button>
                <button id="btnSaveEdit" class="btn btn-warning btn-sm px-4 d-none">
                    <i class="fas fa-save me-1"></i>編輯
                </button>
                <button id="btnCancelEdit" class="btn btn-outline-secondary btn-sm d-none">
                    <i class="fas fa-ban me-1"></i>取消
                </button>
                <div id="formAlert" class="alert alert-warning py-1 px-3 mb-0 d-none small">
                    <i class="fas fa-exclamation-triangle me-1"></i>
                    <span id="formAlertMsg"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- 規則清單 -->
    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
            <h5 class="mb-0">
                <i class="fas fa-list text-primary me-2"></i>
                條件控制規則清單
                <span class="badge bg-secondary ms-1" id="ruleCount">0</span>
            </h5>
            <div class="d-flex align-items-center gap-2">
                <div id="saveAlert" class="d-none small"></div>
                <button id="btnSaveToDb" class="btn btn-primary btn-sm d-none">
                    <i class="fas fa-database me-1"></i>儲存規則至資料庫
                </button>
                <button id="btnClearAll" class="btn btn-outline-danger btn-sm d-none">
                    <i class="fas fa-trash-alt me-1"></i>清除全部
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="emptyRuleMsg" class="text-center py-5 text-muted">
                <i class="fas fa-clipboard-list fa-3x mb-3 d-block opacity-25"></i>
                <div>尚未新增任何條件控制規則</div>
                <small>請填寫上方表單後按下「新增規則」</small>
            </div>
            <div class="table-responsive d-none" id="ruleTableWrapper">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center" style="width:50px">#</th>
                            <th><i class="fas fa-tag me-1"></i>條件點位</th>
                            <th class="text-center" style="width:90px">運算子</th>
                            <th class="text-center" style="width:100px">數值</th>
                            <th><i class="fas fa-bolt me-1"></i>控制點位</th>
                            <th class="text-center" style="width:100px">控制值</th>
                            <th>備註</th>
                            <th class="text-center" style="width:70px">操作</th>
                        </tr>
                    </thead>
                    <tbody id="ruleTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<link rel="stylesheet" href="~/css/conditionctrl.css" />

<script>
    window._condCtrlData = {
        allPoints:   @Html.Raw(pointJson),
        allCoords:   @Html.Raw(coordJson),
        allDbCoords: @Html.Raw(dbCoordJson),
        dbRules:     @Html.Raw(existingRulesJson)
    };
</script>

@section Scripts {
    <script src="~/js/conditionctrl.js"></script>
}
