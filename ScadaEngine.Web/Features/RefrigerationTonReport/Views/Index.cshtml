@model ScadaEngine.Web.Features.RefrigerationTonReport.Models.RefrigerationTonReportViewModel
@{
    ViewData["Title"] = Localizer["refrigerationtonreport.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-snowflake text-primary me-2"></i>@Localizer["refrigerationtonreport.title"]
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>@Localizer["refrigerationtonreport.breadcrumb.energy"]
        </span>
    </div>

    <!-- 查詢條件 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <i class="fas fa-filter me-1"></i>@Localizer["refrigerationtonreport.filter.title"]
        </div>
        <div class="card-body p-3">
            <div class="rt-filter-bar">
                <div class="rt-circuit">
                    <label class="form-label fw-semibold"><i class="fas fa-sitemap me-1"></i>@Localizer["refrigerationtonreport.filter.circuit"]</label>
                    <select id="rtCircuit" class="form-select form-select-sm">
                        <option value="">@Localizer["refrigerationtonreport.select.loading"]</option>
                    </select>
                </div>
                <div class="rt-narrow-unit">
                    <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i>@Localizer["refrigerationtonreport.filter.granularity"]</label>
                    <select id="rtGranularity" class="form-select form-select-sm">
                        <option value="hour">@Localizer["refrigerationtonreport.granularity.hour"]</option>
                        <option value="day" selected>@Localizer["refrigerationtonreport.granularity.day"]</option>
                        <option value="month">@Localizer["refrigerationtonreport.granularity.month"]</option>
                        <option value="year">@Localizer["refrigerationtonreport.granularity.year"]</option>
                    </select>
                </div>

                <!-- 時粒度：起訖時 -->
                <div class="rt-wide-date rt-period rt-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["refrigerationtonreport.filter.hour_start"]</label>
                    <div class="input-group input-group-sm rt-hour-group">
                        <input type="date" id="rtHourStartDate" class="form-control form-control-sm">
                        <select id="rtHourStartHour" class="form-select form-select-sm rt-hour-select"></select>
                    </div>
                </div>
                <div class="rt-wide-date rt-period rt-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["refrigerationtonreport.filter.hour_end"]</label>
                    <div class="input-group input-group-sm rt-hour-group">
                        <input type="date" id="rtHourEndDate" class="form-control form-control-sm">
                        <select id="rtHourEndHour" class="form-select form-select-sm rt-hour-select"></select>
                    </div>
                </div>

                <!-- 日粒度 -->
                <div class="rt-narrow-date rt-period rt-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["refrigerationtonreport.filter.day_start"]</label>
                    <input type="date" id="rtDayStart" class="form-control form-control-sm">
                </div>
                <div class="rt-narrow-date rt-period rt-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["refrigerationtonreport.filter.day_end"]</label>
                    <input type="date" id="rtDayEnd" class="form-control form-control-sm">
                </div>

                <!-- 月粒度 -->
                <div class="rt-narrow-date rt-period rt-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["refrigerationtonreport.filter.month_start"]</label>
                    <input type="month" id="rtMonthStart" class="form-control form-control-sm">
                </div>
                <div class="rt-narrow-date rt-period rt-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["refrigerationtonreport.filter.month_end"]</label>
                    <input type="month" id="rtMonthEnd" class="form-control form-control-sm">
                </div>

                <!-- 年粒度 -->
                <div class="rt-narrow-date rt-period rt-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["refrigerationtonreport.filter.year_start"]</label>
                    <input type="number" id="rtYearStart" class="form-control form-control-sm" min="2000" max="2100">
                </div>
                <div class="rt-narrow-date rt-period rt-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["refrigerationtonreport.filter.year_end"]</label>
                    <input type="number" id="rtYearEnd" class="form-control form-control-sm" min="2000" max="2100">
                </div>

                <div class="rt-btn">
                    <button class="btn btn-primary btn-sm" onclick="window._rt.query()">
                        <i class="fas fa-search me-1"></i>@Localizer["refrigerationtonreport.button.query"]
                    </button>
                </div>
                <div class="rt-btn">
                    <button class="btn btn-success btn-sm" onclick="window._rt.exportExcel()" id="rtBtnExport" disabled>
                        <i class="fas fa-file-excel me-1"></i>@Localizer["refrigerationtonreport.button.export"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 結果區 -->
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-chart-bar me-1"></i>@Localizer["refrigerationtonreport.chart.title"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small" id="rtWarnText"></span>
                        <button type="button" id="rtBtnToggleBreakdown" class="btn btn-sm btn-outline-secondary d-none" onclick="window._rt.toggleBreakdown()">
                            <i class="fas fa-layer-group me-1"></i><span id="rtBtnToggleBreakdownText">@Localizer["refrigerationtonreport.button.show_breakdown"]</span>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div style="height:360px;">
                        <canvas id="rtChart"></canvas>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    @Localizer["refrigerationtonreport.label.total"]：<span id="rtTotal" class="fw-bold text-primary">--</span> RT·h
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <i class="fas fa-table me-1"></i>@Localizer["refrigerationtonreport.table.title"]
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:420px;overflow-y:auto;">
                        <table class="table table-striped table-hover table-bordered mb-0">
                            <thead class="table-dark" style="position:sticky;top:0;z-index:30;">
                                <tr>
                                    <th>@Localizer["refrigerationtonreport.table.col_period"]</th>
                                    <th class="text-end">@Localizer["refrigerationtonreport.table.col_rt_hour"]</th>
                                </tr>
                            </thead>
                            <tbody id="rtTableBody">
                                <tr><td colspan="2" class="text-center text-muted py-4">@Localizer["refrigerationtonreport.table.empty"]</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/refrigerationtonreport.css" />

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/js/refrigerationtonreport.js"></script>
    <script>
        window._rtInit = { today: '@Model.dtToday.ToString("yyyy-MM-dd")' };
    </script>
}
