@model ScadaEngine.Web.Features.ElectricityCostReport.Models.ElectricityCostReportViewModel
@{
    ViewData["Title"] = Localizer["costreport.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-file-invoice-dollar text-primary me-2"></i>@Localizer["costreport.title"]
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>@Localizer["costreport.breadcrumb.energy"]
        </span>
    </div>

    <!-- 查詢條件（版型同用電報表，樣式共用 energyreport.css 的 er-* class） -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <i class="fas fa-filter me-1"></i>@Localizer["costreport.filter.title"]
        </div>
        <div class="card-body p-3">
            <div class="er-filter-bar">
                <div class="er-circuit">
                    <label class="form-label fw-semibold"><i class="fas fa-sitemap me-1"></i>@Localizer["costreport.filter.circuit"]</label>
                    <select id="ecrCircuit" class="form-select form-select-sm">
                        <option value="">@Localizer["costreport.select.loading"]</option>
                    </select>
                </div>
                <div class="er-narrow-unit">
                    <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i>@Localizer["costreport.filter.granularity"]</label>
                    <select id="ecrGranularity" class="form-select form-select-sm">
                        <option value="hour">@Localizer["costreport.granularity.hour"]</option>
                        <option value="day" selected>@Localizer["costreport.granularity.day"]</option>
                        <option value="month">@Localizer["costreport.granularity.month"]</option>
                        <option value="year">@Localizer["costreport.granularity.year"]</option>
                    </select>
                </div>

                <!-- 時粒度：起訖時（日期 + 0~23 時，無分鐘） -->
                <div class="er-wide-date er-period er-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["costreport.filter.hour_start"]</label>
                    <div class="input-group input-group-sm er-hour-group">
                        <input type="date" id="ecrHourStartDate" class="form-control form-control-sm">
                        <select id="ecrHourStartHour" class="form-select form-select-sm er-hour-select"></select>
                    </div>
                </div>
                <div class="er-wide-date er-period er-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["costreport.filter.hour_end"]</label>
                    <div class="input-group input-group-sm er-hour-group">
                        <input type="date" id="ecrHourEndDate" class="form-control form-control-sm">
                        <select id="ecrHourEndHour" class="form-select form-select-sm er-hour-select"></select>
                    </div>
                </div>

                <!-- 日粒度：起訖日 -->
                <div class="er-narrow-date er-period er-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["costreport.filter.day_start"]</label>
                    <input type="date" id="ecrDayStart" class="form-control form-control-sm">
                </div>
                <div class="er-narrow-date er-period er-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["costreport.filter.day_end"]</label>
                    <input type="date" id="ecrDayEnd" class="form-control form-control-sm">
                </div>

                <!-- 月粒度：起訖月 -->
                <div class="er-narrow-date er-period er-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["costreport.filter.month_start"]</label>
                    <input type="month" id="ecrMonthStart" class="form-control form-control-sm">
                </div>
                <div class="er-narrow-date er-period er-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["costreport.filter.month_end"]</label>
                    <input type="month" id="ecrMonthEnd" class="form-control form-control-sm">
                </div>

                <!-- 年粒度：起訖年 -->
                <div class="er-narrow-date er-period er-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["costreport.filter.year_start"]</label>
                    <input type="number" id="ecrYearStart" class="form-control form-control-sm" min="2000" max="2100">
                </div>
                <div class="er-narrow-date er-period er-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["costreport.filter.year_end"]</label>
                    <input type="number" id="ecrYearEnd" class="form-control form-control-sm" min="2000" max="2100">
                </div>

                <!-- 月粒度：期別實際區間提示 -->
                <div class="er-period er-period-month er-period-hint">
                    <span id="ecrPeriodHint" class="text-muted small"></span>
                </div>

                <div class="er-btn">
                    <button class="btn btn-primary btn-sm" onclick="window._ecr.query()">
                        <i class="fas fa-search me-1"></i>@Localizer["costreport.button.query"]
                    </button>
                </div>
                <div class="er-btn">
                    <button class="btn btn-success btn-sm" onclick="window._ecr.exportExcel()" id="btnEcrExport" disabled>
                        <i class="fas fa-file-excel me-1"></i>@Localizer["costreport.button.export"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 結果區 -->
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-chart-bar me-1"></i>@Localizer["costreport.chart.title"]</span>
                    <span class="text-muted small" id="ecrEstimateText"></span>
                </div>
                <div class="card-body">
                    <div style="height:360px;position:relative;">
                        <canvas id="ecrChart"></canvas>
                        <div id="ecrNoData" class="ecr-nodata" style="display:none;"></div>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    @Localizer["costreport.label.total"]：<span id="ecrTotalCost" class="fw-bold text-primary">--</span> @Localizer["costreport.unit.ntd"]
                    <span class="ms-3">@Localizer["costreport.label.total_kwh"]：<span id="ecrTotalKwh" class="fw-bold">--</span> kWh</span>
                    <span class="ms-3 text-muted">@Localizer["costreport.note.exclude_base"]</span>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <i class="fas fa-table me-1"></i>@Localizer["costreport.table.title"]
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:420px;overflow-y:auto;">
                        <table class="table table-striped table-hover table-bordered mb-0">
                            <thead class="table-dark" style="position:sticky;top:0;z-index:30;">
                                <tr>
                                    <th>@Localizer["costreport.table.col_period"]</th>
                                    <th class="text-end">@Localizer["costreport.table.col_kwh"]</th>
                                    <th class="text-end">@Localizer["costreport.table.col_cost"]</th>
                                </tr>
                            </thead>
                            <tbody id="ecrTableBody">
                                <tr><td colspan="3" class="text-center text-muted py-4">@Localizer["costreport.table.empty"]</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/energyreport.css" />
<link rel="stylesheet" href="~/css/electricitycostreport.css" asp-append-version="true" />

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/js/electricitycostreport.js" asp-append-version="true"></script>
    <script>
        window._ecrInit = { today: '@Model.dtToday.ToString("yyyy-MM-dd")' };
    </script>
}
