@model ScadaEngine.Web.Features.Ems.Models.EmsIndexViewModel
@{
    ViewData["Title"] = Localizer["ems.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
    // 各驅動 JS 依「其相關卡片是否至少一張可見」條件載入（卡片不渲染 → 輪詢自然不發生）
    bool hasEmsJs    = Model.HasCard("MainMeter") || Model.HasCard("Demand");
    bool hasEnergyJs = Model.HasCard("EnergyBar") || Model.HasCard("EnergyPie") || Model.HasCard("Yoy");
    bool hasCostJs   = Model.HasCard("Cost");
}

<div class="ems-hub">
    <div class="container-fluid mt-3">
        @if (Model.aVisibleCards.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-th-large fa-2x mb-3 d-block opacity-50"></i>
                @Localizer["ems.no_cards"]
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var card in Model.aVisibleCards)
                {
                    <partial name="@card.szPartialViewName" />
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    @if (hasEmsJs || hasEnergyJs)
    {
        <script src="~/lib/chartjs/chart.umd.min.js"></script>
    }
    @if (hasEmsJs)
    {
        <script src="~/js/ems.js" asp-append-version="true"></script>
    }
    @if (hasEnergyJs)
    {
        <script src="~/js/ems-hub-energy.js"></script>
    }
    @if (hasCostJs)
    {
        <script src="~/js/ems-hub-cost.js" asp-append-version="true"></script>
    }
}
