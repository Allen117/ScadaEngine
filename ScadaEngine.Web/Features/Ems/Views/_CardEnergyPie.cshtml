<!-- 子迴路用電圓餅圖卡片（與比較表共用同一組日/月/年切換） -->
<div class="col-md-6 col-lg-5 col-xl-4">
    <div class="card shadow-sm h-100 d-flex flex-column">
        <div class="card-header py-2 d-flex justify-content-between align-items-center flex-wrap gap-2"
             style="background:#43a047;color:#fff;">
            <span><i class="fas fa-chart-pie me-1"></i>子迴路用電占比</span>
            <span class="d-flex align-items-center gap-2">
                <span class="btn-group btn-group-sm ems-gran-group" role="group" aria-label="占比/比較粒度切換" id="pdGranGroup">
                    <button type="button" class="btn ems-gran-btn active" data-gran="hour">日</button>
                    <button type="button" class="btn ems-gran-btn" data-gran="day">月</button>
                    <button type="button" class="btn ems-gran-btn" data-gran="month">年</button>
                </span>
                <input type="date" id="pdPivotDate" class="form-control form-control-sm ems-hub-picker" />
                <input type="month" id="pdPivotMonth" class="form-control form-control-sm ems-hub-picker" style="display:none;" />
                <input type="number" id="pdPivotYear" min="2000" max="2100" class="form-control form-control-sm ems-hub-picker" style="display:none;" />
            </span>
        </div>
        <div class="card-body p-2 flex-grow-1">
            <div id="pieEmpty" class="ems-hub-empty" style="display:none;"></div>
            <div id="pieChartWrap" class="ems-hub-chart-wrap">
                <canvas id="mainMeterPieChart"></canvas>
            </div>
            <div id="pieNegNote" class="small text-muted mt-1"></div>
        </div>
    </div>
</div>
