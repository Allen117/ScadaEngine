@model ScadaEngine.Web.Features.Realtime.Models.RealtimeMonitorViewModel
@{
    ViewData["Title"] = "SCADA 即時監控儀表板";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var firstCoordinator = Model.CoordinatorList.FirstOrDefault();
    // SID 格式: {nDatabaseId * 65536 + nModbusId * 256 + 1}-S{N}
    // 同一個 Coordinator 的所有 SID 數字都落在 [Id*65536, (Id+1)*65536) 範圍內
    static List<RealtimeDataItemModel> FilterByCoordinatorId(List<RealtimeDataItemModel> list, int coordinatorId)
    {
        if (coordinatorId <= 0) return list;
        int rangeBase = coordinatorId * 65536;
        return list.Where(x =>
        {
            var hyphen = x.szSID.IndexOf('-');
            if (hyphen < 0) return false;
            return int.TryParse(x.szSID[..hyphen], out var num) && num >= rangeBase && num < rangeBase + 65536;
        }).ToList();
    }
    var initialFilteredList = firstCoordinator == null
        ? Model.RealtimeDataList
        : FilterByCoordinatorId(Model.RealtimeDataList, firstCoordinator.Id);
    // 輸出完整點位資料給 JS，讓切換設備時立即可用
    var initialDataJson = System.Text.Json.JsonSerializer.Serialize(
        Model.RealtimeDataList.Select(item => new {
            subTopic = item.szSubTopic,
            sid = item.szSID,
            name = item.szName,
            value = item.hasData ? item.dValue.ToString("F3") : "--",
            unit = item.szUnit,
            quality = item.szQuality,
            timestamp = item.hasData ? item.dtTimestamp.ToString("yyyy-MM-dd HH:mm:ss") : "--",
            isRecent = item.isRecent,
            cssClass = item.CssRowClass,
            badgeClass = item.QualityBadgeClass
        })
    );
}

<div class="container-fluid mt-4">

    <!-- 頁面標題與連線狀態 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">
            <i class="fas fa-tachometer-alt text-primary me-2"></i>
            SCADA 即時監控儀表板
        </h2>
        <div class="d-flex align-items-center">
            <span class="badge @(Model.isConnectionHealthy ? "bg-success" : "bg-danger") me-3" id="connectionStatus">
                <i class="fas @(Model.isConnectionHealthy ? "fa-wifi" : "fa-exclamation-triangle") me-1"></i>
                @(Model.isConnectionHealthy ? "連線正常" : "連線異常")
            </span>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="refreshData()" id="refreshBtn">
                <i class="fas fa-sync-alt me-1" id="refreshIcon"></i> 重新整理
            </button>
        </div>
    </div>

    <div class="row">
        <!-- 左側 Coordinator 清單 -->
        <div class="col-md-2 pe-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2">
                    <h6 class="mb-0">
                        <i class="fas fa-server me-1"></i>
                        設備清單
                    </h6>
                </div>
                <div id="coordinatorList">
                    @if (Model.CoordinatorList.Any())
                    {
                        var isFirst = true;
                        @foreach (var coordinator in Model.CoordinatorList)
                        {
                            var modbusIds = coordinator.szModbusID.Split(',', StringSplitOptions.TrimEntries);
                            var deviceNames = coordinator.szDeviceName.Split(',', StringSplitOptions.TrimEntries);
                            var hasSubItems = modbusIds.Length > 1;

                            if (hasSubItems)
                            {
                                <div class="coordinator-group">
                                    <a href="#" class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                       data-id="@coordinator.Id"
                                       data-modbusid="@coordinator.szModbusID"
                                       data-name="@coordinator.szName">
                                        <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                        <i class="fas fa-plug me-1 text-secondary"></i>
                                        <span class="small">@coordinator.szName</span>
                                    </a>
                                    <div class="sub-menu" style="display:none;">
                                        @for (var j = 0; j < modbusIds.Length; j++)
                                        {
                                            var subName = j < deviceNames.Length ? deviceNames[j] : "";
                                            var subModbusId = modbusIds[j];
                                            <a href="#"
                                               class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                               data-id="@coordinator.Id"
                                               data-modbusid="@subModbusId"
                                               data-name="@(string.IsNullOrEmpty(subName) ? subModbusId : subName)">
                                                <i class="fas fa-microchip me-1 text-muted" style="font-size:.75rem;"></i>
                                                <span class="small">@(string.IsNullOrEmpty(subName) ? subModbusId : subName)</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                                isFirst = false;
                            }
                            else
                            {
                                <a href="#" class="list-group-item list-group-item-action py-2 coordinator-item @(isFirst ? "active" : "")"
                                   data-id="@coordinator.Id"
                                   data-modbusid="@coordinator.szModbusID"
                                   data-name="@coordinator.szName">
                                    <i class="fas fa-plug me-1 text-secondary"></i>
                                    <span class="small">@coordinator.szName</span>
                                </a>
                                isFirst = false;
                            }
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted small py-3 text-center">
                            <i class="fas fa-inbox d-block mb-1"></i>
                            無設備資料
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 右側主要內容 -->
        <div class="col-md-10">

    <!-- 錯誤訊息 -->
    @if (!string.IsNullOrEmpty(Model.szErrorMessage))
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @Model.szErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }

    <!-- 即時資料表格 -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-table text-primary me-2"></i>
                        即時資料監控 (<span id="pointCount">@initialFilteredList.Count</span> 筆)
                        @if (firstCoordinator != null)
                        {
                            <small class="text-muted ms-2" id="currentCoordinatorName">— @firstCoordinator.szName</small>
                        }
                    </h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0" id="realtimeTable">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 25%; cursor: pointer; user-select: none;" onclick="sortTable('name')" id="th-name">名稱 <span class="sort-icon">⇅</span></th>
                                    <th style="width: 20%; cursor: pointer; user-select: none;" onclick="sortTable('subTopic')" id="th-subTopic">SID <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" class="text-end" onclick="sortTable('value')" id="th-value">數值 <span class="sort-icon">⇅</span></th>
                                    <th style="width: 10%; cursor: pointer; user-select: none;" onclick="sortTable('unit')" id="th-unit">單位 <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" onclick="sortTable('quality')" id="th-quality">品質 <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" onclick="sortTable('timestamp')" id="th-timestamp">時間戳記 <span class="sort-icon">⇅</span></th>
                                </tr>
                            </thead>
                            <tbody id="realtimeTableBody">
                                @if (initialFilteredList.Any())
                                {
                                    @foreach (var item in initialFilteredList)
                                    {
                                        <tr class="@item.CssRowClass" data-subtopic="@item.szSubTopic">
                                            <td>@item.szName</td>
                                            <td><small class="text-muted">@item.szSubTopic</small></td>
                                            <td class="text-end">
                                                <span class="fw-bold">@(item.hasData ? item.dValue.ToString("F3") : "--")</span>
                                            </td>
                                            <td><span class="badge bg-light text-dark">@item.szUnit</span></td>
                                            <td><span class="badge @item.QualityBadgeClass">@item.szQuality</span></td>
                                            <td><small>@(item.hasData ? item.dtTimestamp.ToString("MM-dd HH:mm:ss") : "--")</small></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                            尚無即時資料，請確認 MQTT 連線狀態
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-light text-muted">
                    <div class="d-flex justify-content-between">
                        <small>
                            <i class="fas fa-info-circle me-1"></i>
                            自動更新週期: 3 秒 | 訂閱主題: SCADA/Realtime/+
                        </small>
                        <small id="footerLastUpdate">
                            最後更新: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
        </div><!-- /col-md-10 -->
    </div><!-- /row -->
</div><!-- /container-fluid -->

<!-- 自訂樣式 -->
<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }
    
    .row-recent {
        animation: pulse-green 1s ease-in-out;
    }
    
    .row-outdated {
        opacity: 0.7;
    }

    .row-nodata {
        opacity: 0.5;
        color: #6c757d;
    }

    thead th .sort-icon {
        font-size: 0.75em;
        opacity: 0.5;
        margin-left: 4px;
    }

    thead th.sort-asc .sort-icon::before { content: '▲'; }
    thead th.sort-desc .sort-icon::before { content: '▼'; }
    thead th.sort-asc .sort-icon,
    thead th.sort-desc .sort-icon { opacity: 1; font-size: 0.8em; }
    thead th.sort-asc span,
    thead th.sort-desc span { display: inline; }
    
    @@keyframes pulse-green {
        0% { background-color: rgba(40, 167, 69, 0.3); }
        100% { background-color: inherit; }
    }

    .cell-updated {
        animation: cell-flash 0.8s ease-out;
    }

    @@keyframes cell-flash {
        0%   { background-color: rgba(255, 193, 7, 0.65); }
        100% { background-color: transparent; }
    }
    
    .card {
        border: none;
        border-radius: 10px;
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }

    .coordinator-item,
    .coordinator-toggle {
        border-left: 3px solid transparent;
        transition: border-color 0.15s;
    }
    .coordinator-item:hover,
    .coordinator-toggle:hover {
        border-left-color: #0d6efd;
    }
    .coordinator-item.active,
    .coordinator-toggle.active {
        border-left-color: #0d6efd;
        background-color: #e8f0fe !important;
        color: #0d6efd !important;
    }
    .sub-item {
        border-left: 3px solid transparent;
        background-color: #f8f9fa;
        transition: border-color 0.15s;
    }
    .sub-item:hover {
        border-left-color: #6ea8fe;
    }
    .sub-item.active {
        border-left-color: #6ea8fe;
        background-color: #dbe9fd !important;
        color: #0d6efd !important;
    }
    .toggle-icon.open {
        transform: rotate(90deg);
    }
</style>

<!-- JavaScript 自動更新邏輯 -->
<script>
    let isRefreshing = false;

    // 目前選取的 Coordinator DB Id（0 = 不篩選）
    let currentCoordinatorDbId = @(firstCoordinator?.Id ?? 0);
    // 子選單篩選：特定 ModbusID（null = 顯示整個 Coordinator）
    let currentSubModbusId = null;

    // 排序狀態
    let sortColumn = null;
    let sortDirection = 'asc'; // 'asc' | 'desc'

    // 排序點擊處理
    function sortTable(column) {
        if (sortColumn === column) {
            sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        } else {
            sortColumn = column;
            sortDirection = 'asc';
        }
        updateSortIcons();
        updateTable();
    }

    // 更新欄位排序圖示
    function updateSortIcons() {
        ['name', 'subTopic', 'value', 'unit', 'quality', 'timestamp'].forEach(col => {
            const th = document.getElementById('th-' + col);
            if (!th) return;
            th.classList.remove('sort-asc', 'sort-desc');
            th.querySelector('.sort-icon').textContent = '⇅';
            if (col === sortColumn) {
                th.classList.add(sortDirection === 'asc' ? 'sort-asc' : 'sort-desc');
                th.querySelector('.sort-icon').textContent = '';
            }
        });
    }

    // 取得 SID 中 S 後的序號（e.g. "196865-S3" → 3）
    function getSNumber(sid) {
        if (!sid) return 0;
        const m = sid.match(/-S(\d+)$/);
        return m ? parseInt(m[1]) : 0;
    }

    // 對資料陣列排序
    function applySorting(data) {
        if (!sortColumn) {
            // 預設依 SID 的 S 序號由小到大
            return [...data].sort((a, b) => getSNumber(a.sid) - getSNumber(b.sid));
        }
        return [...data].sort((a, b) => {
            let va = a[sortColumn] ?? '';
            let vb = b[sortColumn] ?? '';
            if (sortColumn === 'value') {
                const na = parseFloat(va);
                const nb = parseFloat(vb);
                const aIsNum = !isNaN(na);
                const bIsNum = !isNaN(nb);
                if (aIsNum && bIsNum) { va = na; vb = nb; }
                else if (!aIsNum && bIsNum) return 1;
                else if (aIsNum && !bIsNum) return -1;
            }
            if (va < vb) return sortDirection === 'asc' ? -1 : 1;
            if (va > vb) return sortDirection === 'asc' ? 1 : -1;
            return 0;
        });
    }

    // 快取全部點位資料（含未收到資料的點位），由 Razor 初始化
    let lastData = @Html.Raw(initialDataJson);

    // 記錄目前表格顯示的 subTopic 順序，用於判斷是否需要重建
    let currentDisplayOrder = [];

    // 依目前選取的 Coordinator 篩選資料
    function filterByCoordinator(data) {
        if (!currentCoordinatorDbId) return data;

        let rangeBase, rangeEnd;
        if (currentSubModbusId !== null) {
            // 子選單篩選：SID 範圍 = dbId*65536 + modbusId*256 ~ +256
            const mid = parseInt(currentSubModbusId);
            rangeBase = currentCoordinatorDbId * 65536 + mid * 256;
            rangeEnd = rangeBase + 256;
        } else {
            // 整個 Coordinator 範圍
            rangeBase = currentCoordinatorDbId * 65536;
            rangeEnd = rangeBase + 65536;
        }

        const filtered = data.filter(item => {
            if (!item.sid) return false;
            const hyphen = item.sid.indexOf('-');
            if (hyphen < 0) return false;
            const sidNum = parseInt(item.sid.substring(0, hyphen));
            return !isNaN(sidNum) && sidNum >= rangeBase && sidNum < rangeEnd;
        });
        console.log(`[篩選] CoordinatorId=${currentCoordinatorDbId}, SubModbusId=${currentSubModbusId}, 範圍=[${rangeBase}, ${rangeEnd}), 總資料=${data.length}, 篩選後=${filtered.length}`);
        if (filtered.length === 0 && data.length > 0) {
            const sample = data.slice(0, 5).map(d => d.sid);
            console.warn('[篩選] 篩選結果為空！前 5 筆 SID:', sample);
        }
        return filtered;
    }

    // 建立單行 HTML
    function buildRowHtml(item) {
        const tsDisplay = item.timestamp === '--' ? '--' : item.timestamp.substring(5, 19);
        return `<tr class="${item.cssClass}" data-subtopic="${item.subTopic}">
            <td>${item.name}</td>
            <td><small class="text-muted">${item.subTopic}</small></td>
            <td class="text-end"><span class="fw-bold">${item.value}</span></td>
            <td><span class="badge bg-light text-dark">${item.unit}</span></td>
            <td><span class="badge ${item.badgeClass}">${item.quality}</span></td>
            <td><small>${tsDisplay}</small></td>
        </tr>`;
    }

    // 對單一 cell 觸發閃爍動畫
    function flashCell(el) {
        el.classList.remove('cell-updated');
        void el.offsetWidth; // 強制 reflow，重新觸發動畫
        el.classList.add('cell-updated');
    }

    // 比對單行資料，只更新有變化的欄位
    function updateRowIfChanged(row, item) {
        // value
        const valueSpan = row.querySelector('td:nth-child(3) span.fw-bold');
        if (valueSpan && valueSpan.textContent !== item.value) {
            valueSpan.textContent = item.value;
            flashCell(valueSpan);
        }
        // quality badge
        const qualityBadge = row.querySelector('td:nth-child(5) span.badge');
        const newQualityClass = `badge ${item.badgeClass}`;
        if (qualityBadge) {
            if (qualityBadge.textContent !== item.quality) qualityBadge.textContent = item.quality;
            if (qualityBadge.className !== newQualityClass) qualityBadge.className = newQualityClass;
        }
        // timestamp
        const tsSmall = row.querySelector('td:nth-child(6) small');
        const newTs = item.timestamp === '--' ? '--' : item.timestamp.substring(5, 19);
        if (tsSmall && tsSmall.textContent !== newTs) tsSmall.textContent = newTs;
        // row class
        if (row.className !== item.cssClass) row.className = item.cssClass;
    }

    // 自動更新函式
    async function refreshData() {
        if (isRefreshing) return;
        try {
            isRefreshing = true;
            const refreshBtn = document.getElementById('refreshBtn');
            const refreshIcon = document.getElementById('refreshIcon');
            refreshIcon.classList.add('fa-spin');
            refreshBtn.disabled = true;

            const response = await fetch('/api/realtime/latest');
            const result = await response.json();

            if (result.success) {
                updateTable(result.data);
                updateConnectionStatus(result.connectionStatus);
                updateFooterTime(result.timestamp);
            } else {
                console.error('更新資料失敗:', result.error);
                showTemporaryAlert('更新資料失敗: ' + result.error, 'danger');
            }
        } catch (error) {
            console.error('AJAX 請求失敗:', error);
            showTemporaryAlert('網路請求失敗，請檢查連線', 'danger');
        } finally {
            isRefreshing = false;
            const refreshBtn = document.getElementById('refreshBtn');
            const refreshIcon = document.getElementById('refreshIcon');
            refreshIcon.classList.remove('fa-spin');
            refreshBtn.disabled = false;
        }
    }

    // 更新連線狀態
    function updateConnectionStatus(isConnected) {
        const statusBadge = document.getElementById('connectionStatus');
        if (isConnected) {
            statusBadge.className = 'badge bg-success me-3';
            statusBadge.innerHTML = '<i class="fas fa-wifi me-1"></i>連線正常';
        } else {
            statusBadge.className = 'badge bg-danger me-3';
            statusBadge.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i>連線異常';
        }
    }

    // 更新表格：結構不變時 partial update，否則全部重建
    function updateTable(data) {
        if (data !== undefined && data && data.length > 0) {
            // 以 SID 為 key 合併：保留既有佔位項目，用新資料覆蓋已存在的
            const merged = new Map();
            lastData.forEach(item => merged.set(item.sid, item));
            data.forEach(item => merged.set(item.sid, item));
            lastData = Array.from(merged.values());
        }
        const filtered = filterByCoordinator(lastData);
        const tbody = document.getElementById('realtimeTableBody');

        const pointCountEl = document.getElementById('pointCount');
        if (pointCountEl) pointCountEl.textContent = filtered.length;
        if (filtered.length === 0) {
            tbody.innerHTML = `<tr>
                <td colspan="6" class="text-center text-muted py-4">
                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                    尚無即時資料，請確認 MQTT 連線狀態
                </td></tr>`;
            currentDisplayOrder = [];
            return;
        }

        const sorted = applySorting(filtered);
        const newOrder = sorted.map(x => x.subTopic);

        // 判斷列順序是否與現有表格一致
        const sameStructure =
            newOrder.length === currentDisplayOrder.length &&
            newOrder.every((s, i) => s === currentDisplayOrder[i]);

        if (!sameStructure) {
            // 結構不同（切換設備、排序改變、初次載入）：全部重建
            tbody.innerHTML = sorted.map(item => buildRowHtml(item)).join('');
            currentDisplayOrder = newOrder;
            return;
        }

        // 結構相同：逐行 partial update，只更新有變化的 cell
        const rows = Array.from(tbody.querySelectorAll('tr[data-subtopic]'));
        sorted.forEach((item, i) => {
            if (rows[i]) updateRowIfChanged(rows[i], item);
        });
    }

    // 更新頁腳時間
    function updateFooterTime(timestamp) {
        document.getElementById('footerLastUpdate').textContent = '最後更新: ' + timestamp;
    }

    // 顯示臨時提醒
    function showTemporaryAlert(message, type = 'info') {
        const alertHtml = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
        const container = document.querySelector('.container-fluid');
        const alertDiv = document.createElement('div');
        alertDiv.innerHTML = alertHtml;
        container.insertBefore(alertDiv, container.firstChild);
        setTimeout(() => {
            const alert = document.querySelector('.alert');
            if (alert) alert.remove();
        }, 3000);
    }

    // 頁面載入完成後啟動
    document.addEventListener('DOMContentLoaded', function() {
        // 以 Razor 初始資料立即繪製表格（不等 AJAX）
        updateTable();

        function clearAllSidebarActive() {
            document.querySelectorAll('.coordinator-item, .coordinator-toggle, .sub-item')
                .forEach(el => el.classList.remove('active'));
        }

        // 單一設備點擊（無子選單）
        document.querySelectorAll('.coordinator-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                clearAllSidebarActive();
                this.classList.add('active');
                currentCoordinatorDbId = parseInt(this.dataset.id) || 0;
                currentSubModbusId = null;
                const nameEl = document.getElementById('currentCoordinatorName');
                if (nameEl) nameEl.textContent = '— ' + (this.dataset.name || '');
                updateTable();
            });
        });

        // 展開/收合子選單 + 顯示整個 Coordinator 資料
        document.querySelectorAll('.coordinator-toggle').forEach(toggle => {
            toggle.addEventListener('click', function(e) {
                e.preventDefault();
                const subMenu = this.nextElementSibling;
                const icon = this.querySelector('.toggle-icon');
                if (subMenu.style.display === 'none') {
                    subMenu.style.display = '';
                    icon.classList.add('open');
                } else {
                    subMenu.style.display = 'none';
                    icon.classList.remove('open');
                }
                clearAllSidebarActive();
                this.classList.add('active');
                currentCoordinatorDbId = parseInt(this.dataset.id) || 0;
                currentSubModbusId = null;
                const nameEl = document.getElementById('currentCoordinatorName');
                if (nameEl) nameEl.textContent = '— ' + (this.dataset.name || '');
                updateTable();
            });
        });

        // 子項目點擊：篩選特定 ModbusID
        document.querySelectorAll('.sub-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                clearAllSidebarActive();
                this.classList.add('active');
                currentCoordinatorDbId = parseInt(this.dataset.id) || 0;
                currentSubModbusId = this.dataset.modbusid;
                const nameEl = document.getElementById('currentCoordinatorName');
                if (nameEl) nameEl.textContent = '— ' + (this.dataset.name || '');
                updateTable();
            });
        });

        // 1 秒後執行第一次 AJAX 更新
        setTimeout(refreshData, 1000);

        // 每 3 秒自動更新
        setInterval(refreshData, 3000);

        console.log('SCADA 即時監控儀表板已啟動，自動更新週期: 3秒');
    });

    // 手動重新整理按鈕
    function manualRefresh() {
        refreshData();
    }

</script>