@model ScadaEngine.Web.Features.Realtime.Models.RealtimeMonitorViewModel
@{
    ViewData["Title"] = Localizer["realtime.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var firstCoordinator = Model.CoordinatorList.FirstOrDefault();
    // SID 格式: {nDatabaseId * 65536 + nModbusId * 256 + 1}-S{N}
    // 同一個 Coordinator 的所有 SID 數字都落在 [Id*65536, (Id+1)*65536) 範圍內
    static List<RealtimeDataItemModel> FilterByCoordinatorId(List<RealtimeDataItemModel> list, int coordinatorId)
    {
        if (coordinatorId <= 0) return list;
        int rangeBase = coordinatorId * 65536;
        return list.Where(x =>
        {
            var hyphen = x.szSID.IndexOf('-');
            if (hyphen < 0) return false;
            return int.TryParse(x.szSID[..hyphen], out var num) && num >= rangeBase && num < rangeBase + 65536;
        }).ToList();
    }
    var initialFilteredList = firstCoordinator == null
        ? Model.RealtimeDataList
        : FilterByCoordinatorId(Model.RealtimeDataList, firstCoordinator.Id);
    // 輸出完整點位資料給 JS，讓切換設備時立即可用
    var initialDataJson = System.Text.Json.JsonSerializer.Serialize(
        Model.RealtimeDataList.Select(item => new {
            subTopic = item.szSubTopic,
            sid = item.szSID,
            name = item.szName,
            value = item.hasData ? item.dValue.ToString("F3") : "--",
            unit = item.szUnit,
            quality = item.szQuality,
            timestamp = item.hasData ? item.dtTimestamp.ToString("yyyy-MM-dd HH:mm:ss") : "--",
            isRecent = item.isRecent,
            cssClass = item.CssRowClass,
            badgeClass = item.QualityBadgeClass
        })
    );

    var szCalcLabel = Localizer["realtime.coordinator.calc"].Value;
    var szUngroupedLabel = Localizer["realtime.coordinator.ungrouped"].Value;
}

<link rel="stylesheet" href="~/css/realtime.css" />

<div class="container-fluid mt-4">

    <!-- 頁面標題與連線狀態 -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">
            <i class="fas fa-tachometer-alt text-primary me-2"></i>
            @Localizer["realtime.title"]
        </h2>
        <div class="d-flex align-items-center">
            <span class="badge @(Model.isConnectionHealthy ? "bg-success" : "bg-danger") me-3" id="connectionStatus">
                <i class="fas @(Model.isConnectionHealthy ? "fa-wifi" : "fa-exclamation-triangle") me-1"></i>
                @(Model.isConnectionHealthy ? Localizer["realtime.connection.ok"].Value : Localizer["realtime.connection.bad"].Value)
            </span>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window._realtime.refreshData()" id="refreshBtn">
                <i class="fas fa-sync-alt me-1" id="refreshIcon"></i> @Localizer["realtime.button.refresh"]
            </button>
        </div>
    </div>

    <div class="row">
        <!-- 左側 Coordinator 清單 -->
        <div class="col-md-2 pe-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2">
                    <h6 class="mb-0">
                        <i class="fas fa-server me-1"></i>
                        @Localizer["realtime.coordinator.title"]
                    </h6>
                </div>
                <div id="coordinatorList">
                    @if (Model.CoordinatorList.Any())
                    {
                        var isFirst = true;
                        @foreach (var coordinator in Model.CoordinatorList)
                        {
                            var modbusIds = coordinator.szModbusID.Split(',', StringSplitOptions.TrimEntries);
                            var deviceNames = coordinator.szDeviceName.Split(',', StringSplitOptions.TrimEntries);
                            var hasSubItems = modbusIds.Length > 1;

                            if (hasSubItems)
                            {
                                <div class="coordinator-group">
                                    <a href="#" class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                       data-id="@coordinator.Id"
                                       data-modbusid="@coordinator.szModbusID"
                                       data-name="@coordinator.szName">
                                        <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                        <i class="fas fa-plug me-1 text-secondary"></i>
                                        <span class="small">@coordinator.szName</span>
                                    </a>
                                    <div class="sub-menu" style="display:none;">
                                        @for (var j = 0; j < modbusIds.Length; j++)
                                        {
                                            var subName = j < deviceNames.Length ? deviceNames[j] : "";
                                            var subModbusId = modbusIds[j];
                                            <a href="#"
                                               class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                               data-id="@coordinator.Id"
                                               data-modbusid="@subModbusId"
                                               data-name="@(string.IsNullOrEmpty(subName) ? subModbusId : subName)">
                                                <i class="fas fa-microchip me-1 text-muted" style="font-size:.75rem;"></i>
                                                <span class="small">@(string.IsNullOrEmpty(subName) ? subModbusId : subName)</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                                isFirst = false;
                            }
                            else
                            {
                                <a href="#" class="list-group-item list-group-item-action py-2 coordinator-item @(isFirst ? "active" : "")"
                                   data-id="@coordinator.Id"
                                   data-modbusid="@coordinator.szModbusID"
                                   data-name="@coordinator.szName">
                                    <i class="fas fa-plug me-1 text-secondary"></i>
                                    <span class="small">@coordinator.szName</span>
                                </a>
                                isFirst = false;
                            }
                        }
                        @if (Model.DbCoordinatorList.Any())
                        {
                            <div class="coordinator-group">
                                <a href="#" class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                   data-sid-prefix="DB"
                                   data-name="DB">
                                    <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                    <i class="fas fa-database me-1 text-secondary"></i>
                                    <span class="small">DB</span>
                                </a>
                                <div class="sub-menu" style="display:none;">
                                    @foreach (var dbCoord in Model.DbCoordinatorList)
                                    {
                                        <a href="#"
                                           class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                           data-sid-prefix="DB@(dbCoord.Id)-"
                                           data-name="@dbCoord.szName">
                                            <i class="fas fa-database me-1 text-muted" style="font-size:.75rem;"></i>
                                            <span class="small">@dbCoord.szName</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                        @if (Model.CalcPointGroups.Any())
                        {
                            <div class="coordinator-group">
                                <a href="#" class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                   data-id="-999"
                                   data-modbusid=""
                                   data-name="@szCalcLabel">
                                    <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                    <i class="fas fa-calculator me-1 text-warning"></i>
                                    <span class="small">@szCalcLabel</span>
                                </a>
                                <div class="sub-menu" style="display:none;">
                                    @foreach (var group in Model.CalcPointGroups)
                                    {
                                        <a href="#"
                                           class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                           data-id="-999"
                                           data-calcgroup="@group"
                                           data-name="@group">
                                            <i class="fas fa-layer-group me-1 text-muted" style="font-size:.75rem;"></i>
                                            <span class="small">@group</span>
                                        </a>
                                    }
                                    @{
                                        var hasUngrouped = Model.CalcGroupMap.Any(kvp => string.IsNullOrWhiteSpace(kvp.Value));
                                    }
                                    @if (hasUngrouped)
                                    {
                                        <a href="#"
                                           class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                           data-id="-999"
                                           data-calcgroup=""
                                           data-name="@szUngroupedLabel">
                                            <i class="fas fa-inbox me-1 text-muted" style="font-size:.75rem;"></i>
                                            <span class="small">@szUngroupedLabel</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <a href="#" class="list-group-item list-group-item-action py-2 coordinator-item"
                               data-id="-999"
                               data-modbusid=""
                               data-name="@szCalcLabel">
                                <i class="fas fa-calculator me-1 text-warning"></i>
                                <span class="small">@szCalcLabel</span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted small py-3 text-center">
                            <i class="fas fa-inbox d-block mb-1"></i>
                            @Localizer["realtime.coordinator.empty"]
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 右側主要內容 -->
        <div class="col-md-10">

    <!-- 錯誤訊息 -->
    @if (!string.IsNullOrEmpty(Model.szErrorMessage))
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @Model.szErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }

    <!-- 即時資料表格 -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-table text-primary me-2"></i>
                        @Localizer["realtime.table.title"] (<span id="pointCount">@initialFilteredList.Count</span> @Localizer["realtime.table.count_suffix"])
                        @if (firstCoordinator != null)
                        {
                            <small class="text-muted ms-2" id="currentCoordinatorName">— @firstCoordinator.szName</small>
                        }
                    </h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0" id="realtimeTable">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 25%; cursor: pointer; user-select: none;" onclick="window._realtime.sortTable('name')" id="th-name">@Localizer["realtime.col.name"] <span class="sort-icon">⇅</span></th>
                                    <th style="width: 20%; cursor: pointer; user-select: none;" onclick="window._realtime.sortTable('subTopic')" id="th-subTopic">@Localizer["realtime.col.sid"] <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" class="text-end" onclick="window._realtime.sortTable('value')" id="th-value">@Localizer["realtime.col.value"] <span class="sort-icon">⇅</span></th>
                                    <th style="width: 10%; cursor: pointer; user-select: none;" onclick="window._realtime.sortTable('unit')" id="th-unit">@Localizer["realtime.col.unit"] <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" onclick="window._realtime.sortTable('quality')" id="th-quality">@Localizer["realtime.col.quality"] <span class="sort-icon">⇅</span></th>
                                    <th style="width: 15%; cursor: pointer; user-select: none;" onclick="window._realtime.sortTable('timestamp')" id="th-timestamp">@Localizer["realtime.col.timestamp"] <span class="sort-icon">⇅</span></th>
                                </tr>
                            </thead>
                            <tbody id="realtimeTableBody">
                                @if (initialFilteredList.Any())
                                {
                                    @foreach (var item in initialFilteredList)
                                    {
                                        <tr class="@item.CssRowClass" data-subtopic="@item.szSubTopic">
                                            <td>@item.szName</td>
                                            <td><small class="text-muted">@item.szSubTopic</small></td>
                                            <td class="text-end">
                                                <span class="fw-bold">@(item.hasData ? item.dValue.ToString("F3") : "--")</span>
                                            </td>
                                            <td><span class="badge bg-light text-dark">@item.szUnit</span></td>
                                            <td><span class="badge @item.QualityBadgeClass">@item.szQuality</span></td>
                                            <td><small>@(item.hasData ? item.dtTimestamp.ToString("MM-dd HH:mm:ss") : "--")</small></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                            @Localizer["realtime.empty.no_data"]
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-light text-muted">
                    <div class="d-flex justify-content-between">
                        <small>
                            <i class="fas fa-info-circle me-1"></i>
                            @Localizer["realtime.footer.note"]
                        </small>
                        <small id="footerLastUpdate">
                            @Localizer["realtime.footer.last_update"]: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
        </div><!-- /col-md-10 -->
    </div><!-- /row -->
</div><!-- /container-fluid -->

@section Scripts {
    <script>
        window._realtimeInitCoordinatorId = @(firstCoordinator?.Id ?? 0);
        window._realtimeInitData = @Html.Raw(initialDataJson);
        window._realtimeCalcGroupMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CalcGroupMap));
    </script>
    <script src="~/js/realtime.js"></script>
}
