@{
    ViewData["Title"] = Localizer["schedule.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var schedules = ViewBag.Schedules as List<ScadaEngine.Web.Features.ScheduleSetting.Models.TimeScheduleModel>;

    var schedulesJson = System.Text.Json.JsonSerializer.Serialize(
        schedules!.Select(s => new {
            id = s.nId, name = s.szName,
            recurrenceType = s.nRecurrenceType,
            runLength = s.nRunLength,
            restLength = s.nRestLength,
            anchorDateTime = s.dtAnchorDateTime?.ToString("yyyy-MM-dd HH:mm"),
            daysOfWeek = s.szDaysOfWeek ?? "",
            daysOfMonth = s.szDaysOfMonth ?? "",
            startTime = s.szStartTime, endTime = s.szEndTime,
            excludeDates = s.szExcludeDates ?? "",
            includeDates = s.szIncludeDates ?? "",
            isEnabled = s.isEnabled, remarks = s.szRemarks ?? ""
        })
    );
}

<link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css" />
<link rel="stylesheet" href="~/css/schedulesetting.css" asp-append-version="true" />

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="fas fa-calendar-alt me-2"></i>@Localizer["schedule.title"]</h4>
        <button class="btn btn-primary" onclick="window._schedule.showAddModal()">
            <i class="fas fa-plus me-1"></i>@Localizer["schedule.button.add"]
        </button>
    </div>

    <!-- 排程列表 -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="scheduleTable">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:50px">@Localizer["schedule.col.enabled"]</th>
                            <th>@Localizer["schedule.col.name"]</th>
                            <th>@Localizer["schedule.col.mode"]</th>
                            <th>@Localizer["schedule.col.days"]</th>
                            <th>@Localizer["schedule.col.timerange"]</th>
                            <th>@Localizer["schedule.col.status"]</th>
                            <th>@Localizer["schedule.col.remarks"]</th>
                            <th style="width:120px">@Localizer["schedule.col.actions"]</th>
                        </tr>
                    </thead>
                    <tbody id="scheduleBody"></tbody>
                </table>
            </div>
            <div id="emptyMsg" class="text-center text-muted py-4 d-none">
                <i class="fas fa-inbox fa-3x mb-2 d-block"></i>
                <div>@Localizer["schedule.empty.no_data"]</div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body py-2 px-3">
            <small class="text-muted">
                <i class="fas fa-info-circle me-1"></i>@Localizer["schedule.footer.note"]
            </small>
        </div>
    </div>
</div>

<!-- 新增/編輯 Modal -->
<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">@Localizer["schedule.modal.title_add"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId" />

                <!-- 名稱 + 模式 -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="fas fa-tag me-1"></i>@Localizer["schedule.field.name"]</label>
                        <input type="text" class="form-control" id="txtName" maxlength="100" placeholder="@Localizer["schedule.field.name_placeholder"]" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="fas fa-sync-alt me-1"></i>@Localizer["schedule.field.recurrence_type"]</label>
                        <select class="form-select" id="selRecurrenceType" onchange="window._schedule.onTypeChange()">
                            <option value="0">@Localizer["schedule.recurrence.weekly"]</option>
                            <option value="1">@Localizer["schedule.recurrence.n_week_cycle"]</option>
                            <option value="2">@Localizer["schedule.recurrence.monthly"]</option>
                            <option value="3">@Localizer["schedule.recurrence.n_month_cycle"]</option>
                        </select>
                    </div>
                </div>

                <!-- 週期參數區（type 1,3 時顯示） -->
                <div class="row mb-3 d-none" id="cycleSection">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="fas fa-play me-1"></i>@Localizer["schedule.cycle.run"]</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="txtRunLength" min="1" max="52" value="1" />
                            <span class="input-group-text" id="runUnit">@Localizer["schedule.unit.week"]</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold"><i class="fas fa-pause me-1"></i>@Localizer["schedule.cycle.rest"]</label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="txtRestLength" min="1" max="52" value="1" />
                            <span class="input-group-text" id="restUnit">@Localizer["schedule.unit.week"]</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["schedule.cycle.anchor_datetime"]</label>
                        <input type="text" class="form-control" id="txtAnchorDateTime" autocomplete="off" />
                        <small class="text-muted">@Localizer["schedule.cycle.anchor_hint"]</small>
                    </div>
                </div>

                <!-- 星期選擇（type 0,1 時顯示） -->
                <div class="mb-3" id="daysOfWeekSection">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["schedule.field.days_of_week"]</label>
                    <div class="d-flex gap-2 flex-wrap" id="dayCheckboxes">
                        <label class="day-check"><input type="checkbox" value="1" /><span>@Localizer["schedule.dayofweek.mon"]</span></label>
                        <label class="day-check"><input type="checkbox" value="2" /><span>@Localizer["schedule.dayofweek.tue"]</span></label>
                        <label class="day-check"><input type="checkbox" value="3" /><span>@Localizer["schedule.dayofweek.wed"]</span></label>
                        <label class="day-check"><input type="checkbox" value="4" /><span>@Localizer["schedule.dayofweek.thu"]</span></label>
                        <label class="day-check"><input type="checkbox" value="5" /><span>@Localizer["schedule.dayofweek.fri"]</span></label>
                        <label class="day-check"><input type="checkbox" value="6" /><span>@Localizer["schedule.dayofweek.sat"]</span></label>
                        <label class="day-check"><input type="checkbox" value="7" /><span>@Localizer["schedule.dayofweek.sun"]</span></label>
                    </div>
                    <div class="mt-1">
                        <button type="button" class="btn btn-outline-secondary btn-xs" onclick="window._schedule.selectWeekdays()">@Localizer["schedule.button.weekdays"]</button>
                        <button type="button" class="btn btn-outline-secondary btn-xs" onclick="window._schedule.selectAll()">@Localizer["schedule.button.select_all"]</button>
                        <button type="button" class="btn btn-outline-secondary btn-xs" onclick="window._schedule.clearDays()">@Localizer["schedule.button.clear"]</button>
                    </div>
                </div>

                <!-- 日期選擇（type 2,3 時顯示） -->
                <div class="mb-3 d-none" id="daysOfMonthSection">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["schedule.field.days_of_month"]</label>
                    <div class="d-flex gap-1 flex-wrap" id="domCheckboxes"></div>
                    <div class="mt-1">
                        <button type="button" class="btn btn-outline-secondary btn-xs" onclick="window._schedule.selectAllDom()">@Localizer["schedule.button.select_all"]</button>
                        <button type="button" class="btn btn-outline-secondary btn-xs" onclick="window._schedule.clearDom()">@Localizer["schedule.button.clear"]</button>
                    </div>
                </div>

                <hr />

                <!-- 時段 -->
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i>@Localizer["schedule.field.start_time"]</label>
                        <input type="text" class="form-control" id="txtStartTime" value="08:00" autocomplete="off" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-clock me-1"></i>@Localizer["schedule.field.end_time"]
                            <small class="text-muted fw-normal">@Localizer["schedule.field.end_time_hint"]</small>
                        </label>
                        <input type="text" class="form-control" id="txtEndTime" value="17:00" autocomplete="off" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold"><i class="fas fa-comment me-1"></i>@Localizer["schedule.field.remarks"]</label>
                        <input type="text" class="form-control" id="txtRemarks" maxlength="200" />
                    </div>
                </div>

                <hr />

                <!-- 例外日 / 加開日 -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-ban me-1 text-danger"></i>@Localizer["schedule.field.exclude_dates"]
                            <small class="text-muted fw-normal">@Localizer["schedule.field.exclude_hint"]</small>
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" id="txtExcludeDate"
                                   placeholder="yyyy/MM/dd" maxlength="10" inputmode="numeric" />
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="window._schedule.addExcludeDate()">
                                <i class="fas fa-plus"></i> @Localizer["schedule.button.add_date"]
                            </button>
                        </div>
                        <div class="date-chip-list mt-2" id="excludeDateChips"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-plus me-1 text-success"></i>@Localizer["schedule.field.include_dates"]
                            <small class="text-muted fw-normal">@Localizer["schedule.field.include_hint"]</small>
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" id="txtIncludeDate"
                                   placeholder="yyyy/MM/dd" maxlength="10" inputmode="numeric" />
                            <button type="button" class="btn btn-outline-success btn-sm" onclick="window._schedule.addIncludeDate()">
                                <i class="fas fa-plus"></i> @Localizer["schedule.button.add_date"]
                            </button>
                        </div>
                        <div class="date-chip-list mt-2" id="includeDateChips"></div>
                    </div>
                </div>

                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="chkEnabled" checked>
                    <label class="form-check-label">@Localizer["schedule.field.is_enabled"]</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["schedule.button.cancel"]</button>
                <button type="button" class="btn btn-primary" onclick="window._schedule.save()">
                    <i class="fas fa-save me-1"></i>@Localizer["schedule.button.save"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window._scheduleInitData = {
            schedules: @Html.Raw(schedulesJson)
        };
    </script>
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/zh-tw.js"></script>
    <script src="~/js/flatpickr-init.js"></script>
    <script src="~/js/schedulesetting.js" asp-append-version="true"></script>
}
