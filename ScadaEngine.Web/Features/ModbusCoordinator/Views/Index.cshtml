@using ScadaEngine.Engine.Models
@model List<CoordinatorModel>
@{
    ViewData["Title"] = Localizer["modbuscoordinator.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/modbuscoordinator.css" />

<div class="container-fluid mt-4">
    <h4 class="mb-3"><i class="fas fa-network-wired me-2"></i>@Localizer["modbuscoordinator.title"]</h4>

    <div class="row">
        <!-- 左側選單 -->
        <div class="col-md-3 pe-0">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2">
                    <h6 class="mb-0"><i class="fas fa-server me-1"></i> @Localizer["modbuscoordinator.card.modbus_comm"]</h6>
                </div>
                <div id="coordinatorList">
                    @if (Model.Any())
                    {
                        @for (var i = 0; i < Model.Count; i++)
                        {
                            var c = Model[i];
                            var modbusIds = c.szModbusID.Split(',', StringSplitOptions.TrimEntries);
                            var deviceNames = c.szDeviceName.Split(',', StringSplitOptions.TrimEntries);
                            var hasSubItems = modbusIds.Length > 1;

                            if (hasSubItems)
                            {
                                <!-- 有子選單的 Coordinator -->
                                <div class="coordinator-group">
                                    <a href="#"
                                       class="list-group-item list-group-item-action py-2 coordinator-toggle"
                                       data-index="@i">
                                        <i class="fas fa-chevron-right me-1 toggle-icon text-secondary" style="font-size:.7rem;transition:transform .2s;"></i>
                                        <i class="fas fa-plug me-1 text-secondary"></i>
                                        <span class="small">@c.szName</span>
                                        @if (!c.isMonitorEnabled)
                                        {
                                            <span class="badge bg-secondary ms-1" style="font-size:.6rem;">@Localizer["modbuscoordinator.badge.disabled"]</span>
                                        }
                                    </a>
                                    <div class="sub-menu" style="display:none;">
                                        @for (var j = 0; j < modbusIds.Length; j++)
                                        {
                                            var subName = j < deviceNames.Length ? deviceNames[j] : "";
                                            var subId = modbusIds[j];
                                            <a href="#"
                                               class="list-group-item list-group-item-action py-1 ps-4 sub-item"
                                               data-index="@i"
                                               data-sub-index="@j"
                                               data-sub-id="@c.Id"
                                               data-sub-modbusid="@subId"
                                               data-sub-name="@subName">
                                                <i class="fas fa-microchip me-1 text-muted" style="font-size:.75rem;"></i>
                                                <span class="small">@(string.IsNullOrEmpty(subName) ? subId : subName)</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <!-- 無子選單的 Coordinator -->
                                <a href="#"
                                   class="list-group-item list-group-item-action py-2 coordinator-item"
                                   data-index="@i">
                                    <i class="fas fa-plug me-1 text-secondary"></i>
                                    <span class="small">@c.szName</span>
                                    @if (!c.isMonitorEnabled)
                                    {
                                        <span class="badge bg-secondary ms-1" style="font-size:.6rem;">@Localizer["modbuscoordinator.badge.disabled"]</span>
                                    }
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                            @Localizer["modbuscoordinator.empty.no_device"]
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 右側詳情 -->
        <div class="col-md-9">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex align-items-center justify-content-between">
                    <h6 class="mb-0" id="detailTitle">
                        <i class="fas fa-info-circle me-1"></i>
                        @(Model.Any() ? Localizer["modbuscoordinator.card.device_detail"].Value : Localizer["modbuscoordinator.card.select_device"].Value)
                    </h6>
                    @if (User.IsInRole("Admin"))
                    {
                        <button class="btn btn-outline-primary btn-sm" id="btnOpenPoints" style="display:none;">
                            <i class="fas fa-list-ol me-1"></i>@Localizer["modbuscoordinator.points.title"]
                        </button>
                    }
                </div>
                <div class="card-body" id="detailBody">
                    @if (Model.Any())
                    {
                        <!-- 完整欄位（單一 ModbusID 時顯示） -->
                        <div id="fullDetail" class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.id"]</label>
                                <input type="text" class="form-control form-control-sm" id="fieldId" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.name"]</label>
                                <input type="text" class="form-control form-control-sm" id="fieldName" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.modbus_id"]</label>
                                <input type="text" class="form-control form-control-sm" id="fieldModbusID" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.delay_time"]</label>
                                <input type="text" class="form-control form-control-sm" id="fieldDelayTime" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.monitor_enabled"]</label>
                                <input type="text" class="form-control form-control-sm" id="fieldMonitorEnabled" readonly />
                            </div>
                        </div>

                        <!-- 子項目欄位（子選單項目點擊時顯示） -->
                        <div id="subDetail" class="row g-3" style="display:none;">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.id"]</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldId" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.modbus_id"]</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldModbusID" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">@Localizer["modbuscoordinator.label.sub_name"]</label>
                                <input type="text" class="form-control form-control-sm" id="subFieldName" />
                            </div>
                            <div class="col-12 mt-2">
                                <button class="btn btn-primary btn-sm" id="btnSaveName">
                                    <i class="fas fa-save me-1"></i>@Localizer["modbuscoordinator.btn.save_name"]
                                </button>
                                <span id="saveStatus" class="ms-2 small" style="display:none;"></span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-hand-pointer fa-3x mb-3 d-block"></i>
                            <p>@Localizer["modbuscoordinator.empty.guide"]</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <!-- 點位熱編輯 Modal（限 Admin）：讀寫 Engine Modbus JSON，存檔後 Engine 自動重載 -->
    <div class="modal fade" id="pointsModal" tabindex="-1" aria-labelledby="pointsTitle" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title" id="pointsTitle">
                        <i class="fas fa-list-ol me-1"></i>@Localizer["modbuscoordinator.points.title"]
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="small text-muted px-3 py-2 border-bottom" id="pointsDeviceInfo"></div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 points-table">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center points-col-seq">@Localizer["modbuscoordinator.points.col_seq"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_name"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_address"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_datatype"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_ratio"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_unit"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_min"]</th>
                                    <th>@Localizer["modbuscoordinator.points.col_max"]</th>
                                </tr>
                            </thead>
                            <tbody id="pointsTbody"></tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <span id="pointsStatus" class="small me-auto" style="display:none;"></span>
                    <button class="btn btn-outline-secondary btn-sm" id="btnReloadPoints">
                        <i class="fas fa-sync me-1"></i>@Localizer["modbuscoordinator.points.btn_reload"]
                    </button>
                    <button class="btn btn-primary btn-sm" id="btnSavePoints">
                        <i class="fas fa-save me-1"></i>@Localizer["modbuscoordinator.points.btn_save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        window._modbusCoordinatorData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    </script>
    <script src="~/js/modbuscoordinator.js"></script>
}
