@model ScadaEngine.Web.Features.EnergyReport.Models.EnergyReportViewModel
@{
    ViewData["Title"] = Localizer["energyreport.title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">
            <i class="fas fa-chart-bar text-primary me-2"></i>@Localizer["energyreport.title"]
        </h2>
        <span class="text-muted small">
            <i class="fas fa-leaf me-1"></i>@Localizer["energyreport.breadcrumb.energy"]
        </span>
    </div>

    <!-- 查詢條件 -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light py-2">
            <i class="fas fa-filter me-1"></i>@Localizer["energyreport.filter.title"]
        </div>
        <div class="card-body p-3">
            <div class="er-filter-bar">
                <div class="er-circuit">
                    <label class="form-label fw-semibold"><i class="fas fa-sitemap me-1"></i>@Localizer["energyreport.filter.circuit"]</label>
                    <select id="erCircuit" class="form-select form-select-sm">
                        <option value="">@Localizer["energyreport.select.loading"]</option>
                    </select>
                </div>
                <div class="er-narrow-unit">
                    <label class="form-label fw-semibold"><i class="fas fa-clock me-1"></i>@Localizer["energyreport.filter.granularity"]</label>
                    <select id="erGranularity" class="form-select form-select-sm">
                        <option value="hour">@Localizer["energyreport.granularity.hour"]</option>
                        <option value="day" selected>@Localizer["energyreport.granularity.day"]</option>
                        <option value="month">@Localizer["energyreport.granularity.month"]</option>
                        <option value="year">@Localizer["energyreport.granularity.year"]</option>
                    </select>
                </div>

                <!-- 時粒度：起訖時（日期 + 0~23 時，無分鐘） -->
                <div class="er-wide-date er-period er-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["energyreport.filter.hour_start"]</label>
                    <div class="input-group input-group-sm er-hour-group">
                        <input type="date" id="erHourStartDate" class="form-control form-control-sm">
                        <select id="erHourStartHour" class="form-select form-select-sm er-hour-select"></select>
                    </div>
                </div>
                <div class="er-wide-date er-period er-period-hour">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-day me-1"></i>@Localizer["energyreport.filter.hour_end"]</label>
                    <div class="input-group input-group-sm er-hour-group">
                        <input type="date" id="erHourEndDate" class="form-control form-control-sm">
                        <select id="erHourEndHour" class="form-select form-select-sm er-hour-select"></select>
                    </div>
                </div>

                <!-- 日粒度：起訖日 -->
                <div class="er-narrow-date er-period er-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["energyreport.filter.day_start"]</label>
                    <input type="date" id="erDayStart" class="form-control form-control-sm">
                </div>
                <div class="er-narrow-date er-period er-period-day">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar me-1"></i>@Localizer["energyreport.filter.day_end"]</label>
                    <input type="date" id="erDayEnd" class="form-control form-control-sm">
                </div>

                <!-- 月粒度：起訖月 -->
                <div class="er-narrow-date er-period er-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["energyreport.filter.month_start"]</label>
                    <input type="month" id="erMonthStart" class="form-control form-control-sm">
                </div>
                <div class="er-narrow-date er-period er-period-month">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-week me-1"></i>@Localizer["energyreport.filter.month_end"]</label>
                    <input type="month" id="erMonthEnd" class="form-control form-control-sm">
                </div>

                <!-- 年粒度：起訖年 -->
                <div class="er-narrow-date er-period er-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["energyreport.filter.year_start"]</label>
                    <input type="number" id="erYearStart" class="form-control form-control-sm" min="2000" max="2100">
                </div>
                <div class="er-narrow-date er-period er-period-year">
                    <label class="form-label fw-semibold"><i class="fas fa-calendar-alt me-1"></i>@Localizer["energyreport.filter.year_end"]</label>
                    <input type="number" id="erYearEnd" class="form-control form-control-sm" min="2000" max="2100">
                </div>

                <div class="er-btn">
                    <button class="btn btn-primary btn-sm" onclick="window._er.query()">
                        <i class="fas fa-search me-1"></i>@Localizer["energyreport.button.query"]
                    </button>
                </div>
                <div class="er-btn">
                    <button class="btn btn-success btn-sm" onclick="window._er.exportExcel()" id="btnExport" disabled>
                        <i class="fas fa-file-excel me-1"></i>@Localizer["energyreport.button.export"]
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 結果區 -->
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-chart-bar me-1"></i>@Localizer["energyreport.chart.title"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small" id="erWarnText"></span>
                        <button type="button" id="btnToggleBreakdown" class="btn btn-sm btn-outline-secondary d-none" onclick="window._er.toggleBreakdown()">
                            <i class="fas fa-layer-group me-1"></i><span id="btnToggleBreakdownText">@Localizer["energyreport.button.show_breakdown"]</span>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div style="height:360px;">
                        <canvas id="erChart"></canvas>
                    </div>
                </div>
                <div class="card-footer bg-light text-muted small">
                    @Localizer["energyreport.label.total"]：<span id="erTotal" class="fw-bold text-primary">--</span> kWh
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-light py-2">
                    <i class="fas fa-table me-1"></i>@Localizer["energyreport.table.title"]
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:420px;overflow-y:auto;">
                        <table class="table table-striped table-hover table-bordered mb-0">
                            <thead class="table-dark" style="position:sticky;top:0;z-index:30;">
                                <tr>
                                    <th>@Localizer["energyreport.table.col_period"]</th>
                                    <th class="text-end">@Localizer["energyreport.table.col_kwh"]</th>
                                </tr>
                            </thead>
                            <tbody id="erTableBody">
                                <tr><td colspan="2" class="text-center text-muted py-4">@Localizer["energyreport.table.empty"]</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/energyreport.css" />

@section Scripts {
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/js/energyreport.js"></script>
    <script>
        window._erInit = { today: '@Model.dtToday.ToString("yyyy-MM-dd")' };
    </script>
}
