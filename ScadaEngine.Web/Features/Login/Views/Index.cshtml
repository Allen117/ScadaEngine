@model ScadaEngine.Web.Features.Login.Models.LoginModel
@{
    ViewData["Title"] = "SCADA 系統登入";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-shell">
    <!-- 品牌區：系統名 + 副標 -->
    <div class="login-brand">
        <h1 class="login-brand-title">SCADA 智慧能源管理平台</h1>
        <div class="login-brand-subtitle">AI-Powered Energy Intelligence</div>
    </div>

    <div class="card login-card">
        <div class="card-body">
            <h2 class="login-title fs-3">
                <i class="fas fa-bolt"></i>
                系統登入
            </h2>

            @if (ViewData["SetupHint"] as bool? == true)
            {
                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle"></i>
                    系統尚無管理者帳號，請於伺服器本機開啟
                    <strong>http://localhost:5038</strong> 完成初始設定。
                </div>
            }

            <form asp-action="Index" asp-controller="Login" method="post" id="frmLogin">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <!-- 使用者名稱輸入框 -->
                <div class="mb-3">
                    <label asp-for="szUserName" class="form-label">
                        <i class="fas fa-user"></i>
                        使用者名稱
                    </label>
                    <input asp-for="szUserName"
                           class="form-control"
                           id="tbUserName"
                           placeholder="請輸入使用者名稱"
                           autocomplete="username"
                           required />
                    <span asp-validation-for="szUserName" class="text-danger"></span>
                </div>

                <!-- 密碼輸入框 -->
                <div class="mb-3">
                    <label asp-for="szPassword" class="form-label">
                        <i class="fas fa-key"></i>
                        密碼
                    </label>
                    <input asp-for="szPassword"
                           type="password"
                           class="form-control"
                           id="tbPassword"
                           placeholder="請輸入密碼"
                           autocomplete="current-password"
                           required />
                    <span asp-validation-for="szPassword" class="text-danger"></span>
                </div>

                <!-- 記住我選項 -->
                <div class="mb-3 form-check">
                    <input asp-for="isRememberMe"
                           type="checkbox"
                           class="form-check-input"
                           id="chkRememberMe" />
                    <label asp-for="isRememberMe" class="form-check-label">
                        記住我
                    </label>
                </div>

                <!-- 登入按鈕 -->
                <div class="d-grid">
                    <button type="submit"
                            class="btn btn-primary btn-lg btn-login"
                            id="btnLogin">
                        <i class="fas fa-sign-in-alt"></i>
                        立即登入
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 卡片下方特色圖示橫排 -->
    <div class="login-features">
        <div class="login-feature">
            <div class="login-feature-icon"><i class="fas fa-tachometer-alt"></i></div>
            <div class="login-feature-label">即時監控</div>
        </div>
        <div class="login-feature">
            <div class="login-feature-icon"><i class="fas fa-brain"></i></div>
            <div class="login-feature-label">AI 分析</div>
        </div>
        <div class="login-feature">
            <div class="login-feature-icon"><i class="fas fa-leaf"></i></div>
            <div class="login-feature-label">節能優化</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
}
