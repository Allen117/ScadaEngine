<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SCADA 監控系統</title>
    
    <!-- Bootstrap 5.3.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome 6 Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- 自訂樣式 -->
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }
        
        .footer {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px 0;
            margin-top: auto;
        }
        
        main {
            min-height: calc(100vh - 140px);
        }
        
        .card {
            border: none;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }
        
        .btn-primary {
            background: linear-gradient(45deg, #007bff, #0056b3);
            border: none;
        }
        
        .btn-primary:hover {
            background: linear-gradient(45deg, #0056b3, #004085);
            transform: translateY(-1px);
        }
        
        .text-primary {
            color: #007bff !important;
        }
    </style>
</head>
<body class="d-flex flex-column">
    <!-- 導覽列 -->
    @if (ViewData["ShowNavigation"]?.ToString() != "false")
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-industry me-2"></i>
                    SCADA 監控系統
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/RealTime">
                                <i class="fas fa-tachometer-alt me-1"></i>
                                即時數據
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/ControlAlgorithm">
                                <i class="fas fa-microchip me-1"></i>
                                控制邏輯
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-chart-line me-1"></i>
                                歷史資料
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/History/Trend">趨勢圖</a></li>
                                <li><a class="dropdown-item" href="/History/Report">報表查詢</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Config">
                                <i class="fas fa-cogs me-1"></i>
                                系統設定
                            </a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user me-1"></i>
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="/Account/Profile">個人資料</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="#"
                                           onclick="showLogoutModal(event)">
                                            <i class="fas fa-sign-out-alt me-1"></i>登出
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>
                                    登入
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    }
    
    <!-- 主要內容 -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- 頁腳 -->
    @if (ViewData["ShowNavigation"]?.ToString() != "false")
    {
        <footer class="footer mt-auto">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h6><i class="fas fa-industry me-2"></i>SCADA 監控系統</h6>
                        <p class="mb-0">工業監控與資料採集系統</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p class="mb-1">
                            <i class="fas fa-code me-1"></i>
                            版本 1.0.0 | 
                            <i class="fas fa-calendar me-1"></i>
                            @DateTime.Now.Year 工研院
                        </p>
                        <p class="mb-0">
                            <small>
                                <i class="fas fa-server me-1"></i>
                                伺服器時間: <span id="serverClock"></span>
                            </small>
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    }

    <!-- 登出確認 Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title" id="logoutModalLabel">
                        <i class="fas fa-sign-out-alt text-danger me-2"></i>確認登出
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-3">
                    <p class="mb-1">確定要登出嗎？</p>
                    <small class="text-muted">登出後需重新輸入帳號密碼</small>
                </div>
                <div class="modal-footer border-0 pt-0 justify-content-center gap-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-danger btn-sm" onclick="confirmLogout()">確認登出</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 登出用隱藏表單 (POST + AntiForgeryToken) -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <form id="logoutForm" action="/Login/Logout" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>
    }

    <!-- Bootstrap 5.3.3 JavaScript Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            function updateClock() {
                var now = new Date();
                var pad = function (n) { return n.toString().padStart(2, '0'); };
                var s = now.getFullYear() + '-' + pad(now.getMonth() + 1) + '-' + pad(now.getDate()) +
                    ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds());
                var el = document.getElementById('serverClock');
                if (el) el.textContent = s;
            }
            updateClock();
            setInterval(updateClock, 1000);
        })();

        function showLogoutModal(e) {
            e.preventDefault();
            new bootstrap.Modal(document.getElementById('logoutModal')).show();
        }
        function confirmLogout() {
            document.getElementById('logoutForm').submit();
        }
    </script>

    <!-- 頁面特定 JavaScript -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>