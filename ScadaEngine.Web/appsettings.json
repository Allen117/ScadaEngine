{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EnergyAggregation": {
    "MaxStalenessHours": 2
  },
  "ScadaPageAccumulation": {
    "MaxStalenessHours": 2,
    "MaxGapMinutes": 5,
    "ResultCacheSeconds": 30
  },
  "ElectricityCost": {
    "CatchUpDays": 7
  },
  "EngineModbusConfig": {
    "WatchedFolder": "C:/SCADA/Engine/App/Modbus",
    "MirrorFolder": "../ScadaEngine.Engine/Modbus"
  },
  "EngineOpcUaConfig": {
    "WatchedFolder": "C:/SCADA/Engine/App/OpcUaPoint",
    "MirrorFolder": "../ScadaEngine.Engine/OpcUaPoint"
  },
  "EngineDbPointConfig": {
    "WatchedFolder": "C:/SCADA/Engine/App/DBPoint",
    "MirrorFolder": "../ScadaEngine.Engine/DBPoint"
  }
}
